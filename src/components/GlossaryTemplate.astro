---
import { GENERATORS, urlFor, CATEGORIES_ES, CATEGORIES_EN } from '../lib/generators';
import type { Lang } from '../lib/i18n';
import { SITE_URL } from '../lib/i18n';
import type { GlossaryEntry } from '../lib/glossary-data/types';

export interface Props {
  lang: Lang;
  entry: GlossaryEntry;
}

const { lang, entry } = Astro.props;
const t = entry[lang];

const homeHref = lang === 'es' ? '/' : '/en';
const homeLabel = lang === 'es' ? 'Inicio' : 'Home';
const glossaryHref = lang === 'es' ? '/glosario' : '/en/glossary';
const glossaryLabel = lang === 'es' ? 'Glosario' : 'Glossary';
const relatedTitle = lang === 'es' ? 'Generadores relacionados' : 'Related generators';
const examplesTitle = lang === 'es' ? 'Ejemplos' : 'Examples';
const faqTitle = lang === 'es' ? 'Preguntas frecuentes' : 'FAQ';

const slugKey = lang === 'es' ? 'es' : 'en';
const related = t.related
  .map(s => GENERATORS.find(g => g.slug[slugKey] === s))
  .filter((g): g is NonNullable<typeof g> => !!g);

const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '');
const breadcrumbSchema = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `${SITE_URL}${homeHref}` },
    { '@type': 'ListItem', position: 2, name: glossaryLabel, item: `${SITE_URL}${glossaryHref}` },
    { '@type': 'ListItem', position: 3, name: t.h1, item: `${SITE_URL}${path}` },
  ],
};

const definedTermSchema = {
  '@context': 'https://schema.org', '@type': 'DefinedTerm',
  name: t.h1, description: t.short, inDefinedTermSet: { '@type': 'DefinedTermSet', name: 'Genfy Glossary', url: `${SITE_URL}${glossaryHref}` },
};
---
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)}></script>

<div class="glo-page">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={homeHref}>{homeLabel}</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <a href={glossaryHref}>{glossaryLabel}</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="crumb-current">{t.h1}</span>
  </nav>

  <header class="glo-hero">
    <span class="glo-emoji">{entry.emoji}</span>
    <h1>{t.h1}</h1>
    <p class="glo-short">{t.short}</p>
  </header>

  <article class="glo-body">
    {t.body.map(s => (
      <section>
        <h2>{s.h2}</h2>
        <Fragment set:html={s.html} />
      </section>
    ))}

    {t.examples && t.examples.length > 0 && (
      <section>
        <h2>{examplesTitle}</h2>
        <ul class="glo-examples">
          {t.examples.map(ex => (<li><code>{ex}</code></li>))}
        </ul>
      </section>
    )}

    {t.faq.length > 0 && (
      <section>
        <h2>{faqTitle}</h2>
        <div class="glo-faq">
          {t.faq.map(f => (
            <details><summary>{f.q}</summary><p>{f.a}</p></details>
          ))}
        </div>
      </section>
    )}
  </article>

  {related.length > 0 && (
    <section class="glo-related">
      <h2>{relatedTitle}</h2>
      <div class="glo-related-grid">
        {related.map(g => (
          <a class="glo-related-card" href={urlFor(g, lang)}>
            <span class="glo-related-emoji">{g.emoji}</span>
            <span class="glo-related-title">{g.title[lang]}</span>
            <span class="glo-related-desc">{g.description[lang]}</span>
            <span class="glo-related-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  )}
</div>

<style>
  .glo-page { max-width: 760px; margin: 0 auto; }
  .crumbs { display: flex; gap: 0.5rem; align-items: center; color: var(--text-muted); font-size: 0.8125rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .crumbs a { color: var(--text-subtle); text-decoration: none; }
  .crumbs a:hover { color: var(--text); }
  .crumb-sep { color: var(--text-muted); flex-shrink: 0; }
  .crumb-current { color: var(--text); font-weight: 500; }

  .glo-hero { text-align: left; padding: 1.5rem 0 2rem; border-bottom: 1px solid var(--border-soft); margin-bottom: 2rem; }
  .glo-emoji { font-size: 2.25rem; line-height: 1; display: inline-block; margin-bottom: 0.75rem; }
  .glo-hero h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.75rem; letter-spacing: -0.02em; }
  .glo-short { font-size: 1.0625rem; color: var(--text-soft); margin: 0; line-height: 1.55; max-width: 60ch; }

  .glo-body section { margin-bottom: 2.5rem; }
  .glo-body h2 { font-size: 1.25rem; font-weight: 700; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-soft); }
  .glo-body :global(p) { color: var(--text); line-height: 1.65; max-width: 64ch; }
  .glo-body :global(ul), .glo-body :global(ol) { color: var(--text-soft); padding-left: 1.5rem; max-width: 62ch; }
  .glo-body :global(li) { margin-bottom: 0.5rem; }
  .glo-body :global(code) { background: var(--bg-inset); padding: 0.125rem 0.375rem; border-radius: 4px; font-family: var(--font-mono); font-size: 0.875em; }
  .glo-body :global(pre) { background: var(--bg-inset); padding: 1rem; border-radius: var(--radius); overflow-x: auto; }
  .glo-examples { list-style: none; padding: 0; }
  .glo-examples li { background: var(--bg-inset); padding: 0.5rem 0.75rem; border-radius: var(--radius-sm); margin-bottom: 0.375rem; }

  .glo-faq details {
    padding: 0.875rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius);
    margin-bottom: 0.5rem;
  }
  .glo-faq summary { cursor: pointer; font-weight: 600; }
  .glo-faq p { margin: 0.5rem 0 0; color: var(--text-soft); }

  .glo-related { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--border-soft); }
  .glo-related h2 { font-size: 1.25rem; margin: 0 0 1.25rem; }
  .glo-related-grid { display: grid; grid-template-columns: 1fr; gap: 0.625rem; }
  @media (min-width: 600px) { .glo-related-grid { grid-template-columns: 1fr 1fr; } }
  .glo-related-card {
    position: relative;
    display: flex; flex-direction: column; gap: 0.25rem;
    padding: 1rem 1.125rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none; color: var(--text);
    transition: border-color 180ms var(--ease), transform 180ms var(--ease);
  }
  .glo-related-card:hover { border-color: var(--accent); transform: translateY(-1px); text-decoration: none; }
  .glo-related-emoji { font-size: 1.25rem; }
  .glo-related-title { font-weight: 600; font-size: 0.9375rem; }
  .glo-related-desc { color: var(--text-soft); font-size: 0.8125rem; line-height: 1.5; }
  .glo-related-arrow { position: absolute; top: 1rem; right: 1.125rem; color: var(--text-muted); }
</style>
