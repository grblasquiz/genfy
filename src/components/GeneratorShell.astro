---
import AdSlot from './AdSlot.astro';
import { t, type Lang } from '../lib/i18n';

export interface Props {
  lang?: Lang;
  title: string;
  intro: string;
  tag?: string;
}

const { lang = 'es', title, intro, tag } = Astro.props;
const tt = t[lang];
---
<section class="gen-hero">
  {tag && <span class="tag">{tag}</span>}
  <h1>{title}</h1>
  <p class="lead">{intro}</p>
</section>

<div class="gen-tool card">
  <slot name="tool" />
</div>

<AdSlot variant="inline" slot="in-content-1" label={lang === 'en' ? 'Sponsored' : 'Publicidad'} />

<section class="gen-content">
  <slot name="content" />
</section>

<AdSlot variant="inline" slot="in-content-2" label={lang === 'en' ? 'Sponsored' : 'Publicidad'} />

<section class="gen-faq faq">
  <h2>{tt.faqTitle}</h2>
  <slot name="faq" />
</section>

<style>
  .gen-hero { margin-bottom: 1.5rem; }
  .gen-hero .lead { font-size: 1.0625rem; color: var(--text-soft); max-width: 65ch; }
  .gen-tool { margin-bottom: 1.5rem; }
  .gen-content :global(h2) { margin-top: 2rem; }
  .gen-content :global(p) { max-width: 70ch; }
  .gen-content :global(ul), .gen-content :global(ol) { color: var(--text-soft); padding-left: 1.5rem; }
  .gen-content :global(li) { margin-bottom: 0.375rem; }
</style>
