---
const PUBLISHER_ID = ''; // ca-pub-XXXXXXXXXXXXXXXX
const isDev = import.meta.env.DEV;

export interface Props {
  slot?: string;
  format?: 'auto' | 'fluid' | 'rectangle' | 'horizontal' | 'vertical';
  layout?: string;
  responsive?: boolean;
  label?: string;
  variant?: 'inline' | 'sidebar' | 'anchor';
}

const {
  slot = '0000000000',
  format = 'auto',
  layout,
  responsive = true,
  label = 'Ad',
  variant = 'inline',
} = Astro.props;

const enabled = !!PUBLISHER_ID;
---

{enabled && (
  <div class={`ad-slot ad-${variant}`} data-slot={slot}>
    <span class="ad-label">{label}</span>
    <ins
      class="adsbygoogle"
      style="display:block"
      data-ad-client={PUBLISHER_ID}
      data-ad-slot={slot}
      data-ad-format={format}
      data-ad-layout={layout}
      data-full-width-responsive={responsive ? 'true' : 'false'}
    ></ins>
    <script is:inline>
      (window.adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
)}

{!enabled && isDev && (
  <div class={`ad-slot ad-${variant} ad-placeholder`} data-slot={slot}>
    <span class="ad-label">{label}</span>
    <span class="ad-placeholder-tag">{variant} · {slot}</span>
  </div>
)}

<style>
  .ad-slot { margin: 2rem 0; min-height: 100px; }
  .ad-label {
    display: block;
    font-size: 0.6875rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }
  .ad-sidebar { min-height: 280px; margin-top: 0; }
  .ad-anchor {
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 50;
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    padding: 0.625rem 1rem;
    margin: 0;
    text-align: center;
  }
  @media (min-width: 768px) { .ad-anchor { display: none; } }
  .ad-placeholder {
    padding: 1.75rem 1rem;
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius);
    background: var(--bg-inset);
    text-align: center;
  }
  .ad-placeholder-tag {
    display: block;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }
</style>
