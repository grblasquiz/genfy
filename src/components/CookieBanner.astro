---
import { type Lang } from '../lib/i18n';
const { lang = 'es' } = Astro.props as { lang?: Lang };
const t = lang === 'es' ? {
  msg: 'Usamos cookies para analítica y publicidad. Al continuar aceptás su uso.',
  accept: 'Aceptar',
  privacy: 'Política',
  privacyHref: '/privacidad',
} : {
  msg: 'We use cookies for analytics and ads. By continuing you agree to their use.',
  accept: 'Accept',
  privacy: 'Privacy',
  privacyHref: '/en/privacy',
};
---
<div class="cookie-banner" id="cookie-banner" hidden>
  <p>{t.msg} <a href={t.privacyHref}>{t.privacy}</a></p>
  <button class="btn btn-primary" id="cookie-accept" type="button">{t.accept}</button>
</div>

<script is:inline>
  (function() {
    const KEY = 'genfy:cookie-ack:v1';
    const banner = document.getElementById('cookie-banner');
    const accept = document.getElementById('cookie-accept');
    if (!banner || !accept) return;
    try {
      if (!localStorage.getItem(KEY)) banner.hidden = false;
    } catch (e) {}
    accept.addEventListener('click', () => {
      try { localStorage.setItem(KEY, '1'); } catch (e) {}
      banner.hidden = true;
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 60;
    max-width: 520px;
    margin: 0 auto;
    padding: 0.875rem 1.125rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    animation: slide-up 280ms var(--ease);
  }
  .cookie-banner p { margin: 0; flex: 1; min-width: 240px; font-size: 0.8125rem; color: var(--text-soft); line-height: 1.5; }
  .cookie-banner a { color: var(--text); text-decoration-color: var(--accent); }
  .cookie-banner .btn { padding: 0.5rem 0.875rem; font-size: 0.8125rem; }
  .cookie-banner[hidden] { display: none; }
</style>
