---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Tester de regex (expresiones regulares) | Genfy';
const description = 'Probá expresiones regulares en tiempo real con resaltado de coincidencias. Compatible con sintaxis JavaScript. 100% local.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué dialecto de regex usa?', acceptedAnswer: { '@type': 'Answer', text: 'JavaScript (ECMAScript). Es muy parecido a PCRE pero con diferencias menores: lookbehinds, named groups, flags. Si tu regex viene de Python o Perl, podría requerir ajustes.' } },
    { '@type': 'Question', name: '¿Qué flags soporta?', acceptedAnswer: { '@type': 'Answer', text: 'g (global), i (case insensitive), m (multiline), s (dotall), u (unicode), y (sticky). Combinás varias seleccionando los checkboxes correspondientes.' } },
    { '@type': 'Question', name: '¿Mi texto se sube a un servidor?', acceptedAnswer: { '@type': 'Answer', text: 'No. El test se hace 100% en el navegador con el motor de regex nativo de JavaScript. Tu texto y patrón nunca salen del dispositivo.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Dev" title="Tester de regex"
    intro="Probá expresiones regulares con resaltado en tiempo real, conteo de matches y captura de grupos. Compatible con sintaxis JavaScript.">

    <div slot="tool">
      <label for="rx-pat">Patrón</label>
      <input id="rx-pat" type="text" value="\b\w+@\w+\.\w+\b" style="font-family: var(--font-mono);" />
      <div class="rx-flags">
        <label class="chk"><input type="checkbox" id="f-g" checked /> g (global)</label>
        <label class="chk"><input type="checkbox" id="f-i" /> i (insensitive)</label>
        <label class="chk"><input type="checkbox" id="f-m" /> m (multiline)</label>
        <label class="chk"><input type="checkbox" id="f-s" /> s (dotall)</label>
        <label class="chk"><input type="checkbox" id="f-u" /> u (unicode)</label>
      </div>
      <label for="rx-text" style="margin-top:1rem;">Texto</label>
      <textarea id="rx-text" rows="6" style="font-family: var(--font-mono); font-size: 0.9rem;">Contactos:
ana@ejemplo.com
pedro_lopez@correo.com.ar
admin@genfy.net</textarea>
      <div id="rx-status" class="rx-status"></div>
      <label style="margin-top:1rem;">Coincidencias</label>
      <div id="rx-matches" class="rx-matches"></div>
    </div>

    <div slot="content">
      <h2>Qué es una expresión regular</h2>
      <p>
        Una regex (regular expression) es un mini lenguaje para describir patrones en texto. Con unos pocos caracteres podés decir cosas como "una secuencia de tres dígitos seguida de un guion y cuatro dígitos más" (un teléfono <code>\d&lcub;3&rcub;-\d&lcub;4&rcub;</code>) o "un email" (<code>\b\w+@\w+\.\w+\b</code>). Existen desde 1968 y siguen siendo la herramienta más concisa para validar, extraer y reemplazar texto.
      </p>

      <h2>Caracteres más usados</h2>
      <ul>
        <li><code>.</code> — cualquier carácter excepto salto de línea.</li>
        <li><code>\d</code> — un dígito (0-9).</li>
        <li><code>\w</code> — un carácter de palabra (letra, dígito, underscore).</li>
        <li><code>\s</code> — un espacio (incluye tabs y saltos de línea).</li>
        <li><code>+</code> — uno o más del anterior.</li>
        <li><code>*</code> — cero o más del anterior.</li>
        <li><code>?</code> — cero o uno del anterior.</li>
        <li><code>&lcub;n,m&rcub;</code> — entre n y m repeticiones.</li>
        <li><code>^</code> — inicio de línea (con flag m) o inicio del string.</li>
        <li><code>$</code> — fin de línea o del string.</li>
        <li><code>[abc]</code> — uno de a, b o c.</li>
        <li><code>[^abc]</code> — cualquier cosa menos a, b o c.</li>
      </ul>

      <h2>Patrones comunes que vale la pena memorizar</h2>
      <ul>
        <li><strong>Email simple:</strong> <code>\b[\w.-]+@[\w.-]+\.\w+\b</code> — captura la mayoría de emails reales.</li>
        <li><strong>URL:</strong> <code>https?://\S+</code> — http o https seguido de cualquier carácter no espacio.</li>
        <li><strong>IP v4:</strong> <code>\b\d&lcub;1,3&rcub;\.\d&lcub;1,3&rcub;\.\d&lcub;1,3&rcub;\.\d&lcub;1,3&rcub;\b</code>.</li>
        <li><strong>Fecha YYYY-MM-DD:</strong> <code>\d&lcub;4&rcub;-\d&lcub;2&rcub;-\d&lcub;2&rcub;</code>.</li>
        <li><strong>Hex color:</strong> <code>#[0-9a-fA-F]&lcub;3,8&rcub;</code>.</li>
        <li><strong>Solo dígitos:</strong> <code>^\d+$</code> con flag m para validar línea por línea.</li>
      </ul>

      <h2>Flags y qué cambian</h2>
      <ul>
        <li><strong>g (global):</strong> sin esto, regex devuelve solo el primer match. Casi siempre la querés.</li>
        <li><strong>i (insensitive):</strong> ignora mayúsculas/minúsculas. <code>/Hola/i</code> matchea HOLA, hola, HoLa.</li>
        <li><strong>m (multiline):</strong> hace que <code>^</code> y <code>$</code> coincidan con inicio/fin de línea, no solo de string.</li>
        <li><strong>s (dotall):</strong> hace que <code>.</code> también matchee saltos de línea.</li>
        <li><strong>u (unicode):</strong> tratamiento correcto de caracteres Unicode complejos.</li>
        <li><strong>y (sticky):</strong> el match arranca desde lastIndex.</li>
      </ul>

      <h2>Trampas frecuentes</h2>
      <ul>
        <li><strong>Greedy vs lazy.</strong> <code>.*</code> es greedy: agarra todo lo que pueda. <code>.*?</code> es lazy: agarra lo mínimo. Para extraer "el contenido entre comillas más cercano", usá lazy.</li>
        <li><strong>Olvidarse del flag g.</strong> Sin g, replace solo cambia el primer match. <code>"aaa".replace(/a/, 'b')</code> da "baa", no "bbb".</li>
        <li><strong>Escapes en strings.</strong> En JavaScript, <code>"\d"</code> no es lo mismo que <code>"\\d"</code>. En literales <code>/\d/</code> está bien; en strings hay que doblar.</li>
        <li><strong>Catastrophic backtracking.</strong> Patrones como <code>(a+)+b</code> sobre input largo pueden colgar el browser. Usá patrones lineales si vas a procesar texto grande.</li>
      </ul>

      <h2>Cuándo NO usar regex</h2>
      <p>
        Para parsear HTML, JSON, CSV o cualquier formato anidado, regex es una mala idea. Esos formatos requieren parsers reales. La famosa respuesta de Stack Overflow "you cannot parse [X]HTML with regex" es una verdad universal: regex solo entiende lenguajes regulares, y HTML no es regular. Para esos casos usá el parser nativo (DOMParser, JSON.parse, una lib de CSV).
      </p>

      <h2>Tips de productividad</h2>
      <p>
        Si vas a usar la misma regex en varios lugares, ponele un nombre y comentala. Las regex son ilegibles a primera vista; un comentario ahorra debugging. En JavaScript, podés usar <code>//x</code> con la flag x en algunos engines (no en JS estándar) o construir la regex con <code>new RegExp(string)</code> partiendo de partes nombradas. En código real, considerá librerías como Yup o Zod para validación, que abstraen las regex más comunes con APIs declarativas.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Qué dialecto de regex usa?</summary><p>JavaScript (ECMAScript). Muy parecido a PCRE con diferencias menores.</p></details>
      <details><summary>¿Qué flags soporta?</summary><p>g, i, m, s, u, y. Combinables seleccionando los checkboxes.</p></details>
      <details><summary>¿Mi texto se sube a un servidor?</summary><p>No. Es 100% local en el browser.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .rx-flags { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 0.75rem; }
  .chk { display: flex; align-items: center; gap: 0.4rem; margin: 0; font-size: 0.9rem; }
  .chk input { width: auto; }
  .rx-status { font-family: var(--font-mono); font-size: 0.85rem; margin-top: 0.75rem; min-height: 1.25rem; color: var(--text-soft); }
  .rx-status.err { color: var(--danger); }
  .rx-matches { background: var(--bg-inset); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; min-height: 4rem; font-family: var(--font-mono); font-size: 0.85rem; max-height: 240px; overflow: auto; }
  .rx-match { display: block; padding: 0.25rem 0; }
  .rx-match mark { background: var(--accent-soft); color: var(--text); padding: 0.05rem 0.2rem; border-radius: 3px; }
</style>

<script>
  const patEl = document.getElementById('rx-pat') as HTMLInputElement;
  const textEl = document.getElementById('rx-text') as HTMLTextAreaElement;
  const status = document.getElementById('rx-status') as HTMLDivElement;
  const matches = document.getElementById('rx-matches') as HTMLDivElement;
  const flags = ['g','i','m','s','u'];

  function escapeHtml(s: string) { return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  function getFlags(): string {
    let f = '';
    for (const x of flags) {
      const el = document.getElementById('f-' + x) as HTMLInputElement;
      if (el && el.checked) f += x;
    }
    return f;
  }

  function run() {
    const pat = patEl.value;
    if (!pat) { matches.innerHTML = ''; status.textContent = ''; status.className = 'rx-status'; return; }
    try {
      const re = new RegExp(pat, getFlags());
      const text = textEl.value;
      const found: { match: string; index: number }[] = [];
      let m: RegExpExecArray | null;
      if (re.global) {
        while ((m = re.exec(text)) !== null) {
          found.push({ match: m[0], index: m.index });
          if (m.index === re.lastIndex) re.lastIndex++;
        }
      } else {
        m = re.exec(text);
        if (m) found.push({ match: m[0], index: m.index });
      }
      status.textContent = `${found.length} coincidencia${found.length !== 1 ? 's' : ''}`;
      status.className = 'rx-status';
      if (found.length === 0) { matches.innerHTML = '<em>Sin coincidencias</em>'; return; }
      // Build highlighted text
      let html = '';
      let last = 0;
      for (const f of found) {
        html += escapeHtml(text.slice(last, f.index));
        html += '<mark>' + escapeHtml(f.match) + '</mark>';
        last = f.index + f.match.length;
      }
      html += escapeHtml(text.slice(last));
      matches.innerHTML = '<pre style="margin:0; white-space: pre-wrap;">' + html + '</pre>';
    } catch (e: any) {
      status.textContent = 'Error: ' + (e.message || 'regex inválida');
      status.className = 'rx-status err';
      matches.innerHTML = '';
    }
  }

  patEl.addEventListener('input', run);
  textEl.addEventListener('input', run);
  flags.forEach(f => {
    const el = document.getElementById('f-' + f);
    if (el) el.addEventListener('change', run);
  });
  run();
</script>
