---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de números de factura | Genfy';
const description = 'Generá números de factura profesionales: secuenciales con prefijo y año, aleatorios o con checksum. Útil para freelancers, pymes y estudios.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cuál es el formato más usado?', acceptedAnswer: { '@type': 'Answer', text: 'INV-YYYY-#### es el estándar internacional: prefijo "INV", año, y un correlativo zero-padded. También se usa A-2026-0001 cuando hay varias series.' } },
    { '@type': 'Question', name: '¿Pueden tener números no consecutivos?', acceptedAnswer: { '@type': 'Answer', text: 'Depende del país. En la mayoría de jurisdicciones la facturación tiene que ser correlativa para auditoría fiscal. Verificá con tu contador.' } },
    { '@type': 'Question', name: '¿Para qué sirve el checksum?', acceptedAnswer: { '@type': 'Answer', text: 'Detecta errores de tipeo cuando alguien transcribe el número de factura. Útil para sistemas de cobro automáticos o portales de pago.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Trabajo / Work" title="Generador de números de factura"
    intro="Construí formatos de número de factura listos para usar: con prefijo, año, secuencial o aleatorio. Ideal para freelancers, pymes y estudios.">

    <div slot="tool" class="iv">
      <div class="iv-row">
        <div>
          <label for="iv-prefix">Prefijo</label>
          <input id="iv-prefix" type="text" value="INV" maxlength="6" />
        </div>
        <div>
          <label for="iv-year">Año</label>
          <input id="iv-year" type="number" value="2026" min="2000" max="2100" />
        </div>
        <div>
          <label for="iv-pad">Dígitos del correlativo</label>
          <input id="iv-pad" type="number" value="4" min="3" max="8" />
        </div>
      </div>
      <div class="iv-row">
        <div>
          <label for="iv-mode">Modo</label>
          <select id="iv-mode">
            <option value="seq">Secuencial</option>
            <option value="random">Aleatorio</option>
            <option value="checksum">Con checksum</option>
          </select>
        </div>
        <div>
          <label for="iv-start">Inicio (secuencial)</label>
          <input id="iv-start" type="number" value="1" min="1" />
        </div>
        <div>
          <label for="iv-amount">Cantidad</label>
          <input id="iv-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="iv-gen" class="btn btn-primary" type="button">Generar</button>
      <button id="iv-copy" class="btn btn-ghost" type="button">Copiar</button>
      <textarea id="iv-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>Cómo elegir un formato profesional</h2>
      <p>
        El número de factura no es un detalle estético: es la clave que une tu trabajo
        contable, tu sistema de cobranzas y tu auditoría fiscal. El estándar más extendido es
        <strong>INV-YYYY-####</strong>: prefijo "INV", año en cuatro dígitos, y un correlativo
        con padding de ceros (0001, 0002, etc.). Es legible, ordenable cronológicamente y deja
        margen para hasta 9.999 facturas por año. Si superás ese volumen, ampliá a 5 dígitos.
      </p>

      <h2>Modos del generador</h2>
      <ul>
        <li><strong>Secuencial.</strong> El estándar para facturación legal: arranca en el número que vos elijas y va sumando 1.</li>
        <li><strong>Aleatorio.</strong> Útil para presupuestos, órdenes internas o pruebas, donde no hay obligación correlativa.</li>
        <li><strong>Con checksum.</strong> Agrega un dígito final calculado por Luhn (el mismo de las tarjetas de crédito) para detectar errores de transcripción.</li>
      </ul>

      <h2>Por qué la facturación es correlativa</h2>
      <p>
        En Argentina (AFIP), España (Hacienda), México (SAT) y la mayoría de jurisdicciones,
        la facturación debe ser correlativa por punto de venta. Si vos emitís A-001-00000005,
        la siguiente tiene que ser A-001-00000006. Saltar números o repetirlos genera
        observaciones fiscales. Por eso el modo "secuencial" es el correcto para tu sistema
        oficial; el aleatorio es solo para documentos internos.
      </p>

      <h2>El checksum (Luhn) y para qué sirve</h2>
      <p>
        El algoritmo de Luhn agrega un dígito al final que se calcula a partir del resto del
        número. Si alguien tipea mal un dígito (o invierte dos), el checksum no cierra y el
        sistema rechaza el ingreso antes de procesarlo. Es el mismo principio de las tarjetas
        de crédito y los IBAN europeos. No es seguridad criptográfica — es simplemente un
        guardia contra errores humanos.
      </p>

      <h2>Buenas prácticas</h2>
      <ol>
        <li><strong>Reseteá el correlativo cada año.</strong> Hace más fácil archivar y reportar.</li>
        <li><strong>Usá series por tipo de documento.</strong> Factura A, factura B, presupuesto, recibo: cada uno con su prefijo y su correlativo.</li>
        <li><strong>Guardá un registro central.</strong> Hoja de cálculo o sistema. Saber cuál es tu próximo número evita duplicados.</li>
        <li><strong>No uses datos del cliente en el número.</strong> Mantenelo neutro: el cliente va en el cuerpo de la factura, no en su ID.</li>
        <li><strong>Backup.</strong> Si tu sistema se cae, querés saber dónde quedó la numeración. Exportá tu serie cada mes.</li>
      </ol>

      <h2>Ejemplos de formato listos para copiar</h2>
      <ul>
        <li><code>INV-2026-0001</code> — formato anglosajón estándar.</li>
        <li><code>FA-2026-0001</code> — variante en español ("Factura A").</li>
        <li><code>0001-00000001</code> — formato de punto de venta argentino (AFIP).</li>
        <li><code>2026/000001</code> — formato europeo simple, año/correlativo.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>¿Formato más usado?</summary><p>INV-YYYY-####: prefijo, año y correlativo zero-padded.</p></details>
      <details><summary>¿Pueden ser no consecutivos?</summary><p>En la mayoría de países deben ser correlativos. Verificá con tu contador.</p></details>
      <details><summary>¿Para qué el checksum?</summary><p>Para detectar errores de tipeo en sistemas automáticos de cobro.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .iv-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .iv-row { grid-template-columns: 1fr; } }
</style>

<script>
  const prefixEl = document.getElementById('iv-prefix') as HTMLInputElement;
  const yearEl = document.getElementById('iv-year') as HTMLInputElement;
  const padEl = document.getElementById('iv-pad') as HTMLInputElement;
  const modeEl = document.getElementById('iv-mode') as HTMLSelectElement;
  const startEl = document.getElementById('iv-start') as HTMLInputElement;
  const amountEl = document.getElementById('iv-amount') as HTMLInputElement;
  const out = document.getElementById('iv-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('iv-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('iv-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function luhnCheckDigit(num: string): string {
    let sum = 0; let alt = false;
    for (let i = num.length - 1; i >= 0; i--) {
      let d = parseInt(num.charAt(i), 10);
      if (alt) { d *= 2; if (d > 9) d -= 9; }
      sum += d; alt = !alt;
    }
    return String((10 - (sum % 10)) % 10);
  }
  function generate() {
    const prefix = (prefixEl.value || 'INV').toUpperCase();
    const year = parseInt(yearEl.value || '2026', 10);
    const pad_ = Math.max(3, Math.min(8, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const start = Math.max(1, parseInt(startEl.value || '1', 10));
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      let core = '';
      if (mode === 'seq') core = pad(start + i, pad_);
      else core = pad(rint(Math.pow(10, pad_)), pad_);
      let id = `${prefix}-${year}-${core}`;
      if (mode === 'checksum') {
        const digits = (year + core).replace(/\D/g, '');
        id = `${prefix}-${year}-${core}-${luhnCheckDigit(digits)}`;
      }
      arr.push(id);
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = '¡Copiado!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
