---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de paletas de colores gratis | Genfy';
const description = 'Generá paletas de colores armoniosas en un click. Esquemas análogos, complementarios, triádicos y monocromáticos con códigos HEX, RGB y HSL listos para copiar.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué es una paleta armónica?', acceptedAnswer: { '@type': 'Answer', text: 'Es un conjunto de colores que comparten una relación matemática en la rueda cromática (mismo tono, tonos opuestos, separados por 120°, etc.). Eso garantiza que combinen entre sí en lugar de competir.' } },
    { '@type': 'Question', name: '¿Para qué sirve la regla 60-30-10?', acceptedAnswer: { '@type': 'Answer', text: 'Es una regla de diseño de interiores adaptada a UI: 60% color dominante (fondo), 30% color secundario (estructura), 10% color de acento (CTAs, alertas). Aplicarla evita interfaces planas o saturadas.' } },
    { '@type': 'Question', name: '¿Cuántos colores debe tener una paleta?', acceptedAnswer: { '@type': 'Answer', text: 'Para branding, entre 3 y 5 colores principales. Para una UI completa necesitás también una escala neutral de 8-10 grises y estados (success, warning, danger).' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Diseño" title="Generador de paletas de colores"
    intro="Generá paletas armoniosas en segundos. Elegí un esquema (análogo, complementario, triádico o monocromático), bloqueá los colores que te gusten y descargá los códigos HEX listos para usar.">

    <div slot="tool" class="palette-tool">
      <div class="palette-controls">
        <div>
          <label for="pal-base">Color base</label>
          <input id="pal-base" type="color" value="#059669" />
        </div>
        <div>
          <label for="pal-mode">Esquema</label>
          <select id="pal-mode">
            <option value="analogous">Análogo</option>
            <option value="complementary">Complementario</option>
            <option value="triadic">Triádico</option>
            <option value="tetradic">Tetrádico</option>
            <option value="monochromatic">Monocromático</option>
            <option value="random" selected>Aleatorio</option>
          </select>
        </div>
        <div class="palette-actions">
          <button id="pal-gen" class="btn btn-primary" type="button">Generar paleta</button>
          <button id="pal-copy" class="btn btn-ghost" type="button">Copiar todo</button>
        </div>
      </div>
      <p class="palette-hint">Tocá una tarjeta para bloquear ese color (no cambia al regenerar). Tocá el HEX para copiarlo.</p>
      <div id="palette" class="palette"></div>
    </div>

    <div slot="content">
      <h2>Cómo se construye una paleta que funciona</h2>
      <p>
        Una paleta de colores no se elige por gusto: se construye sobre la rueda cromática.
        Cada esquema es una regla geométrica que garantiza armonía visual y reduce el riesgo
        de elegir combinaciones que generan ruido o cansancio visual.
      </p>
      <ul>
        <li><strong>Análogo:</strong> 3 colores juntos en la rueda (ej: azul, azul-verde, verde). Se siente sereno y cohesivo. Ideal para fondos, ilustraciones y marcas que buscan calma.</li>
        <li><strong>Complementario:</strong> dos colores opuestos (ej: azul y naranja). Máximo contraste, perfecto para CTAs que tienen que destacar contra el fondo.</li>
        <li><strong>Triádico:</strong> 3 colores separados por 120°. Vibrante pero balanceado, se usa mucho en branding moderno y diseño infantil.</li>
        <li><strong>Tetrádico:</strong> 4 colores en pares complementarios. Difícil de balancear; conviene un dominante y tres acentos.</li>
        <li><strong>Monocromático:</strong> mismo tono con distintos niveles de saturación y luminosidad. Sobrio, elegante, casi imposible de fallar.</li>
      </ul>

      <h2>La regla 60-30-10</h2>
      <p>
        Heredada del diseño de interiores y adoptada por la UI moderna: 60% color dominante
        (fondos y áreas grandes), 30% color secundario (cards, sidebars, navegación), 10%
        color de acento (botones primarios, links, indicadores). Si en tu interfaz el acento
        ocupa más del 15%, deja de ser acento y se convierte en ruido.
      </p>

      <h2>HEX vs RGB vs HSL: cuál usar</h2>
      <p>
        Los tres formatos representan el mismo color, pero sirven para cosas distintas.
        <strong>HEX</strong> (<code>#059669</code>) es el más compacto y el estándar para
        compartir colores entre diseño y desarrollo. <strong>RGB</strong>
        (<code>rgb(5, 150, 105)</code>) permite alpha y se usa donde HEX no está soportado.
        <strong>HSL</strong> (<code>hsl(160, 94%, 30%)</code>) es el más útil para
        <em>generar variaciones</em>: subir o bajar la luminosidad mantiene el tono, lo que
        permite construir escalas como las de Tailwind o Material partiendo de un solo color.
      </p>

      <h2>Accesibilidad: el contraste no es opcional</h2>
      <p>
        Antes de cerrar una paleta, verificá el contraste entre texto y fondo. WCAG 2.1
        exige al menos 4.5:1 para texto normal y 3:1 para texto grande (nivel AA). Para AAA,
        7:1 y 4.5:1 respectivamente. Una paleta hermosa que falla en contraste es inservible:
        excluye a usuarios con baja visión y a cualquiera que use el sitio bajo sol directo.
      </p>

      <h2>Cómo aplicar una paleta a una interfaz real</h2>
      <ol>
        <li><strong>Definí el primario.</strong> El color que más representa tu marca. No empieces por el secundario.</li>
        <li><strong>Construí una escala neutra de 8-10 grises.</strong> No son negros mezclados con blanco: tienen un tinte sutil hacia tu primario.</li>
        <li><strong>Sumá estados:</strong> success (verde), warning (ámbar), danger (rojo), info (azul). Estos son convenciones; respetalas.</li>
        <li><strong>Probá la paleta con texto y bordes</strong>, no solo con bloques de color planos. Lo que se ve hermoso en swatches puede chocar en un párrafo.</li>
        <li><strong>Documentá los nombres y los usos.</strong> Una paleta sin guía termina en cada equipo eligiendo "el verde que les parece".</li>
      </ol>

      <h2>Paletas que no fallan</h2>
      <p>
        Si dudás, mirá referencias: Stripe, Linear, Vercel y Notion construyen paletas con
        un primario, una escala fría de grises y muy pocos acentos. La sobriedad envejece
        mejor que la moda. Antes de elegir cinco colores vibrantes, preguntate cuántos
        realmente vas a usar en producción.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Qué es una paleta armónica?</summary><p>Es un grupo de colores que comparten una relación matemática en la rueda cromática (mismo tono, tonos opuestos, separados por 120°, etc.). Eso garantiza que combinen.</p></details>
      <details><summary>¿Para qué sirve la regla 60-30-10?</summary><p>60% color dominante, 30% secundario, 10% acento. Aplicarla evita interfaces planas o saturadas.</p></details>
      <details><summary>¿Cuántos colores debe tener una paleta?</summary><p>Para branding, 3 a 5. Para UI completa necesitás también una escala neutral de 8-10 grises y estados (success, warning, danger).</p></details>
      <details><summary>¿Puedo descargar la paleta?</summary><p>Sí. Tocá "Copiar todo" para llevar los HEX al portapapeles, o tocá cada HEX individual para copiarlo solo.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .palette-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: end; margin-bottom: 1rem; }
  .palette-actions { grid-column: 1 / -1; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .palette-hint { font-size: 0.8125rem; color: var(--text-subtle); margin: 0.5rem 0 1rem; }
  .palette { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; min-height: 220px; }
  .swatch { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); cursor: pointer; aspect-ratio: 1 / 1.4; transition: transform var(--t-base) var(--ease); }
  .swatch:hover { transform: translateY(-2px); }
  .swatch[data-locked="true"]::after { content: "🔒"; position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.875rem; }
  .swatch .hex { position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem; font-family: var(--font-mono); font-size: 0.75rem; text-align: center; background: rgba(255,255,255,0.92); color: #09090b; font-weight: 600; letter-spacing: 0.02em; }
  #pal-base { padding: 0.25rem; height: 42px; cursor: pointer; }
  @media (max-width: 600px) { .palette { grid-template-columns: repeat(5, 1fr); gap: 0.4rem; } .palette-controls { grid-template-columns: 1fr; } }
</style>

<script>
  const baseEl = document.getElementById('pal-base') as HTMLInputElement;
  const modeEl = document.getElementById('pal-mode') as HTMLSelectElement;
  const genEl = document.getElementById('pal-gen') as HTMLButtonElement;
  const copyEl = document.getElementById('pal-copy') as HTMLButtonElement;
  const palEl = document.getElementById('palette') as HTMLDivElement;

  type HSL = { h: number; s: number; l: number };
  const locked: (string | null)[] = [null, null, null, null, null];

  function hexToHsl(hex: string): HSL {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0; const l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0));
      else if (max === g) h = (b - r) / d + 2;
      else h = (r - g) / d + 4;
      h *= 60;
    }
    return { h, s: s * 100, l: l * 100 };
  }
  function hslToHex({ h, s, l }: HSL): string {
    s /= 100; l /= 100;
    const k = (n: number) => (n + h / 30) % 12;
    const a = s * Math.min(l, 1 - l);
    const f = (n: number) => l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
    const toHex = (x: number) => Math.round(x * 255).toString(16).padStart(2, '0');
    return '#' + toHex(f(0)) + toHex(f(8)) + toHex(f(4));
  }
  function build(base: string, mode: string): string[] {
    const hsl = hexToHsl(base);
    const out: string[] = [];
    if (mode === 'random') {
      for (let i = 0; i < 5; i++) {
        out.push(hslToHex({ h: Math.random() * 360, s: 55 + Math.random() * 35, l: 35 + Math.random() * 40 }));
      }
    } else if (mode === 'analogous') {
      for (let i = -2; i <= 2; i++) out.push(hslToHex({ h: (hsl.h + i * 22 + 360) % 360, s: hsl.s, l: hsl.l }));
    } else if (mode === 'complementary') {
      out.push(hslToHex(hsl));
      out.push(hslToHex({ ...hsl, l: Math.min(85, hsl.l + 18) }));
      out.push(hslToHex({ ...hsl, l: Math.max(15, hsl.l - 22) }));
      out.push(hslToHex({ h: (hsl.h + 180) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ h: (hsl.h + 180) % 360, s: hsl.s, l: Math.min(85, hsl.l + 18) }));
    } else if (mode === 'triadic') {
      out.push(hslToHex(hsl));
      out.push(hslToHex({ h: (hsl.h + 120) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ h: (hsl.h + 240) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ ...hsl, l: Math.min(90, hsl.l + 25) }));
      out.push(hslToHex({ ...hsl, l: Math.max(10, hsl.l - 25) }));
    } else if (mode === 'tetradic') {
      [0, 90, 180, 270].forEach(d => out.push(hslToHex({ h: (hsl.h + d) % 360, s: hsl.s, l: hsl.l })));
      out.push(hslToHex({ ...hsl, l: Math.min(90, hsl.l + 22) }));
    } else { // monochromatic
      [25, 40, 55, 70, 85].forEach(l => out.push(hslToHex({ ...hsl, l })));
    }
    return out;
  }
  function render(colors: string[]) {
    palEl.innerHTML = '';
    colors.forEach((c, i) => {
      const sw = document.createElement('div');
      sw.className = 'swatch';
      sw.style.background = c;
      sw.dataset.locked = locked[i] ? 'true' : 'false';
      const hex = document.createElement('div');
      hex.className = 'hex';
      hex.textContent = c.toUpperCase();
      sw.appendChild(hex);
      sw.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).classList.contains('hex')) {
          navigator.clipboard.writeText(c.toUpperCase());
          hex.textContent = '¡copiado!';
          setTimeout(() => { hex.textContent = c.toUpperCase(); }, 900);
        } else {
          locked[i] = locked[i] ? null : c;
          sw.dataset.locked = locked[i] ? 'true' : 'false';
        }
      });
      palEl.appendChild(sw);
    });
  }
  let current: string[] = [];
  function regen() {
    const built = build(baseEl.value, modeEl.value);
    current = built.map((c, i) => locked[i] ?? c);
    render(current);
  }
  genEl.addEventListener('click', regen);
  copyEl.addEventListener('click', () => {
    navigator.clipboard.writeText(current.map(c => c.toUpperCase()).join('\n'));
    copyEl.textContent = '¡Copiado!';
    setTimeout(() => { copyEl.textContent = 'Copiar todo'; }, 1200);
  });
  regen();
</script>
