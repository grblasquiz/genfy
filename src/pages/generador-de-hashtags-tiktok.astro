---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de hashtags para TikTok gratis | Genfy';
const description = 'Generá hashtags para TikTok con la lógica del FYP: 3-5 etiquetas precisas que el algoritmo entiende, sin spam ni #fyp vacío.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cuántos hashtags conviene en TikTok?', acceptedAnswer: { '@type': 'Answer', text: 'Entre 3 y 5 hashtags relevantes. TikTok prioriza señales del contenido (audio, captions, watch time) sobre cantidad de hashtags. Más allá de 5 no agrega alcance.' } },
    { '@type': 'Question', name: '¿Sirve usar #fyp o #parati?', acceptedAnswer: { '@type': 'Answer', text: 'No. TikTok no necesita ese hashtag para enviarte al FYP — el algoritmo evalúa el video por sí solo. Usar #fyp consume slots útiles que podrían ir a hashtags de nicho.' } },
    { '@type': 'Question', name: '¿En qué se diferencia de Instagram?', acceptedAnswer: { '@type': 'Answer', text: 'En Instagram el hashtag es feed de descubrimiento. En TikTok es señal contextual al algoritmo. Por eso 3-5 hashtags precisos rinden más que 30 genéricos.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Marketing" title="Generador de hashtags para TikTok"
    intro="En TikTok los hashtags son señales contextuales, no feed. Genfy te devuelve 3-5 hashtags precisos: tema + nicho + comunidad, sin #fyp ni spam.">

    <div slot="tool" class="th">
      <label for="th-niche">Nicho / categoría</label>
      <input id="th-niche" type="text" placeholder="cocina, finanzas, fitness..." value="cocina" />

      <button id="th-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar set</button>

      <div id="th-out" class="th-out"></div>
    </div>

    <div slot="content">
      <h2>Por qué los hashtags en TikTok funcionan distinto</h2>
      <p>
        En Instagram, el hashtag es un feed: la gente abre #fitness y ve posts. En TikTok, ese feed casi no se usa. Lo que importa es el For You Page (FYP), y el algoritmo del FYP lee mucho más que el hashtag: lee el audio que usás, las palabras del caption, los frames del video, el watch time, el tiempo en pantalla, los compartidos. El hashtag es una señal complementaria, no la principal.
      </p>
      <p>
        Por eso la regla cambia. Donde Instagram premia 8-12 hashtags balanceados, TikTok premia 3-5 hashtags precisos. Más allá de eso, le estás pidiendo al algoritmo que adivine en qué categoría categorizar tu contenido, y eso baja la calidad de la distribución.
      </p>

      <h2>El error #fyp y por qué cuesta alcance</h2>
      <p>
        El mito más repetido es que poner #fyp, #foryou o #parati hace que TikTok te empuje al For You Page. Es falso. TikTok decide la distribución por las señales del video, no por hashtags ceremoniales. Pero el costo de usar #fyp es real: te ocupa uno de los 3-5 slots útiles. Si en lugar de #fyp pusieras un hashtag específico de tu nicho, el algoritmo entendería mejor a quién mostrar el video.
      </p>

      <h2>La fórmula 3-1-1 para TikTok</h2>
      <ol>
        <li><strong>3 hashtags de tema (el qué):</strong> describen el contenido directo. Si es una receta, #pasta, #cocinafácil, #recetas.</li>
        <li><strong>1 hashtag de nicho (el quién):</strong> identifica a tu sub-comunidad. #cocinaargentina, #cookingforone, #vegantiktok.</li>
        <li><strong>1 hashtag de momento o trend (cuando aplica):</strong> trends activos, ediciones, challenges. Si no hay nada activo relevante, dejalo afuera.</li>
      </ol>
      <p>
        Total: 4-5 hashtags. Cada uno tiene rol claro y le habla al algoritmo en una dimensión distinta.
      </p>

      <h2>Cómo encontrar hashtags de nicho en TikTok</h2>
      <ol>
        <li>Abrí Buscar y tipeá tu categoría general.</li>
        <li>Mirá las cuentas top en esa búsqueda y revisá qué hashtags repiten.</li>
        <li>Tipeá en Buscar el hashtag para ver el contador real de vistas (no de posts como en Instagram). Buscá hashtags entre 5M-100M de vistas para ranquear.</li>
        <li>Anotá hashtags repetidos en al menos 3 creadores referentes — ese es tu pool de nicho.</li>
        <li>Probá un set por 2 semanas, mirá Insights y rotá los que no traen alcance.</li>
      </ol>

      <h2>Lo que TikTok mide (y por qué los hashtags pesan menos de lo que parece)</h2>
      <p>
        El algoritmo del FYP pondera estas señales aproximadamente en este orden:
      </p>
      <ul>
        <li><strong>Watch time / completion rate:</strong> ¿se ve completo? Es la señal más fuerte.</li>
        <li><strong>Re-watch:</strong> ¿la gente lo mira más de una vez?</li>
        <li><strong>Compartidos:</strong> mucho más fuerte que los likes.</li>
        <li><strong>Comentarios.</strong></li>
        <li><strong>Audio:</strong> usar audios trending da boost.</li>
        <li><strong>Captions:</strong> palabras clave en el caption son procesadas.</li>
        <li><strong>Hashtags:</strong> aportan contexto, no son determinantes.</li>
        <li><strong>Likes / follows:</strong> sorprendentemente, los más débiles.</li>
      </ul>
      <p>
        Por eso un buen hashtag set sin contenido sólido no rinde. Pero contenido sólido con hashtags mal puestos rinde menos de lo que podría.
      </p>

      <h2>SEO en TikTok: la nueva ventaja</h2>
      <p>
        Desde 2023 TikTok funciona también como buscador (especialmente para Gen Z). Eso significa que las palabras clave en captions pesan más que antes. Si tu video es una receta de pasta carbonara, escribí "pasta carbonara fácil 5 minutos" en el caption — vas a aparecer cuando alguien busque eso, aunque no uses ese hashtag exacto. La combinación caption + hashtag es lo que rinde.
      </p>

      <h2>Cuándo cambiar la estrategia</h2>
      <p>
        Cada 6 semanas revisá Insights y filtrá tus 5 videos top: ¿qué hashtags coinciden? Esos son tu set ganador. Los videos que rindieron mal con hashtags distintos te indican qué descartar. La iteración constante con datos reales rinde mucho más que copiar un set genérico de un blog.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Cuántos hashtags?</summary><p>3 a 5 relevantes. TikTok prioriza señales del contenido por sobre cantidad de hashtags.</p></details>
      <details><summary>¿Sirve #fyp o #parati?</summary><p>No. Consume slots útiles que podrían ir a hashtags de nicho.</p></details>
      <details><summary>¿Diferencia con Instagram?</summary><p>En Instagram el hashtag es feed; en TikTok es señal al algoritmo. Por eso 3-5 hashtags precisos rinden más.</p></details>
      <details><summary>¿Conviene SEO en captions?</summary><p>Sí. Desde 2023 TikTok funciona también como buscador. Captions con palabras clave pesan más que antes.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .th-out { margin-top: 1.25rem; display: grid; gap: 1rem; }
  .th-group { padding: 1rem 1.25rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius); cursor: pointer; transition: border-color 0.1s; }
  .th-group:hover { border-color: var(--accent); }
  .th-group h4 { margin: 0 0 0.5rem; font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-subtle); }
  .th-group p { margin: 0; line-height: 1.7; word-break: break-word; font-family: var(--font-mono); font-size: 0.875rem; }
</style>

<script>
  const SETS: Record<string, { theme: string[], niche: string[] }> = {
    cocina: { theme: ['cocinafácil', 'recetas', 'recetacasera'], niche: ['cocinaargentina', 'recetasenminutos'] },
    fitness: { theme: ['fitness', 'workout', 'entrenamiento'], niche: ['fitnesslatino', 'rutinaencasa'] },
    finanzas: { theme: ['finanzas', 'finanzaspersonales', 'ahorrar'], niche: ['finanzaslatam', 'inversionprincipiantes'] },
    moda: { theme: ['outfit', 'moda', 'estilo'], niche: ['modaargentina', 'looksdeldia'] },
    viajes: { theme: ['viajar', 'turismo', 'destinos'], niche: ['viajeslatam', 'mochilero'] },
    marketing: { theme: ['marketing', 'marketingdigital', 'redessociales'], niche: ['marketinglatam', 'emprendedoreslatam'] },
    default: { theme: ['lifestyle', 'creator', 'tips'], niche: ['microcomunidad', 'localbrand'] },
  };

  const niche = document.getElementById('th-niche') as HTMLInputElement;
  const gen = document.getElementById('th-gen') as HTMLButtonElement;
  const out = document.getElementById('th-out')!;

  function findSet(n: string) {
    const k = n.toLowerCase().trim();
    if (SETS[k]) return SETS[k];
    if (k.includes('cocin') || k.includes('comid') || k.includes('food')) return SETS.cocina;
    if (k.includes('fit') || k.includes('gym')) return SETS.fitness;
    if (k.includes('finan') || k.includes('plata') || k.includes('dinero')) return SETS.finanzas;
    if (k.includes('mod') || k.includes('estilo')) return SETS.moda;
    if (k.includes('viaj') || k.includes('travel')) return SETS.viajes;
    if (k.includes('market')) return SETS.marketing;
    return SETS.default;
  }

  function makeGroup(title: string, hashtags: string[]) {
    const g = document.createElement('div');
    g.className = 'th-group';
    const tags = hashtags.map(w => '#' + w).join(' ');
    g.innerHTML = `<h4>${title}</h4><p>${tags}</p>`;
    g.title = 'Click para copiar';
    g.addEventListener('click', () => { navigator.clipboard.writeText(tags); const old = g.querySelector('h4')!.textContent; g.querySelector('h4')!.textContent = '✓ COPIADO'; setTimeout(() => g.querySelector('h4')!.textContent = old, 800); });
    return g;
  }

  function generate() {
    const s = findSet(niche.value);
    out.innerHTML = '';
    out.appendChild(makeGroup('Tema (3) — qué muestra el video', s.theme));
    out.appendChild(makeGroup('Nicho (1-2) — comunidad específica', s.niche));
    const all = [...s.theme, ...s.niche].map(w => '#' + w).join(' ');
    out.appendChild(makeGroup('SET COMPLETO 3-1-1 (4-5 HASHTAGS)', [...s.theme, ...s.niche]));
  }
  gen.addEventListener('click', generate);
  generate();
</script>
