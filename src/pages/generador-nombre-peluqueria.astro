---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de nombre de peluquería y salón gratis | Genfy';
const description = 'Generá nombres únicos para tu peluquería, barbería o salón. Combiná concepto, dueño o estilo y obtené 20 ideas para vidriera, dominio y redes.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Conviene usar mi nombre como dueña?', acceptedAnswer: { '@type': 'Answer', text: 'Funciona muy bien si vas a estar atendiendo personalmente y querés transmitir cercanía. Es menos óptimo si planeás expandir o vender el local.' } },
    { '@type': 'Question', name: '¿Qué diferencia un salón premium de uno de barrio?', acceptedAnswer: { '@type': 'Answer', text: 'Los premium suelen usar nombres minimalistas o de oficio (Atelier, Studio, Color Lab). Los de barrio funcionan con nombres cálidos o con apellidos.' } },
    { '@type': 'Question', name: '¿Cómo verifico disponibilidad?', acceptedAnswer: { '@type': 'Answer', text: 'Google Maps en 5 km, Instagram con handle exacto, dominio y registro de marcas local antes de imprimir tarjetas.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Belleza" title="Generador de nombre de peluquería"
    intro="Combiná concepto, apellido o estilo y obtené 20 ideas para tu peluquería, barbería o salón. Pensado para validar handle de Instagram al instante.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Palabras clave (concepto, apellido, estilo)</label>
      <input id="bn-kw" type="text" placeholder="color, hair, atelier..." value="hair, estudio" />

      <label for="bn-style" style="margin-top:1rem">Estilo</label>
      <select id="bn-style">
        <option value="boutique">Boutique / atelier</option>
        <option value="surname">Apellido + Studio / Salón</option>
        <option value="modern">Moderno (una palabra)</option>
        <option value="craft">Oficio (Color Lab, Hair Lab)</option>
        <option value="warm">Cálido de barrio</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 20 nombres</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>Cómo elegir el nombre de una peluquería o salón</h2>
      <p>
        En belleza, el nombre tiene que comunicar tres cosas en menos de un segundo: nivel de
        precio, estilo (clásico, urbano, moderno) y especialidad si tenés alguna (color, rizos,
        barba). Lo que falla más seguido es elegir un nombre que se ve hermoso en el cartel
        pero no comunica si entra alguien con $20 o con $200.
      </p>
      <ol>
        <li><strong>Coherente con el ticket.</strong> "Atelier" sugiere precio premium; "Cuts" sugiere accesible.</li>
        <li><strong>Claro en la especialidad.</strong> Si tu fuerte es color, "Color Lab" comunica más que "Beauty Studio".</li>
        <li><strong>Memorable después de un corte.</strong> Tu cliente lo recomienda al cuñado.</li>
        <li><strong>Buscable en Maps.</strong> Único en tu zona.</li>
        <li><strong>Handle de IG corto.</strong> Es donde subís transformaciones y antes/después.</li>
      </ol>

      <h2>Estilos por tipo de salón</h2>
      <ul>
        <li><strong>Boutique / atelier:</strong> "Atelier 22", "Studio Hair". Sugiere precio premium y trabajo cuidado.</li>
        <li><strong>Apellido + Studio:</strong> "Méndez Hair", "Rossi Studio". Comunica autoría.</li>
        <li><strong>Moderno (una palabra):</strong> "Tinta", "Forma", "Greña", "Filo". Mood-driven, fácil de tatuar.</li>
        <li><strong>Oficio:</strong> "Color Lab", "Curl Lab", "Cut Lab". Comunica especialidad.</li>
        <li><strong>Cálido de barrio:</strong> "Casa Lola", "El Salón de la Esquina". Para clientela fija de zona.</li>
      </ul>

      <h2>Errores frecuentes</h2>
      <p>
        El error más común es nombres demasiado genéricos: "Belleza Total", "Look Perfecto" o
        "Cabello Sano" tienen miles de resultados. El segundo es elegir nombres que envejecen
        mal: cualquier referencia a una serie o tendencia de moda específica te ata a una
        década. El tercero es usar caracteres especiales que rompen el handle: las tildes y
        eñes se pierden en "@miestiloperu".
      </p>

      <h2>Validación rápida</h2>
      <ol>
        <li>Google Maps en 5 km y en tu ciudad.</li>
        <li>Instagram, TikTok, Treatwell o Booksy según mercado.</li>
        <li>Dominio en Namecheap o Cloudflare.</li>
        <li>Registro de marcas local.</li>
        <li>Probá imprimirlo en una tarjeta de prueba: ¿se ve premium o cheap según tu posicionamiento?</li>
        <li>Decirlo a 5 clientas potenciales: ¿adivinan el ticket promedio?</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>¿Conviene usar mi nombre como dueña?</summary><p>Funciona si atendés personalmente; menos óptimo si planeás expandir.</p></details>
      <details><summary>¿Premium o de barrio?</summary><p>Atelier/Studio sugiere premium; cálido o apellido sugiere cercanía.</p></details>
      <details><summary>¿Cómo verifico disponibilidad?</summary><p>Google Maps, Instagram, dominio y registro de marcas.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; user-select: text; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const BOUT = ['Atelier', 'Studio', 'Maison', 'Salón', 'House', 'Loft', 'Espacio', 'Taller', 'Galería'];
  const SURN = ['Méndez', 'Rossi', 'Pérez', 'García', 'Romero', 'Bianchi', 'López', 'Silva', 'Castro', 'Nakamura'];
  const MODERN = ['Tinta', 'Forma', 'Greña', 'Filo', 'Brote', 'Trazo', 'Pulso', 'Hilo', 'Lino', 'Cobalto'];
  const CRAFT_PRE = ['Color', 'Curl', 'Cut', 'Hair', 'Style', 'Trend', 'Tono', 'Onda'];
  const CRAFT_SUF = ['Lab', 'Studio', 'Atelier', 'House', 'Co'];
  const WARM = ['Casa Lola', 'El Salón', 'Casa Hair', 'La Vereda', 'El Espejo', 'La Esquina', 'El Patio'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function num() { const i = new Uint32Array(1); crypto.getRandomValues(i); return (i[0] % 99) + 1; }

  function generate() {
    const words = kw.value.split(',').map(s => s.trim()).filter(Boolean);
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      const w = words.length ? pick(words) : 'Hair';
      let name = '';
      if (s === 'boutique') name = pick(BOUT) + ' ' + (Math.random() > 0.5 ? cap(w) : String(num()));
      else if (s === 'surname') name = pick(SURN) + ' ' + pick(BOUT);
      else if (s === 'modern') name = pick(MODERN);
      else if (s === 'craft') name = pick(CRAFT_PRE) + ' ' + pick(CRAFT_SUF);
      else if (s === 'warm') name = pick(WARM);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click para copiar';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
