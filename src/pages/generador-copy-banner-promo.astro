---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de copy de banner promocional | Genfy';
const description = 'Generá copies para banners promocionales de Shopify, web o landing. Headlines, sub y CTAs en formato listo para diseñador. 10 variantes en un click.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cuántos caracteres debe tener un banner?', acceptedAnswer: { '@type': 'Answer', text: 'Headline 4 a 7 palabras (25-45 caracteres). Sub-headline 8 a 12 palabras. CTA 2 a 3 palabras.' } },
    { '@type': 'Question', name: '¿El descuento debe ir en el headline?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, si es el principal driver de la promo. "30% off solo hoy" convierte mejor que un mensaje creativo + el descuento abajo.' } },
    { '@type': 'Question', name: '¿Conviene usar countdown?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, en promociones flash o de fin de semana. Pero solo si la urgencia es real — los countdowns falsos bajan la confianza una vez que el cliente vuelve y ve que sigue corriendo.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Empresa / Business" title="Generador de copy de banner promocional"
    intro="Generá 10 banners listos para tu Shopify, web o landing: headline, sub, CTA y observaciones legales. Para promos, lanzamientos, fechas especiales y ventas flash.">

    <div slot="tool" class="bp">
      <label>Tipo de promoción</label>
      <select id="bp-type">
        <option value="descuento">Descuento porcentual</option>
        <option value="envio">Envío gratis</option>
        <option value="2x1">2x1 / múltiplo</option>
        <option value="lanzamiento">Lanzamiento de producto</option>
        <option value="fecha">Fecha especial (Black Friday, San Valentín)</option>
      </select>

      <label style="margin-top:1rem">Beneficio principal</label>
      <input id="bp-benefit" type="text" value="30% en toda la tienda" />

      <label style="margin-top:1rem">Vigencia / urgencia</label>
      <input id="bp-time" type="text" value="solo hasta el domingo" />

      <label style="margin-top:1rem">Categoría / producto</label>
      <input id="bp-cat" type="text" value="indumentaria mujer" />

      <button id="bp-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 10 variantes</button>

      <div id="bp-out" class="bp-out"></div>
    </div>

    <div slot="content">
      <h2>Por qué los banners necesitan copy específico, no creatividad libre</h2>
      <p>
        Un banner tiene 3 a 5 segundos para captar atención y comunicar el beneficio. No es un
        anuncio de marca: es una valla concreta. Las marcas que ven mejor ROI en banners no buscan
        copy creativo, buscan copy claro: el qué, el cuánto y hasta cuándo.
      </p>

      <h2>Estructura de banner que convierte</h2>
      <ol>
        <li><strong>Headline (top):</strong> el beneficio en mayúscula. "30% OFF EN TODA LA TIENDA".</li>
        <li><strong>Sub-headline:</strong> el contexto o categoría. "Indumentaria mujer — colección verano".</li>
        <li><strong>Urgencia:</strong> tiempo o stock limitado. "Solo hasta el domingo" o "Stock limitado".</li>
        <li><strong>CTA:</strong> 2-3 palabras orientadas a la acción. "Comprá ahora", "Aprovechá", "Ver colección".</li>
        <li><strong>Letra chica (cuando aplica):</strong> exclusiones, mínimo de compra. Texto pequeño, no escondido.</li>
      </ol>

      <h2>Las 5 reglas no negociables</h2>
      <ul>
        <li><strong>Una promesa por banner.</strong> No metas dos descuentos distintos.</li>
        <li><strong>Lo importante en mayúscula y arriba.</strong> El ojo escanea primero el bloque más grande.</li>
        <li><strong>CTA contrastante.</strong> Botón con color contrastado y verbo en presente.</li>
        <li><strong>Mobile first.</strong> 70% del tráfico es mobile — diseñá pensando en pantalla chica antes que en monitor.</li>
        <li><strong>Vencimiento real.</strong> Si decís "solo hasta el domingo", el lunes no debería estar el banner.</li>
      </ul>

      <h2>Copy según tipo de promo</h2>
      <ul>
        <li><strong>Descuento porcentual:</strong> "30% OFF EN TODO" + "Hasta domingo 23:59" + "Comprá ahora".</li>
        <li><strong>Envío gratis:</strong> "ENVÍO GRATIS" + "En compras desde USD 50" + "Aprovechá".</li>
        <li><strong>2x1:</strong> "LLEVÁ 2, PAGÁ 1" + "En toda la línea verano" + "Ver colección".</li>
        <li><strong>Lanzamiento:</strong> "NUEVA COLECCIÓN" + "Disponible solo online esta semana" + "Descubrir".</li>
        <li><strong>Fecha especial:</strong> "BLACK FRIDAY" + "Hasta 50% off + 12 cuotas" + "Ver ofertas".</li>
      </ul>

      <h2>Errores que matan la conversión</h2>
      <ol>
        <li>Headlines tipo "¡No te lo podés perder!" sin decir qué se pierde.</li>
        <li>CTAs vagos: "Hacé click acá" o "Más info". El CTA tiene que prometer un resultado.</li>
        <li>Stack de descuentos confusos: "30% + 20% + 10% extra" — el cliente no sabe cuánto paga al final.</li>
        <li>Letra chica enorme. Si la exclusión ocupa más que el beneficio, perdiste credibilidad.</li>
        <li>Copy que no coincide con la página destino. Si el banner dice "envío gratis" y al hacer click hay condiciones, baja la confianza.</li>
      </ol>

      <h2>Cómo testear rápido</h2>
      <p>
        Si tu plataforma permite, probá 2 versiones del banner durante 24-48 horas. Las variables
        que más mueven CTR: el verbo del CTA, la presencia o no de countdown, y si el porcentaje
        está antes o después del producto. Una sola variable a la vez, sino no sabés cuál ganó.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Cuántos caracteres por banner?</summary><p>Headline 25-45 caracteres, sub 8-12 palabras, CTA 2-3 palabras.</p></details>
      <details><summary>¿Descuento en el headline?</summary><p>Sí, si es el driver principal. Convierte mejor.</p></details>
      <details><summary>¿Countdown sí o no?</summary><p>Sí en flash sales, pero solo si la urgencia es real.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bp-out { display: grid; gap: 0.75rem; margin-top: 1.25rem; }
  .bp-card { padding: 1rem 1.125rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-md); cursor: pointer; transition: border-color 0.1s; }
  .bp-card:hover { border-color: var(--primary); }
  .bp-h { font-weight: 700; font-size: 1.0625rem; margin-bottom: 0.25rem; }
  .bp-sub { color: var(--text-soft); font-size: 0.9375rem; margin-bottom: 0.25rem; }
  .bp-cta { font-size: 0.875rem; color: var(--primary); font-weight: 600; }
</style>

<script>
  const type = document.getElementById('bp-type') as HTMLSelectElement;
  const benefit = document.getElementById('bp-benefit') as HTMLInputElement;
  const time = document.getElementById('bp-time') as HTMLInputElement;
  const cat = document.getElementById('bp-cat') as HTMLInputElement;
  const out = document.getElementById('bp-out')!;
  const gen = document.getElementById('bp-gen') as HTMLButtonElement;

  function generate() {
    const b = benefit.value;
    const t = time.value;
    const c = cat.value;

    const items = [
      { h: `${b.toUpperCase()}`, s: `En ${c}, ${t}.`, cta: 'Comprá ahora' },
      { h: `Solo hoy: ${b}`, s: `${c} con descuento especial.`, cta: 'Aprovechar' },
      { h: `${b} en ${c}`, s: `Vigente ${t}. Stock limitado.`, cta: 'Ver colección' },
      { h: `Aprovechá ${b}`, s: `${t}, sin códigos.`, cta: 'Ir a la tienda' },
      { h: `Tu próxima compra: ${b}`, s: `${c}, online y en sucursales. ${t}.`, cta: 'Comprar' },
      { h: `${b} sin letra chica`, s: `Aplicá automáticamente. ${t}.`, cta: 'Empezar' },
      { h: `Termina pronto: ${b}`, s: `Reservá lo tuyo de ${c} antes que se acabe.`, cta: 'Quiero mi descuento' },
      { h: `${b} en toda la web`, s: `${t}. Aplicado en el carrito.`, cta: 'Ver productos' },
      { h: `Promo activa: ${b}`, s: `${c}. Suma envío rápido y devolución gratis.`, cta: 'Aprovechar ahora' },
      { h: `${b} — ${t}`, s: `${c}. La mejor oportunidad del mes.`, cta: 'Lo quiero' },
    ];

    out.innerHTML = '';
    items.forEach(it => {
      const c2 = document.createElement('div');
      c2.className = 'bp-card';
      c2.innerHTML = `<div class="bp-h">${it.h}</div><div class="bp-sub">${it.s}</div><div class="bp-cta">[ ${it.cta} ]</div>`;
      const fullText = `${it.h}\n${it.s}\nCTA: ${it.cta}`;
      c2.title = 'Click para copiar';
      c2.addEventListener('click', () => { navigator.clipboard.writeText(fullText); c2.style.borderColor = 'var(--primary)'; setTimeout(() => c2.style.borderColor = '', 800); });
      out.appendChild(c2);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
