---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de códigos SKU gratis | Genfy';
const description = 'Generá códigos SKU únicos para tu inventario. Estructura categoría + marca + atributo + correlativo. Ideal para ecommerce, retail y bodegas.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué es un SKU?', acceptedAnswer: { '@type': 'Answer', text: 'Stock Keeping Unit: el código interno único que identifica un producto-variante. No se confunde con el código de barras (UPC/EAN), que es para escaneo en POS.' } },
    { '@type': 'Question', name: '¿Cómo se estructura un buen SKU?', acceptedAnswer: { '@type': 'Answer', text: 'Categoría + marca/línea + atributos (talle/color) + correlativo. Por ejemplo: TS-NIK-RJ-M-0001 (Tshirt - Nike - Rojo - Medium - 0001).' } },
    { '@type': 'Question', name: '¿Cuántos caracteres debe tener?', acceptedAnswer: { '@type': 'Answer', text: '8-15 caracteres es la zona recomendada. Menos de 8 limita la información; más de 15 cuesta gestionar manualmente.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Trabajo / Work" title="Generador de códigos SKU"
    intro="Construí SKUs únicos y legibles para tu inventario. Categoría, marca, atributo y correlativo. Ideal para ecommerce, retail y bodegas.">

    <div slot="tool" class="sk">
      <div class="sk-row">
        <div>
          <label for="sk-cat">Categoría (3 letras)</label>
          <input id="sk-cat" type="text" value="TS" maxlength="4" />
        </div>
        <div>
          <label for="sk-brand">Marca/línea (3 letras)</label>
          <input id="sk-brand" type="text" value="NIK" maxlength="4" />
        </div>
        <div>
          <label for="sk-attr">Atributo (color/talle)</label>
          <input id="sk-attr" type="text" value="RJ-M" maxlength="6" placeholder="Ej: RJ-M" />
        </div>
      </div>
      <div class="sk-row">
        <div>
          <label for="sk-pad">Dígitos correlativo</label>
          <input id="sk-pad" type="number" value="4" min="3" max="6" />
        </div>
        <div>
          <label for="sk-mode">Modo</label>
          <select id="sk-mode">
            <option value="seq">Secuencial</option>
            <option value="random">Aleatorio</option>
          </select>
        </div>
        <div>
          <label for="sk-amount">Cantidad</label>
          <input id="sk-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="sk-gen" class="btn btn-primary" type="button">Generar</button>
      <button id="sk-copy" class="btn btn-ghost" type="button">Copiar</button>
      <textarea id="sk-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>SKU vs. código de barras: no son lo mismo</h2>
      <p>
        El <strong>SKU</strong> (Stock Keeping Unit) es tu código interno: lo definís vos, lo
        cambiás cuando querés, y lo usás para gestión de inventario. El <strong>código de
        barras</strong> (UPC/EAN/GTIN) es un identificador global, registrado, que se compra a
        organismos como GS1 y sirve para escaneo en cajas de cualquier tienda. Una camiseta
        Nike negra talle M tiene un único EAN en todo el mundo, pero puede tener un SKU
        distinto en cada retailer que la venda.
      </p>

      <h2>Estructura recomendada</h2>
      <p>
        El patrón estándar para SKU legible es <code>CATEGORIA-MARCA-ATRIBUTO-CORRELATIVO</code>.
        Ejemplo: <code>TS-NIK-RJ-M-0001</code> = "T-shirt, Nike, color rojo, talle M, primera unidad".
        El beneficio: solo viendo el SKU, alguien con conocimiento del sistema entiende qué
        producto es. Esto es invaluable cuando tu equipo crece y nadie tiene la base mental
        completa.
      </p>

      <h2>Reglas para SKUs sostenibles</h2>
      <ol>
        <li><strong>Cortos pero descriptivos.</strong> 8-15 caracteres es lo recomendado.</li>
        <li><strong>Solo mayúsculas y guiones.</strong> Evitá espacios, slashes, comillas.</li>
        <li><strong>Sin caracteres confusos.</strong> Olvidate de O y 0, I y 1 — generan errores en planilla.</li>
        <li><strong>Estables.</strong> Una vez asignado, no lo cambies — todos tus reportes históricos lo usan.</li>
        <li><strong>Únicos.</strong> Cada variante (color, talle) tiene su propio SKU. Nunca compartas SKUs entre variantes.</li>
        <li><strong>No incluyas precio.</strong> Si el precio cambia, el SKU queda inconsistente. Mantenelo separado.</li>
      </ol>

      <h2>Categorización</h2>
      <p>
        Antes de empezar a generar SKUs, sentate a definir tu taxonomía: ¿cómo agrupás los
        productos? ¿Por familia, por proveedor, por canal de venta? Una taxonomía mal pensada
        se nota a los 6 meses cuando los SKUs ya no representan la estructura real del
        inventario. Lo correcto es que la primera porción del SKU corresponda al criterio
        principal de tu negocio (categoría, en la mayoría de casos).
      </p>

      <h2>Ejemplos por industria</h2>
      <ul>
        <li><strong>Ropa:</strong> <code>CAM-LEV-AZ-L-0042</code> (Camisa, Levi's, Azul, Large, #42).</li>
        <li><strong>Tecnología:</strong> <code>NB-DELL-INSP15-0007</code> (Notebook, Dell, Inspiron 15, #7).</li>
        <li><strong>Almacén:</strong> <code>ALI-MOL-1KG-0123</code> (Alimento, Molinos, 1kg, #123).</li>
        <li><strong>Cosmética:</strong> <code>LAB-MAY-RJ02-0009</code> (Labial, Maybelline, Rojo 02, #9).</li>
      </ul>

      <h2>Errores comunes</h2>
      <ul>
        <li><strong>SKUs basados en código de proveedor.</strong> Si cambiás de proveedor, perdés todo el sistema.</li>
        <li><strong>Reusar SKUs de productos discontinuados.</strong> Los reportes históricos se rompen.</li>
        <li><strong>Demasiada profundidad jerárquica.</strong> 3-4 segmentos máximo. Más, y nadie los recuerda.</li>
        <li><strong>Cambiar el formato a mitad de catálogo.</strong> Te quedás con dos lógicas conviviendo y nadie sabe cuál es cuál.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>¿Qué es un SKU?</summary><p>Stock Keeping Unit: código interno único de un producto-variante. Distinto del código de barras.</p></details>
      <details><summary>¿Cómo se estructura?</summary><p>Categoría + marca + atributo + correlativo, separado por guiones.</p></details>
      <details><summary>¿Cuántos caracteres?</summary><p>8-15 es la zona recomendada.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .sk-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .sk-row { grid-template-columns: 1fr; } }
</style>

<script>
  const catEl = document.getElementById('sk-cat') as HTMLInputElement;
  const brandEl = document.getElementById('sk-brand') as HTMLInputElement;
  const attrEl = document.getElementById('sk-attr') as HTMLInputElement;
  const padEl = document.getElementById('sk-pad') as HTMLInputElement;
  const modeEl = document.getElementById('sk-mode') as HTMLSelectElement;
  const amountEl = document.getElementById('sk-amount') as HTMLInputElement;
  const out = document.getElementById('sk-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('sk-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('sk-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function clean(s: string) { return s.toUpperCase().replace(/[^A-Z0-9-]/g, ''); }

  function generate() {
    const cat = clean(catEl.value || 'TS');
    const brand = clean(brandEl.value || 'XXX');
    const attr = clean(attrEl.value || '');
    const pad_ = Math.max(3, Math.min(6, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      const seq = mode === 'seq' ? pad(i + 1, pad_) : pad(rint(Math.pow(10, pad_)), pad_);
      const parts = [cat, brand, attr, seq].filter(Boolean);
      arr.push(parts.join('-'));
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = '¡Copiado!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
