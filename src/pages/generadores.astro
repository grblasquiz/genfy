---
import Layout from '../layouts/Layout.astro';
import { GENERATORS, urlFor, CATEGORIES_ES, type GeneratorMeta } from '../lib/generators';
import { SITE_URL } from '../lib/i18n';

const title = `Todos los generadores online (${GENERATORS.length}) | Genfy`;
const description = `Catálogo completo de ${GENERATORS.length} generadores online gratis: contraseñas, nombres, hashtags, QR, paletas de colores, datos de testing y más. Sin registro.`;

const byCategory = GENERATORS.reduce((acc, g) => {
  (acc[g.category] = acc[g.category] || []).push(g);
  return acc;
}, {} as Record<GeneratorMeta['category'], GeneratorMeta[]>);

const ORDER: GeneratorMeta['category'][] = [
  'security', 'tech', 'data', 'business', 'marketing',
  'design', 'random', 'pets', 'people', 'work', 'content', 'inspiration', 'fun', 'tools',
];

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Generadores online',
  numberOfItems: GENERATORS.length,
  itemListElement: GENERATORS.slice(0, 50).map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.title.es,
    url: `${SITE_URL}${urlFor(g, 'es')}`,
  })),
};
---
<Layout title={title} description={description} lang="es" schema={itemListSchema}>
  <header class="hero">
    <h1>Todos los generadores</h1>
    <p class="lead">
      {GENERATORS.length} herramientas gratis, sin registro, todas funcionan en tu navegador.
      Organizadas por categoría para que encuentres rápido.
    </p>
    <div class="search-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      <input
        type="search"
        id="gen-search"
        placeholder="Buscar entre 287 generadores… (contraseñas, paletas, hashtags, slogans...)"
        autocomplete="off"
        spellcheck="false"
        aria-label="Buscar generadores"
      />
      <button class="search-clear" id="gen-search-clear" type="button" aria-label="Limpiar" hidden>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
      <kbd class="search-kbd">/</kbd>
    </div>
    <p class="search-status" id="search-status" hidden></p>
  </header>

  <div id="cat-sections">
    {ORDER.filter(c => byCategory[c]?.length).map(cat => (
      <section class="cat-section" id={cat} data-cat={cat}>
        <h2>{CATEGORIES_ES[cat]} <span class="cat-count">(<span class="cat-count-n">{byCategory[cat].length}</span>)</span></h2>
        <div class="grid-cards">
          {byCategory[cat].map(g => (
            <a class="gcard" href={urlFor(g, 'es')} data-title={g.title.es.toLowerCase()} data-desc={g.description.es.toLowerCase()} data-cat={g.category}>
              <span class="gcard-emoji">{g.emoji}</span>
              <span class="gcard-title">{g.title.es}</span>
              <span class="gcard-desc">{g.description.es}</span>
              <span class="gcard-arrow" aria-hidden="true">→</span>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>

  <div id="search-empty" class="search-empty" hidden>
    <p>Sin resultados para <strong id="search-q"></strong>.</p>
    <p class="muted">Probá con otra palabra clave o <a href="#" id="clear-search-link">limpiá el filtro</a>.</p>
  </div>

  <script is:inline>
    (function() {
      const input = document.getElementById('gen-search');
      const clearBtn = document.getElementById('gen-search-clear');
      const status = document.getElementById('search-status');
      const empty = document.getElementById('search-empty');
      const sections = document.querySelectorAll('.cat-section');
      const allCards = document.querySelectorAll('.gcard');
      const totalAll = allCards.length;
      let currentQuery = '';

      function normalize(s) {
        return (s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
      }

      function filter(q) {
        const query = normalize(q.trim());
        currentQuery = query;
        clearBtn.hidden = query.length === 0;
        let total = 0;
        sections.forEach(sec => {
          const cards = sec.querySelectorAll('.gcard');
          let visible = 0;
          cards.forEach(c => {
            const t = normalize(c.dataset.title || '');
            const d = normalize(c.dataset.desc || '');
            const cat = normalize(c.dataset.cat || '');
            const match = !query || t.includes(query) || d.includes(query) || cat.includes(query);
            c.hidden = !match;
            if (match) visible++;
          });
          sec.hidden = visible === 0;
          const n = sec.querySelector('.cat-count-n');
          if (n) n.textContent = String(visible);
          total += visible;
        });
        if (!query) {
          status.hidden = true;
          empty.hidden = true;
        } else if (total === 0) {
          status.hidden = true;
          empty.hidden = false;
          document.getElementById('search-q').textContent = '"' + q + '"';
        } else {
          status.hidden = false;
          empty.hidden = true;
          status.textContent = total === 1 ? '1 resultado' : total + ' resultados';
        }
      }

      input.addEventListener('input', e => filter(e.target.value));
      clearBtn.addEventListener('click', () => { input.value = ''; filter(''); input.focus(); });
      document.getElementById('clear-search-link').addEventListener('click', e => { e.preventDefault(); input.value = ''; filter(''); input.focus(); });
      // "/" shortcut to focus
      document.addEventListener('keydown', e => {
        if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
          e.preventDefault();
          input.focus();
        }
        if (e.key === 'Escape' && document.activeElement === input) {
          input.value = '';
          filter('');
          input.blur();
        }
      });
    })();
  </script>
</Layout>

<style>
  .hero { padding: 3rem 0 2rem; }
  .hero .lead { font-size: 1.0625rem; color: var(--text-soft); max-width: 60ch; margin-top: 1rem; }

  .search-wrap {
    position: relative;
    max-width: 640px;
    margin-top: 1.75rem;
    display: flex;
    align-items: center;
  }
  .search-wrap input {
    width: 100%;
    padding: 0.875rem 6.5rem 0.875rem 2.875rem;
    font-size: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    color: var(--text);
    transition: border-color 180ms var(--ease), box-shadow 180ms var(--ease);
  }
  .search-wrap input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
  .search-icon { position: absolute; left: 1rem; color: var(--text-muted); pointer-events: none; }
  .search-clear { position: absolute; right: 3rem; display: inline-flex; align-items: center; justify-content: center; width: 24px; height: 24px; background: var(--bg-inset); border: 0; border-radius: 50%; color: var(--text-soft); cursor: pointer; }
  .search-clear:hover { background: var(--border); color: var(--text); }
  .search-kbd { position: absolute; right: 0.875rem; padding: 0.125rem 0.4375rem; background: var(--bg-inset); border: 1px solid var(--border); border-radius: 4px; color: var(--text-subtle); font-family: var(--font-mono); font-size: 0.75rem; pointer-events: none; }
  .search-status { margin-top: 0.75rem; color: var(--text-subtle); font-size: 0.875rem; font-feature-settings: "tnum"; }
  .search-status[hidden] { display: none; }
  .search-empty {
    margin-top: 3rem;
    padding: 2rem;
    text-align: center;
    background: var(--bg-soft);
    border: 1px dashed var(--border);
    border-radius: var(--radius-lg);
  }
  .search-empty[hidden] { display: none; }
  .gcard[hidden] { display: none; }
  .cat-section[hidden] { display: none; }

  .cat-section { margin-top: 3rem; }
  .cat-section h2 {
    font-size: 1.375rem; font-weight: 600; margin: 0 0 1.25rem;
    border-bottom: 1px solid var(--border-soft); padding-bottom: 0.75rem;
  }
  .cat-count { color: var(--text-muted); font-weight: 400; font-size: 0.9rem; }
  .gcard { position: relative; display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; color: var(--text); transition: border-color var(--t-base) var(--ease), transform var(--t-base) var(--ease), box-shadow var(--t-base) var(--ease); }
  .gcard:hover { border-color: var(--text); transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
  .gcard-emoji { font-size: 1.375rem; line-height: 1; }
  .gcard-title { font-weight: 600; font-size: 0.9375rem; letter-spacing: -0.01em; color: var(--text); }
  .gcard-desc { color: var(--text-soft); font-size: 0.8125rem; line-height: 1.5; }
  .gcard-arrow { position: absolute; top: 1.25rem; right: 1.25rem; color: var(--text-muted); font-size: 0.9rem; transition: transform var(--t-base) var(--ease), color var(--t-base) var(--ease); }
  .gcard:hover .gcard-arrow { color: var(--accent); transform: translateX(3px); }
</style>
