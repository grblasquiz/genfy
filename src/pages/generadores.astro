---
import Layout from '../layouts/Layout.astro';
import { GENERATORS, urlFor } from '../lib/generators';

const title = 'Todos los generadores online | Genfy';
const description = 'Explorá todos los generadores online gratis de Genfy: contraseñas, nombres de empresa, lorem ipsum, nombres para mascotas, códigos QR y más.';
---
<Layout title={title} description={description} lang="es">
  <h1>Todos los generadores</h1>
  <p class="lead">
    Catálogo completo de herramientas de Genfy. Todas son gratis, funcionan en tu navegador
    y no requieren registro.
  </p>
  <div class="grid-cards" style="margin-top:1.5rem;">
    {GENERATORS.map(g => (
      <a class="gcard" href={urlFor(g, 'es')}>
        <span class="gcard-emoji">{g.emoji}</span>
        <span class="gcard-title">{g.title.es}</span>
        <span class="gcard-desc">{g.description.es}</span>
      </a>
    ))}
  </div>
</Layout>
<style>
  .lead { font-size: 1.0625rem; color: var(--text-soft); max-width: 60ch; }
  .gcard { display: flex; flex-direction: column; gap: 0.375rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; color: var(--text); transition: transform 0.1s, box-shadow 0.1s, border-color 0.1s; }
  .gcard:hover { transform: translateY(-2px); box-shadow: var(--shadow); border-color: var(--primary); text-decoration: none; }
  .gcard-emoji { font-size: 1.75rem; }
  .gcard-title { font-weight: 700; font-size: 1.0625rem; }
  .gcard-desc { color: var(--text-soft); font-size: 0.9rem; line-height: 1.5; }
</style>
