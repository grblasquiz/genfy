---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de números de pedido | Genfy';
const description = 'Generá números de pedido (purchase order) profesionales. Formato configurable: prefijo, fecha, secuencial o aleatorio. Para ecommerce y operaciones.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Diferencia entre número de pedido y de factura?', acceptedAnswer: { '@type': 'Answer', text: 'El pedido (PO) es el documento interno que arma una operación; la factura (invoice) es el documento fiscal que se emite cuando se cobra. Pueden tener numeraciones distintas.' } },
    { '@type': 'Question', name: '¿Qué formato uso?', acceptedAnswer: { '@type': 'Answer', text: 'Para ecommerce, ORD-YYYYMMDD-#### (prefijo, fecha, correlativo) es el más legible. Para B2B, PO-YYYY-#### es estándar.' } },
    { '@type': 'Question', name: '¿Tienen que ser correlativos?', acceptedAnswer: { '@type': 'Answer', text: 'Para gestión interna no hay obligación legal — pero conviene mantener correlativos para auditoría operativa y trazabilidad.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Trabajo / Work" title="Generador de números de pedido"
    intro="Construí formatos de número de pedido (purchase order). Ideal para ecommerce, operaciones, compras corporativas y trazabilidad.">

    <div slot="tool" class="po">
      <div class="po-row">
        <div>
          <label for="po-prefix">Prefijo</label>
          <input id="po-prefix" type="text" value="ORD" maxlength="6" />
        </div>
        <div>
          <label for="po-fmt">Formato fecha</label>
          <select id="po-fmt">
            <option value="year">Solo año (YYYY)</option>
            <option value="date" selected>Fecha completa (YYYYMMDD)</option>
            <option value="month">Año y mes (YYYYMM)</option>
            <option value="none">Sin fecha</option>
          </select>
        </div>
        <div>
          <label for="po-pad">Dígitos correlativo</label>
          <input id="po-pad" type="number" value="4" min="3" max="8" />
        </div>
      </div>
      <div class="po-row">
        <div>
          <label for="po-mode">Modo</label>
          <select id="po-mode">
            <option value="seq">Secuencial</option>
            <option value="random">Aleatorio</option>
          </select>
        </div>
        <div>
          <label for="po-start">Inicio</label>
          <input id="po-start" type="number" value="1" min="1" />
        </div>
        <div>
          <label for="po-amount">Cantidad</label>
          <input id="po-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="po-gen" class="btn btn-primary" type="button">Generar</button>
      <button id="po-copy" class="btn btn-ghost" type="button">Copiar</button>
      <textarea id="po-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>Pedido vs. factura: una distinción que se pierde seguido</h2>
      <p>
        El número de pedido (purchase order, PO) es el ID interno con el que tu equipo
        identifica una operación: lo que el cliente compró, lo que vos vas a entregar. La
        factura (invoice) es el documento fiscal que se emite cuando cobrás. Un mismo pedido
        puede generar varias facturas (entregas parciales) o ninguna (si se cancela). Por eso
        conviene tener numeraciones independientes — y por eso los CRMs serios separan ambos
        flujos.
      </p>

      <h2>Formato recomendado por industria</h2>
      <ul>
        <li><strong>Ecommerce.</strong> ORD-YYYYMMDD-#### es lo más útil: te dice de un vistazo cuándo se hizo el pedido sin tener que mirar la base.</li>
        <li><strong>B2B / corporate.</strong> PO-YYYY-#### con correlativo de 5-6 dígitos. Más anónimo, mejor para procesos largos donde la fecha exacta no es crítica.</li>
        <li><strong>SaaS / suscripciones.</strong> SUB-{ClienteID}-#### es común porque ata el pedido al cliente desde el ID.</li>
        <li><strong>Logística / dropshipping.</strong> Suelen agregar prefijo de origen: ORD-AR-2026-####, ORD-MX-2026-####.</li>
      </ul>

      <h2>Por qué fecha en el ID</h2>
      <p>
        Incluir la fecha en el número del pedido tiene dos ventajas operativas: ordenar la lista
        cronológicamente sin necesidad de campo extra, y debuggear rápido cuando un cliente
        llama por una compra de "hace dos meses". Si vos manejás más de 100 pedidos por día,
        considerá pasar al modelo sin fecha y mantener orden por base de datos — el ID empieza
        a alargarse mucho.
      </p>

      <h2>Secuencial vs. aleatorio</h2>
      <p>
        El secuencial es preferible para gestión interna y auditoría. El aleatorio se usa
        cuando no querés exponer cuántos pedidos tenés (por ejemplo, en una tienda nueva: si
        tu cliente ve "ORD-2026-0003" sabe que sos el tercer pedido de la historia). Un atajo
        común es arrancar el secuencial en un número alto (10001 en vez de 1) para evitar el
        problema sin renunciar al orden.
      </p>

      <h2>Trazabilidad: qué guardar junto al ID</h2>
      <ol>
        <li><strong>Timestamp de creación.</strong> Aunque la fecha esté en el ID, guardá la hora exacta.</li>
        <li><strong>Estado.</strong> Pendiente, pagado, en preparación, enviado, entregado, devuelto, cancelado.</li>
        <li><strong>Cliente y método de pago.</strong> Para reconciliación.</li>
        <li><strong>Logs de cambios de estado.</strong> Quién lo movió y cuándo. Esto te salva en disputas.</li>
      </ol>

      <h2>Errores frecuentes</h2>
      <ul>
        <li><strong>Reusar IDs.</strong> Si un pedido se cancela, NO reasignes ese ID — generás confusión histórica.</li>
        <li><strong>Cambiar formato a mitad de año.</strong> Mantenelo estable; cambiá solo en transición de año fiscal.</li>
        <li><strong>IDs ultra-largos.</strong> Más de 20 caracteres se vuelve molesto al teléfono y al chat.</li>
        <li><strong>Letras y números similares.</strong> Evitá O y 0, I y 1 en posiciones que confundan.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>¿Pedido vs. factura?</summary><p>El pedido es interno; la factura es fiscal. Pueden tener numeraciones distintas.</p></details>
      <details><summary>¿Qué formato uso?</summary><p>Ecommerce: ORD-YYYYMMDD-####. B2B: PO-YYYY-####.</p></details>
      <details><summary>¿Correlativos?</summary><p>No es obligación legal, pero ayuda a auditoría y trazabilidad.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .po-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .po-row { grid-template-columns: 1fr; } }
</style>

<script>
  const prefixEl = document.getElementById('po-prefix') as HTMLInputElement;
  const fmtEl = document.getElementById('po-fmt') as HTMLSelectElement;
  const padEl = document.getElementById('po-pad') as HTMLInputElement;
  const modeEl = document.getElementById('po-mode') as HTMLSelectElement;
  const startEl = document.getElementById('po-start') as HTMLInputElement;
  const amountEl = document.getElementById('po-amount') as HTMLInputElement;
  const out = document.getElementById('po-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('po-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('po-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function dateFmt(): string {
    const d = new Date(); const y = d.getFullYear(); const m = pad(d.getMonth() + 1, 2); const day = pad(d.getDate(), 2);
    const f = fmtEl.value;
    if (f === 'year') return `${y}`;
    if (f === 'month') return `${y}${m}`;
    if (f === 'date') return `${y}${m}${day}`;
    return '';
  }
  function generate() {
    const prefix = (prefixEl.value || 'ORD').toUpperCase();
    const pad_ = Math.max(3, Math.min(8, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const start = Math.max(1, parseInt(startEl.value || '1', 10));
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const dateP = dateFmt();
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      let core = '';
      if (mode === 'seq') core = pad(start + i, pad_);
      else core = pad(rint(Math.pow(10, pad_)), pad_);
      const parts = [prefix, dateP, core].filter(Boolean);
      arr.push(parts.join('-'));
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = '¡Copiado!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
