---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de nombre de serie gratis | Genfy';
const description = 'Generá nombres de serie de TV o streaming en segundos. Combiná género, ambiente y formato para conseguir 20 títulos listos para tu pitch.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cómo elijo el nombre de una serie?', acceptedAnswer: { '@type': 'Answer', text: 'Un buen nombre de serie es corto, comunica el género, sostiene varias temporadas y es único en plataformas como Netflix, Prime y HBO Max.' } },
    { '@type': 'Question', name: '¿El nombre debe describir la trama?', acceptedAnswer: { '@type': 'Answer', text: 'Mejor si sugiere el clima emocional o el lugar central, no la trama puntual. Los títulos descriptivos envejecen rápido.' } },
    { '@type': 'Question', name: '¿Cuántas palabras debe tener?', acceptedAnswer: { '@type': 'Answer', text: 'Una a tres palabras es lo ideal para que se vea bien en thumbnails de plataformas y banners de redes.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Entretenimiento" title="Generador de nombre de serie"
    intro="Generá nombres para tu próxima serie de TV o streaming. Combiná género, ambiente y formato para conseguir 20 ideas listas para tu pitch o piloto.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Tema o palabra clave</label>
      <input id="bn-kw" type="text" placeholder="ciudad, familia, secreto..." value="frontera" />

      <label for="bn-style" style="margin-top:1rem">Tono</label>
      <select id="bn-style">
        <option value="prestige">Drama prestige (Bajo el sol)</option>
        <option value="crime">Crime / thriller (La línea oscura)</option>
        <option value="comedy">Comedia (Mejores amigos)</option>
        <option value="scifi">Sci-fi (El protocolo)</option>
        <option value="single">Una sola palabra (Frontera)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 20 títulos</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>Cómo nombrar una serie</h2>
      <p>
        El nombre de una serie tiene que sobrevivir varias temporadas, pósters y un avalanche de
        thumbnails en plataformas. La diferencia con una película es la duración: un título
        demasiado pegado a la trama del primer episodio queda mal cuando la historia muta. Por eso
        los grandes títulos de TV suelen apuntar a un lugar, una emoción o un código (Severance,
        Succession, Better Call Saul) más que a un evento puntual.
      </p>
      <ol>
        <li><strong>Pensá en cinco temporadas.</strong> Si el título es "El asesinato de Pablo", queda raro a partir de la temporada dos.</li>
        <li><strong>Comunicá el género.</strong> El espectador escanea thumbnails: thriller, comedia o drama tiene que ser claro.</li>
        <li><strong>Una a tres palabras.</strong> Los títulos largos se cortan en grids móviles.</li>
        <li><strong>Único en streaming.</strong> Buscá en Netflix, Prime, HBO Max y Apple TV. Las colisiones matan SEO.</li>
        <li><strong>Que aguante el merch.</strong> ¿Se ve bien en una taza, una remera, un poster? Si no, descartalo.</li>
      </ol>

      <h2>Estilos por género</h2>
      <ul>
        <li><strong>Drama prestige</strong>: títulos cortos, conceptuales, con referencia ambiental (Sucesión, Bajo el sol, El reino).</li>
        <li><strong>Crime / thriller</strong>: artículo definido + sustantivo amenazante (La línea oscura, El protocolo).</li>
        <li><strong>Comedia</strong>: claves del grupo o relación (Mejores amigos, Vecinos imposibles).</li>
        <li><strong>Sci-fi</strong>: códigos secos o protocolos (Severance, El experimento, Subcapa 7).</li>
        <li><strong>Una palabra</strong>: el formato premium, alto impacto (Frontera, Verano, Hueso).</li>
      </ul>

      <h2>Errores comunes</h2>
      <p>
        El más común: títulos demasiado descriptivos que pierden vigencia tras la primera
        temporada. Otro: nombres con artículos largos ("La increíble historia de…") que las
        plataformas truncan. Un tercero: títulos en idioma extranjero sin justificación que
        confunden al algoritmo. Y por último, evitar referencias mitológicas trilladas: si
        encontrás un título potente que conecta con un dios griego o nórdico, pensalo dos veces;
        ya hay miles.
      </p>

      <h2>Después de generar</h2>
      <ol>
        <li>Búsqueda en IMDb, Netflix, Prime, HBO Max y JustWatch.</li>
        <li>Verificá disponibilidad de dominio para sitio de campaña.</li>
        <li>Probalo en un thumbnail: ¿se lee a 100x140 píxeles?</li>
        <li>Mostralo a tres lectores del piloto: ¿adivinan el tono?</li>
        <li>Pasá el filtro de cinco temporadas: ¿sigue funcionando?</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>¿Cómo elijo el nombre de una serie?</summary><p>Corto, comunica el género, sostiene varias temporadas y es único en plataformas.</p></details>
      <details><summary>¿Debe describir la trama?</summary><p>Mejor sugerir el clima o el lugar, no el evento puntual.</p></details>
      <details><summary>¿Cuántas palabras debe tener?</summary><p>De una a tres es lo ideal para thumbnails.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; user-select: text; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const PRESTIGE = ['Bajo el sol', 'El reino', 'Sucesión', 'La costa', 'El verano largo', 'Tierra firme', 'La quinta'];
  const CRIME = ['La línea oscura', 'El protocolo', 'Sin ruido', 'Frontera norte', 'La pista', 'Sangre limpia'];
  const COMEDY = ['Mejores amigos', 'Vecinos imposibles', 'Familia rota', 'Trabajo nuevo', 'Equipo de oficina'];
  const SCIFI = ['El experimento', 'Subcapa 7', 'Protocolo nueve', 'Salida cero', 'La cápsula', 'Reset'];
  const NOUN = ['Frontera', 'Verano', 'Hueso', 'Niebla', 'Garra', 'Eco', 'Marea', 'Costa'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const words = kw.value.split(',').map(s => s.trim()).filter(Boolean);
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let name = '';
      if (s === 'prestige') name = pick(PRESTIGE);
      else if (s === 'crime') name = pick(CRIME);
      else if (s === 'comedy') name = pick(COMEDY);
      else if (s === 'scifi') name = pick(SCIFI);
      else if (s === 'single') name = words.length ? cap(pick(words)) : pick(NOUN);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click para copiar';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
