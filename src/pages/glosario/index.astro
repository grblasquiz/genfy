---
import Layout from '../../layouts/Layout.astro';
import type { GlossaryEntry } from '../../lib/glossary-data/types';

const mods = import.meta.glob<{ entry: GlossaryEntry }>('../../lib/glossary-data/*.ts', { eager: true });
const entries: { slug: string; emoji: string; h1: string; short: string }[] = [];
for (const [filepath, mod] of Object.entries(mods)) {
  if (!mod.entry || filepath.includes('/types.ts')) continue;
  entries.push({
    slug: mod.entry.slug.es,
    emoji: mod.entry.emoji,
    h1: mod.entry.es.h1,
    short: mod.entry.es.short,
  });
}
entries.sort((a, b) => a.h1.localeCompare(b.h1));

const title = `Glosario técnico (${entries.length} términos) | Genfy`;
const description = `Glosario bilingüe de términos técnicos: hash, JWT, UUID, Base64, regex, CSS, hashing, web. ${entries.length} entradas con ejemplos y links a generadores Genfy.`;
---
<Layout title={title} description={description} lang="es">
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="crumb-current">Glosario</span>
  </nav>

  <header class="glo-index-hero">
    <h1>Glosario técnico</h1>
    <p class="lead">{entries.length} términos explicados con criterio: definición, cómo funciona, cuándo usarlo y links a los generadores Genfy relacionados.</p>
  </header>

  <div class="glo-index-grid">
    {entries.map(e => (
      <a class="glo-index-card" href={`/glosario/${e.slug}`}>
        <span class="glo-index-emoji">{e.emoji}</span>
        <span class="glo-index-title">{e.h1}</span>
        <span class="glo-index-short">{e.short}</span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; color: var(--text-muted); font-size: 0.8125rem; margin: 1.5rem 0 0; flex-wrap: wrap; }
  .crumbs a { color: var(--text-subtle); text-decoration: none; }
  .crumbs a:hover { color: var(--text); }
  .crumb-sep { color: var(--text-muted); }
  .crumb-current { color: var(--text); font-weight: 500; }
  .glo-index-hero { padding: 2rem 0; max-width: 680px; }
  .glo-index-hero h1 { font-size: clamp(2rem, 4vw, 2.75rem); margin: 0 0 0.875rem; letter-spacing: -0.02em; }
  .lead { font-size: 1.0625rem; color: var(--text-soft); margin: 0; line-height: 1.55; }
  .glo-index-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.75rem; margin-bottom: 4rem; }
  .glo-index-card { display: flex; flex-direction: column; gap: 0.375rem; padding: 1rem 1.125rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; color: var(--text); transition: border-color 180ms var(--ease), transform 180ms var(--ease); }
  .glo-index-card:hover { border-color: var(--accent); transform: translateY(-1px); text-decoration: none; }
  .glo-index-emoji { font-size: 1.25rem; }
  .glo-index-title { font-weight: 700; font-size: 1rem; letter-spacing: -0.01em; }
  .glo-index-short { font-size: 0.8125rem; color: var(--text-soft); line-height: 1.5; }
</style>
