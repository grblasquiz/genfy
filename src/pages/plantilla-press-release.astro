---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Plantilla de comunicado de prensa | Genfy';
const description = 'Generá un comunicado de prensa profesional con estructura AIDA, titular, lead, cuerpo, cita y boilerplate. Listo para enviar a periodistas.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué es un comunicado de prensa?', acceptedAnswer: { '@type': 'Answer', text: 'Es un documento breve y formal que una empresa envía a medios para anunciar una novedad relevante: lanzamiento, ronda, alianza, premio o cambio importante.' } },
    { '@type': 'Question', name: '¿Cuánto debe medir?', acceptedAnswer: { '@type': 'Answer', text: 'Idealmente entre 300 y 500 palabras. Una página A4 como máximo. Si el periodista necesita más datos, va a pedirlos.' } },
    { '@type': 'Question', name: '¿Por qué AIDA y no otra estructura?', acceptedAnswer: { '@type': 'Answer', text: 'AIDA (Atención-Interés-Deseo-Acción) sigue siendo el esqueleto que mejor funciona en comunicados porque respeta cómo lee un periodista: titular fuerte, datos en orden de importancia y CTA claro.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Empresa / Business" title="Plantilla de comunicado de prensa"
    intro="Completá los datos de la novedad y obtené un comunicado completo con titular, lead, cuerpo, cita ejecutiva y boilerplate. Listo para enviar a tu lista de medios.">

    <div slot="tool" class="pr">
      <label>Empresa</label>
      <input id="pr-co" type="text" value="Acme Corp" />

      <label style="margin-top:1rem">Tipo de novedad</label>
      <select id="pr-type">
        <option value="lanzamiento">Lanzamiento de producto</option>
        <option value="ronda">Ronda de inversión</option>
        <option value="alianza">Alianza estratégica</option>
        <option value="premio">Premio o reconocimiento</option>
        <option value="expansion">Expansión a nuevo mercado</option>
      </select>

      <label style="margin-top:1rem">Titular en una frase</label>
      <input id="pr-title" type="text" value="Acme Corp lanza su nueva plataforma de cursos para profesionales en transición" />

      <label style="margin-top:1rem">Dato clave (cifra, fecha, hito)</label>
      <input id="pr-key" type="text" value="50.000 alumnos en su primer año" />

      <label style="margin-top:1rem">Voz autorizada (cargo)</label>
      <input id="pr-spokesperson" type="text" value="Juan Pérez, CEO de Acme Corp" />

      <button id="pr-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar comunicado</button>

      <pre id="pr-out" class="pr-out"></pre>
    </div>

    <div slot="content">
      <h2>Cómo se estructura un comunicado de prensa</h2>
      <p>
        El comunicado de prensa es un género con reglas precisas. Un periodista que recibe 80 mails
        por día no va a perdonar la ambigüedad. Por eso la estructura clásica sigue intacta desde
        hace décadas: titular, lead, cuerpo en pirámide invertida, cita ejecutiva, boilerplate y
        contacto. Lo único que cambió es que hoy hay que pensar también en SEO y en cómo se ve el
        comunicado pegado en Slack o WhatsApp.
      </p>

      <h2>Aplicar AIDA al comunicado</h2>
      <p>
        AIDA es el esqueleto comercial más antiguo: Atención, Interés, Deseo, Acción. Aplicado al
        press release queda así:
      </p>
      <ol>
        <li><strong>Atención (titular):</strong> 8-12 palabras, directas, que digan qué pasó. "Acme Corp recauda USD 5M para escalar su plataforma de cursos".</li>
        <li><strong>Interés (lead):</strong> el primer párrafo responde quién, qué, cuándo, dónde, por qué. Tres frases máximo.</li>
        <li><strong>Deseo (cuerpo):</strong> dos o tres párrafos con el contexto, las cifras, el porqué importa. Cita textual del CEO o del partner.</li>
        <li><strong>Acción (cierre):</strong> boilerplate corporativo de 3-4 líneas + datos de contacto del responsable de prensa.</li>
      </ol>

      <h2>Las reglas no negociables</h2>
      <ul>
        <li><strong>Una sola noticia por comunicado.</strong> Si querés contar tres cosas, mandá tres comunicados.</li>
        <li><strong>Pirámide invertida.</strong> Lo más importante arriba. El periodista debería poder cortar el último párrafo y la nota seguiría teniendo sentido.</li>
        <li><strong>Cita ejecutiva real, no marketing.</strong> "Estamos muy contentos de anunciar..." no se publica nunca. "Pasamos de 5 a 50 mil clientes en 12 meses porque encontramos producto que el mercado pedía hace años" sí.</li>
        <li><strong>Boilerplate constante.</strong> Tres a cuatro líneas que describen la empresa, fundación, fundadores, alcance.</li>
        <li><strong>Adjunto: kit de prensa.</strong> Logo, fotos en alta, bios cortas, fact sheet.</li>
      </ul>

      <h2>Errores que tiran tu comunicado al spam</h2>
      <ol>
        <li>Titular con superlativos: "el mejor", "el primero del mundo", "revolucionario". Los periodistas los filtran automáticamente.</li>
        <li>Cuerpo con jerga interna. Si tu comunicado tiene 4 acrónimos en el primer párrafo, no se entiende.</li>
        <li>Sin cifras. Una noticia sin números es opinión.</li>
        <li>Mandarlo a una lista genérica de prensa. Mejor 10 periodistas relevantes con un mail personalizado que 200 con un envío masivo.</li>
        <li>No tener foto en alta resolución. Sin imagen no hay nota — al menos no atractiva.</li>
      </ol>

      <h2>Cuándo NO mandar un comunicado</h2>
      <p>
        No todo lo que pasa en tu empresa es noticia. No mandes comunicados por: contratar un nuevo
        gerente de nivel medio, sumar una integración menor, lanzar un cambio de marca cosmético o
        cumplir aniversarios sin un dato relevante. La regla simple: si tu propio equipo de ventas
        no lo encontraría útil para conversar con clientes, tampoco lo va a encontrar útil un
        periodista.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Qué es un comunicado de prensa?</summary><p>Un documento breve que una empresa envía a medios para anunciar una novedad relevante.</p></details>
      <details><summary>¿Cuánto debe medir?</summary><p>300 a 500 palabras, una página A4 máximo.</p></details>
      <details><summary>¿Por qué AIDA?</summary><p>Porque respeta el orden en que un periodista lee: titular fuerte, lead con quién/qué/cuándo, cuerpo con datos y cierre accionable.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .pr-out { margin-top: 1.25rem; padding: 1.25rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); white-space: pre-wrap; font-family: ui-monospace, monospace; font-size: 0.8125rem; line-height: 1.6; }
</style>

<script>
  const co = document.getElementById('pr-co') as HTMLInputElement;
  const type = document.getElementById('pr-type') as HTMLSelectElement;
  const titulo = document.getElementById('pr-title') as HTMLInputElement;
  const key = document.getElementById('pr-key') as HTMLInputElement;
  const sp = document.getElementById('pr-spokesperson') as HTMLInputElement;
  const out = document.getElementById('pr-out')!;
  const gen = document.getElementById('pr-gen') as HTMLButtonElement;

  function generate() {
    const today = new Date().toLocaleDateString('es-AR', { day: 'numeric', month: 'long', year: 'numeric' });
    const t = `PARA PUBLICACIÓN INMEDIATA
${today}

${titulo.value.toUpperCase()}

${key.value} respalda el anuncio. La compañía busca consolidar su posición y abrir nuevos frentes en los próximos 12 meses.

[Ciudad, ${today}] — ${co.value} anunció hoy ${titulo.value.toLowerCase()}. La novedad llega en un contexto de fuerte crecimiento del segmento y refleja la estrategia de la compañía de invertir donde detecta una demanda concreta del mercado.

El anuncio incluye ${key.value}, lo que ubica a ${co.value} entre los referentes de su categoría. La empresa proyecta sostener el ritmo de crecimiento durante los próximos trimestres apoyada en su base actual de clientes y nuevas alianzas estratégicas.

"${getCita(type.value, key.value)}", afirmó ${sp.value}.

Sobre ${co.value}
${co.value} es una empresa fundada con la misión de transformar su categoría a través de productos simples, accesibles y con foco en el resultado del cliente. Hoy atiende a miles de usuarios y opera en múltiples mercados.

Contacto de prensa
prensa@acme.example  |  +54 11 0000-0000

###`;
    out.textContent = t;
  }

  function getCita(type: string, key: string): string {
    if (type === 'lanzamiento') return `Llevamos meses preparándonos para este lanzamiento. ${key} muestra que el problema que resolvemos es real, y este paso nos acerca al estándar que queríamos establecer en la categoría`;
    if (type === 'ronda') return `Esta ronda nos da el oxígeno para ejecutar el plan de los próximos 24 meses sin compromisos. ${key} confirma la tracción y vamos a apoyarnos en eso para escalar`;
    if (type === 'alianza') return `La alianza nos permite llegar a un público al que solos no podríamos llegar en el corto plazo. ${key} ya estaba en nuestros números, y juntos podemos multiplicarlo`;
    if (type === 'premio') return `El reconocimiento es del equipo, no del management. ${key} es la consecuencia natural de haber priorizado al cliente cada vez que tuvimos que elegir`;
    return `${key} confirma que la apuesta era correcta. El mercado necesita lo que estamos construyendo, y estamos listos para servir a más clientes`;
  }

  gen.addEventListener('click', generate);
  generate();
</script>
