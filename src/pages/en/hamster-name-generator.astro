---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';
import { HAMSTER_NAMES, SMALL_PET_STYLES } from '../../lib/small-pet-names';

const title = 'Hamster Name Generator | Genfy';
const description = 'Cute, funny or food-themed: find the perfect name for your hamster. 60+ ideas in English and Spanish — free instant generator.';
const stylesEN = SMALL_PET_STYLES.en;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Do hamsters recognize their name?', acceptedAnswer: { '@type': 'Answer', text: 'They can learn to associate a sound with food. They don\'t recognize names like dogs do, but they react to consistent repeated sounds.' } },
    { '@type': 'Question', name: 'Good name for a male hamster?', acceptedAnswer: { '@type': 'Answer', text: 'Short and fun: Pip, Bumble, Mochi, Peanut, Pumpkin, Cookie. Aim for 1-2 syllables.' } },
    { '@type': 'Question', name: 'Does name length matter for hamsters?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Hamsters live 2-3 years — you want a name you actually enjoy saying, short and easy.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" withSidebar={true} schema={faqSchema}>
  <GeneratorShell lang="en" tag="Pets" title="Hamster Name Generator"
    intro="Cute, funny or food-themed: find the name that fits your hamster best. Click and get 12 fresh ideas.">

    <div slot="tool" class="cn">
      <label for="cn-style">Style</label>
      <select id="cn-style">
        {Object.entries(stylesEN).map(([k, v]) => <option value={k}>{v}</option>)}
        <option value="all">Mix of all</option>
      </select>
      <button id="cn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 12 names</button>
      <div id="cn-out" class="cn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a name for your hamster</h2>
      <p>
        Hamsters are tiny, round and often shy at first. The name should reflect that: short, soft,
        sweet. And — important — one you actually enjoy saying out loud, because you'll talk to them
        more than you think.
      </p>
      <ul>
        <li><strong>1 or 2 syllables.</strong> Pip, Mochi, Bumble, Peanut work much better than something elaborate.</li>
        <li><strong>Soft sounds.</strong> Hamsters have sensitive hearing — nothing harsh or shouted.</li>
        <li><strong>Pair it with food.</strong> Say the name right before a sunflower seed. After a few weeks they associate the sound with something good.</li>
        <li><strong>Match the personality.</strong> Always on the wheel: Wheels. Big cheeks: Cheeks. Always sleeping: Snooze.</li>
      </ul>

      <h2>Names by style</h2>
      <ul>
        <li><strong>Cute</strong> (Pip, Mochi, Bumble, Pumpkin): the most popular, fits almost any hamster.</li>
        <li><strong>Food</strong> (Peanut, Popcorn, Cookie, Caramel): plays on the cheek-stuffing image hamsters are known for.</li>
        <li><strong>Funny</strong> (Sir Cheeks, Captain Squeak, Doctor Wheel): for outsized personalities.</li>
      </ul>

      <h2>Trends</h2>
      <p>
        In US and UK exotic-pet vet directories, the most common hamster names are Peanut, Cookie,
        Mochi, Bumble, Pumpkin and Pip. Round-shape names (Bumble, Marshmallow, Pumpkin) and food
        names account for nearly half of all picks.
      </p>

      <h2>Common mistakes</h2>
      <ol>
        <li>Elaborate names that get shortened to a 1-syllable nickname anyway.</li>
        <li>Not using the name because "they don't get it" — you lose the chance to soothe them with your voice when they're scared.</li>
        <li>Names that rhyme with stronger words you say at home.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>Do hamsters recognize their name?</summary><p>They can learn to associate a sound with food. They don't recognize names like dogs do, but they react to consistent repeated sounds.</p></details>
      <details><summary>Good name for a male hamster?</summary><p>Short and fun: Pip, Bumble, Mochi, Peanut, Pumpkin, Cookie. Aim for 1-2 syllables.</p></details>
      <details><summary>Does name length matter for hamsters?</summary><p>Yes. Hamsters live 2-3 years — you want a name you actually enjoy saying, short and easy.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .cn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .cn-item { padding: 0.625rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; text-align: center; cursor: pointer; transition: border-color 0.1s; }
  .cn-item:hover { border-color: var(--primary); }
</style>

<script define:vars={{ DATA: HAMSTER_NAMES }}>
  const styleEl = document.getElementById('cn-style');
  const out = document.getElementById('cn-out');
  const gen = document.getElementById('cn-gen');

  function pick(arr) { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const s = styleEl.value;
    let pool = [];
    if (s === 'all') pool = [...DATA.cute.en, ...DATA.food.en, ...DATA.funny.en];
    else pool = DATA[s].en;
    const set = new Set();
    let attempts = 0;
    while (set.size < Math.min(12, pool.length) && attempts < 200) { attempts++; set.add(pick(pool)); }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'cn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
