---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Spa Name Generator | Genfy';
const description = 'Generate unique names for your spa or wellness center. Mix concept, sensation or service and get 20 ideas ready for storefront and domain.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What kind of name suits a spa?', acceptedAnswer: { '@type': 'Answer', text: 'Something that conveys calm, rest and professionalism. Words like rest, pause, refuge or minimalist names work very well.' } },
    { '@type': 'Question', name: 'How do I avoid sounding cliche?', acceptedAnswer: { '@type': 'Answer', text: 'Avoid saturated terms like "wellness", "balance" or "harmony". Look for concrete metaphors: water, stone, thread, sprout.' } },
    { '@type': 'Question', name: 'How do I check availability?', acceptedAnswer: { '@type': 'Answer', text: 'Google Maps within 3 miles, Instagram, domain and local trademark register before investing in signage.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Wellness" title="Spa Name Generator"
    intro="Mix element, concept or sensation and get 20 ideas for your spa, massage center or wellness lounge. Built to validate domain and handle instantly.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Keywords (concept, sensation, element)</label>
      <input id="bn-kw" type="text" placeholder="water, pause, stone..." value="water, pause" />

      <label for="bn-style" style="margin-top:1rem">Style</label>
      <select id="bn-style">
        <option value="single">One word (Pause, Rest)</option>
        <option value="elemental">Element + Spa (Water Spa)</option>
        <option value="boutique">Boutique (Atelier of Rest)</option>
        <option value="object">Natural object (Thread, Stone)</option>
        <option value="local">Local + Spa</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a spa name</h2>
      <p>
        A spa sells sensation more than service: calm, rest, professionalism. The name has to
        open that sensation in under a second from the storefront or an Instagram ad. If your
        candidate makes you think of stress, aggression or humor, it doesn't work.
      </p>
      <ol>
        <li><strong>Suggests rest, not obligation.</strong> "Rest", "Pause", "Refuge" work; "Total Body Boost" pushes.</li>
        <li><strong>Professional, not casual.</strong> Your client pays for trust in the team and cleanliness.</li>
        <li><strong>Tied to a concrete element.</strong> Water, stone, thread, sprout — real anchors, not abstractions.</li>
        <li><strong>Compatible with soft tones.</strong> Clean type on neutral palette.</li>
        <li><strong>Short IG handle.</strong> Where you post treatments and testimonials.</li>
      </ol>

      <h2>Styles that work for spas</h2>
      <ul>
        <li><strong>One word:</strong> "Pause", "Rest", "Quiet", "Refuge". Mood-driven, easy to remember.</li>
        <li><strong>Element + Spa:</strong> "Water Spa", "Stone Spa". Concrete and professional.</li>
        <li><strong>Boutique:</strong> "Atelier of Rest", "Maison Pause". Premium without cliche.</li>
        <li><strong>Natural object:</strong> "Thread", "Stone", "Sprout", "Mist". Physical anchors.</li>
        <li><strong>Local + Spa:</strong> "Mission Spa", "Brera Spa". Local SEO.</li>
      </ul>

      <h2>What to avoid</h2>
      <p>
        Avoid the saturated terms: "wellness", "harmony", "balance" and "total wellbeing"
        compete against hundreds of results. Communicate your offer in practical terms (muscle
        relaxation, sleep improvement, skincare) and reserve metaphors for imagery. Also avoid
        names that promise medical results: any suggestion of cure or treatment can lead to
        regulatory issues.
      </p>

      <h2>Quick validation</h2>
      <ol>
        <li>Google Maps within 3 miles.</li>
        <li>Instagram, TikTok, Booksy or Vagaro.</li>
        <li>Domain on Namecheap or Cloudflare.</li>
        <li>Local trademark register.</li>
        <li>Print on a test towel: does it convey calm?</li>
        <li>Tell 5 prospects: do they associate it with rest?</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>What name suits a spa?</summary><p>Conveys calm, rest, professionalism. Rest, pause, refuge work.</p></details>
      <details><summary>How to avoid cliche?</summary><p>Avoid wellness, harmony, balance. Pick concrete metaphors.</p></details>
      <details><summary>How to check availability?</summary><p>Google Maps, Instagram, domain and trademark register.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const SINGLE = ['Pause', 'Rest', 'Quiet', 'Refuge', 'Calm', 'Mist', 'Still', 'Steam', 'Soft', 'Edge'];
  const ELEM = ['Water', 'Stone', 'Thread', 'Sprout', 'Fog', 'Linen', 'Rock', 'Steam', 'Salt', 'Bamboo'];
  const BOUT = ['Atelier of Rest', 'Maison Pause', 'House of Calm', 'Studio Mist', 'Salon Pause', 'Atelier Still'];
  const LOCAL = ['Mission', 'SoHo', 'Brera', 'Capitol', 'Hudson', 'River', 'Park', 'Pier'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const words = kw.value.split(',').map(s => s.trim()).filter(Boolean);
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      const w = words.length ? pick(words) : 'Spa';
      let name = '';
      if (s === 'single') name = pick(SINGLE);
      else if (s === 'elemental') name = pick(ELEM) + ' Spa';
      else if (s === 'boutique') name = pick(BOUT);
      else if (s === 'object') name = pick(ELEM);
      else if (s === 'local') name = pick(LOCAL) + ' Spa';
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
