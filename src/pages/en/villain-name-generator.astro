---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Villain Name Generator | Genfy';
const description = 'Generate original names for villains, antagonists and final bosses. Mix dark tones, titles and stylish attributes.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What makes a villain memorable?', acceptedAnswer: { '@type': 'Answer', text: 'A strong villain has believable motivation, visual presence and a name that hints at their power or wound. The name should be short, sharp and easy to shout in an action scene.' } },
    { '@type': 'Question', name: 'How do I avoid cliches?', acceptedAnswer: { '@type': 'Answer', text: 'Avoid pseudo-German last names, overused Lord/Doctor prefixes and references to ancient deities. Pick concrete imagery: rust, thorn, raven, ash, cinder.' } },
    { '@type': 'Question', name: 'Does it work for tabletop RPGs?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, the names work for D&D campaigns, indie video games, novels and comics. Note three per session and pick the one that fits your antagonist best.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Creative" title="Villain Name Generator"
    intro="Mix title, dark attribute and signature trait to build memorable antagonists. For novels, comics, tabletop RPGs and video games.">

    <div slot="tool" class="vl">
      <label for="vl-style">Style</label>
      <select id="vl-style">
        <option value="title">With title (Lord, Baron, Doctor)</option>
        <option value="compound">Compound (Ironscar, Bonecrown)</option>
        <option value="agent">"The X of Y"</option>
        <option value="single">Single nickname</option>
      </select>

      <label for="vl-tone" style="margin-top:1rem">Tone</label>
      <select id="vl-tone">
        <option value="cold">Cold / methodical</option>
        <option value="rotten">Decayed / corrupt</option>
        <option value="savage">Savage / brutal</option>
        <option value="cunning">Cunning / manipulator</option>
      </select>

      <button id="vl-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>
      <div id="vl-out" class="vl-out"></div>
    </div>

    <div slot="content">
      <h2>What separates a memorable villain from a forgettable one</h2>
      <p>A weak antagonist has a generic name, fuzzy motivation and a single good scene. A memorable one meets three conditions: the name evokes a concrete image, the actions follow internal logic, and the reader understands why this character believes they're right. The name is the first crack the reader peeks through into that twisted logic.</p>
      <h2>Formulas that work</h2>
      <ol>
        <li><strong>Title + dark surname.</strong> Lord Raven, Baron Rust, Doctor Thorn. Sounds medieval or gothic and fits fantasy and horror.</li>
        <li><strong>English compound.</strong> Ironscar, Bonecrown, Rotwolf, Coldfang. Works very well for video games and comics.</li>
        <li><strong>Epithet structure.</strong> "The Hunter of the Wastes", "The Hand of Ash". Adds gravitas without being on the nose.</li>
        <li><strong>Single nickname.</strong> Cinder, Brine, Mordrak, Helkan. One word the rest of the world says with fear.</li>
      </ol>
      <h2>Mistakes that kill a villain before they speak</h2>
      <p>The wrong name can ruin three chapters. The most expensive mistakes: copying famous villain names with one letter changed, using ancient deities as shorthand for "evil" (it's lazy and culturally questionable), picking a name so long the hero can never shout it in an action beat, and names that get confused with the protagonist's at a glance.</p>
      <h2>Picking by genre</h2>
      <ul>
        <li><strong>Epic fantasy:</strong> longer titles and solemn rhythm (Baron of Black Iron).</li>
        <li><strong>Urban thriller:</strong> short, almost street-level nickname (Brine, Ash).</li>
        <li><strong>Sci-fi:</strong> tech compounds (Voidkeeper, Nullbinder).</li>
        <li><strong>Cosmic horror:</strong> words that feel older than the language (Mordrak, Helkan).</li>
      </ul>
      <h2>Final validation</h2>
      <p>Before locking it, read the name out loud three times. If the hero can shout it while wounded, if it fits on the book cover, if no one says "isn't that from such-and-such comic?", and if you still find it threatening after the fifth read, you have your villain.</p>
    </div>

    <div slot="faq">
      <details><summary>What makes a villain memorable?</summary><p>Believable motivation, visual presence and a short name easy to shout.</p></details>
      <details><summary>How do I avoid cliches?</summary><p>Avoid ancient deities and pseudo-German surnames. Pick concrete imagery: rust, thorn, raven.</p></details>
      <details><summary>Does it work for tabletop RPGs?</summary><p>Yes, it works for D&D, indie games, novels and comics.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .vl-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .vl-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; }
  .vl-item:hover { border-color: var(--primary); }
</style>

<script>
  const TITLES = ['Lord', 'Lady', 'Baron', 'Baroness', 'Doctor', 'Master', 'Count', 'Marshal', 'Warden', 'Inquisitor'];
  const COLD = ['Iron', 'Steel', 'Mist', 'Rust', 'Lead', 'Copper', 'Granite', 'Grit'];
  const ROT = ['Carrion', 'Ash', 'Dust', 'Thistle', 'Brine', 'Mold', 'Salt', 'Decay'];
  const SAV = ['Claw', 'Fang', 'Thorn', 'Edge', 'Bone', 'Cinder', 'Pyre', 'Char'];
  const CUN = ['Shade', 'Glass', 'Ink', 'Cord', 'Thread', 'Veil', 'Mirror', 'Cloth'];
  const ENG_DARK = ['Iron', 'Bone', 'Rot', 'Cold', 'Ash', 'Rust', 'Cinder', 'Black', 'Grim', 'Void', 'Null', 'Dread'];
  const ENG_NOUN = ['scar', 'crown', 'wolf', 'fang', 'fist', 'maw', 'shroud', 'thorn', 'gate', 'mark', 'reign', 'lash'];
  const PLACES = ['the Wastes', 'the Ash Plains', 'Black Iron', 'the Pyre', 'the Hollow', 'the Mist', 'the Salt Coast', 'the Cinder Halls'];
  const SINGLE = ['Brine', 'Cinder', 'Soot', 'Mordrak', 'Helkan', 'Vorkun', 'Tally', 'Vinegar', 'Spur', 'Hollow'];

  const style = document.getElementById('vl-style') as HTMLSelectElement;
  const tone = document.getElementById('vl-tone') as HTMLSelectElement;
  const gen = document.getElementById('vl-gen') as HTMLButtonElement;
  const out = document.getElementById('vl-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function pool(t: string) {
    if (t === 'cold') return COLD;
    if (t === 'rotten') return ROT;
    if (t === 'savage') return SAV;
    return CUN;
  }

  function generate() {
    const s = style.value, t = tone.value;
    const set = new Set<string>(); let tries = 0;
    while (set.size < 20 && tries < 200) {
      tries++;
      let name = '';
      if (s === 'title') name = pick(TITLES) + ' ' + pick(pool(t));
      else if (s === 'compound') name = pick(ENG_DARK) + pick(ENG_NOUN);
      else if (s === 'agent') name = 'The ' + pick(pool(t)) + ' of ' + pick(PLACES);
      else name = pick(SINGLE);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'vl-item'; el.textContent = n; el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
