---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Order Number Generator | Genfy';
const description = 'Generate professional purchase order numbers. Configurable format: prefix, date, sequential or random. For ecommerce and operations.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Difference between order number and invoice number?', acceptedAnswer: { '@type': 'Answer', text: 'A purchase order (PO) is the internal document that frames an operation; the invoice is the fiscal document issued for billing. They can have separate numbering.' } },
    { '@type': 'Question', name: 'What format should I use?', acceptedAnswer: { '@type': 'Answer', text: 'For ecommerce, ORD-YYYYMMDD-#### (prefix, date, sequence) is the most readable. For B2B, PO-YYYY-#### is the standard.' } },
    { '@type': 'Question', name: 'Do they need to be sequential?', acceptedAnswer: { '@type': 'Answer', text: 'No legal requirement for internal management, but sequential numbers help auditing and traceability.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Work" title="Order Number Generator"
    intro="Build purchase order number formats. Great for ecommerce, operations, corporate purchasing and traceability.">

    <div slot="tool" class="po">
      <div class="po-row">
        <div>
          <label for="po-prefix">Prefix</label>
          <input id="po-prefix" type="text" value="ORD" maxlength="6" />
        </div>
        <div>
          <label for="po-fmt">Date format</label>
          <select id="po-fmt">
            <option value="year">Year only (YYYY)</option>
            <option value="date" selected>Full date (YYYYMMDD)</option>
            <option value="month">Year + month (YYYYMM)</option>
            <option value="none">No date</option>
          </select>
        </div>
        <div>
          <label for="po-pad">Sequence digits</label>
          <input id="po-pad" type="number" value="4" min="3" max="8" />
        </div>
      </div>
      <div class="po-row">
        <div>
          <label for="po-mode">Mode</label>
          <select id="po-mode">
            <option value="seq">Sequential</option>
            <option value="random">Random</option>
          </select>
        </div>
        <div>
          <label for="po-start">Start</label>
          <input id="po-start" type="number" value="1" min="1" />
        </div>
        <div>
          <label for="po-amount">Amount</label>
          <input id="po-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="po-gen" class="btn btn-primary" type="button">Generate</button>
      <button id="po-copy" class="btn btn-ghost" type="button">Copy</button>
      <textarea id="po-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>Order vs. invoice: a distinction often missed</h2>
      <p>
        The purchase order (PO) is the internal ID your team uses to identify an operation:
        what the customer bought, what you'll deliver. The invoice is the fiscal document
        issued when billing. One PO can spawn several invoices (partial deliveries) or none
        (if cancelled). That's why independent numbering is best — and why serious CRMs split
        the two flows.
      </p>

      <h2>Recommended format by industry</h2>
      <ul>
        <li><strong>Ecommerce.</strong> ORD-YYYYMMDD-#### is most useful: tells you at a glance when the order was placed without DB lookups.</li>
        <li><strong>B2B / corporate.</strong> PO-YYYY-#### with a 5-6 digit sequence. More anonymous, better for long-running processes.</li>
        <li><strong>SaaS / subscriptions.</strong> SUB-{CustomerID}-#### ties the order to the customer right in the ID.</li>
        <li><strong>Logistics / dropshipping.</strong> Often add origin prefix: ORD-US-2026-####, ORD-UK-2026-####.</li>
      </ul>

      <h2>Why include date in the ID</h2>
      <p>
        Embedding the date offers two operational wins: chronological sorting without an extra
        column, and fast debugging when a customer calls about a purchase from "two months
        ago". If you handle 100+ orders per day, consider dropping the date and ordering by DB
        — the ID gets unwieldy.
      </p>

      <h2>Sequential vs. random</h2>
      <p>
        Sequential is preferable for internal management and audits. Random is used when you
        don't want to expose how many orders you have (e.g. on a new store: customer sees
        "ORD-2026-0003" and knows you're brand new). A common shortcut is to start the
        sequence high (10001 instead of 1) — keeps order, hides volume.
      </p>

      <h2>Traceability: what to store with the ID</h2>
      <ol>
        <li><strong>Creation timestamp.</strong> Even if the date is in the ID, store the exact time.</li>
        <li><strong>Status.</strong> Pending, paid, picking, shipped, delivered, returned, cancelled.</li>
        <li><strong>Customer and payment method.</strong> For reconciliation.</li>
        <li><strong>Status change logs.</strong> Who moved it and when. This saves you in disputes.</li>
      </ol>

      <h2>Common mistakes</h2>
      <ul>
        <li><strong>Reusing IDs.</strong> If an order is cancelled, do NOT reassign that ID — historical confusion guaranteed.</li>
        <li><strong>Changing format mid-year.</strong> Keep it stable; switch only at fiscal-year transitions.</li>
        <li><strong>Ultra-long IDs.</strong> Over 20 characters becomes painful on phone and chat.</li>
        <li><strong>Lookalike characters.</strong> Avoid O vs 0, I vs 1 in confusing positions.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>Order vs invoice?</summary><p>Order is internal; invoice is fiscal. Use separate numbering.</p></details>
      <details><summary>What format?</summary><p>Ecommerce: ORD-YYYYMMDD-####. B2B: PO-YYYY-####.</p></details>
      <details><summary>Sequential?</summary><p>Not legally required, but helps audits and traceability.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .po-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .po-row { grid-template-columns: 1fr; } }
</style>

<script>
  const prefixEl = document.getElementById('po-prefix') as HTMLInputElement;
  const fmtEl = document.getElementById('po-fmt') as HTMLSelectElement;
  const padEl = document.getElementById('po-pad') as HTMLInputElement;
  const modeEl = document.getElementById('po-mode') as HTMLSelectElement;
  const startEl = document.getElementById('po-start') as HTMLInputElement;
  const amountEl = document.getElementById('po-amount') as HTMLInputElement;
  const out = document.getElementById('po-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('po-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('po-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function dateFmt(): string {
    const d = new Date(); const y = d.getFullYear(); const m = pad(d.getMonth() + 1, 2); const day = pad(d.getDate(), 2);
    const f = fmtEl.value;
    if (f === 'year') return `${y}`;
    if (f === 'month') return `${y}${m}`;
    if (f === 'date') return `${y}${m}${day}`;
    return '';
  }
  function generate() {
    const prefix = (prefixEl.value || 'ORD').toUpperCase();
    const pad_ = Math.max(3, Math.min(8, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const start = Math.max(1, parseInt(startEl.value || '1', 10));
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const dateP = dateFmt();
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      let core = '';
      if (mode === 'seq') core = pad(start + i, pad_);
      else core = pad(rint(Math.pow(10, pad_)), pad_);
      const parts = [prefix, dateP, core].filter(Boolean);
      arr.push(parts.join('-'));
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
