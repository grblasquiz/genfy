---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free TV Show Name Generator | Genfy';
const description = 'Generate names for TV or streaming shows in seconds. Combine genre, atmosphere and format to get 20 pitch-ready titles.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I name a TV show?', acceptedAnswer: { '@type': 'Answer', text: 'A great show title is short, communicates the genre, survives multiple seasons, and is unique on Netflix, Prime and HBO Max.' } },
    { '@type': 'Question', name: 'Should the title describe the plot?', acceptedAnswer: { '@type': 'Answer', text: 'Better to suggest the emotional climate or central location than the immediate plot. Descriptive titles age fast.' } },
    { '@type': 'Question', name: 'How long should the title be?', acceptedAnswer: { '@type': 'Answer', text: 'One to three words is ideal so it reads well on thumbnails and social banners.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Entertainment" title="TV Show Name Generator"
    intro="Generate names for your next TV or streaming show. Combine genre, atmosphere and format to get 20 ideas ready for your pitch or pilot.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Theme or keyword</label>
      <input id="bn-kw" type="text" placeholder="city, family, secret..." value="border" />

      <label for="bn-style" style="margin-top:1rem">Tone</label>
      <select id="bn-style">
        <option value="prestige">Prestige drama (Under the Sun)</option>
        <option value="crime">Crime / thriller (The Dark Line)</option>
        <option value="comedy">Comedy (Best Friends)</option>
        <option value="scifi">Sci-fi (The Protocol)</option>
        <option value="single">Single word (Border)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 titles</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to name a TV show</h2>
      <p>
        A show title has to survive multiple seasons, posters and an avalanche of thumbnails. The
        difference with a film is duration: a title glued to the season-one plot looks weird by
        season three. The best TV titles point to a place, an emotion or a code (Severance,
        Succession, Better Call Saul) rather than an event.
      </p>
      <ol>
        <li><strong>Think five seasons ahead.</strong> If your title is "The Murder of Paul", it gets weird in season two.</li>
        <li><strong>Communicate the genre.</strong> Viewers scan thumbnails — thriller, comedy or drama should be clear.</li>
        <li><strong>One to three words.</strong> Long titles get cut in mobile grids.</li>
        <li><strong>Unique across streaming.</strong> Search Netflix, Prime, HBO Max and Apple TV. Collisions kill SEO.</li>
        <li><strong>Survives merch.</strong> Does it look good on a mug, a tee, a poster? If not, drop it.</li>
      </ol>

      <h2>Styles by genre</h2>
      <ul>
        <li><strong>Prestige drama</strong>: short, conceptual, atmospheric (Succession, Under the Sun, The Kingdom).</li>
        <li><strong>Crime / thriller</strong>: definite article + threatening noun (The Dark Line, The Protocol).</li>
        <li><strong>Comedy</strong>: keys to a group or relationship (Best Friends, Impossible Neighbors).</li>
        <li><strong>Sci-fi</strong>: dry codes or protocols (Severance, Subfloor 7, Reset).</li>
        <li><strong>Single word</strong>: premium format, high impact (Border, Summer, Bone).</li>
      </ul>

      <h2>Common mistakes</h2>
      <p>
        Most common: overly descriptive titles that lose currency after season one. Next: names
        with long articles ("The Incredible Story of...") that platforms truncate. A third:
        foreign-language titles without a clear reason that confuse the algorithm. And: avoid
        worn-out mythological references — if your strong title hangs on a Greek or Norse deity,
        think twice; it's already saturated.
      </p>

      <h2>After generating</h2>
      <ol>
        <li>Search IMDb, Netflix, Prime, HBO Max and JustWatch.</li>
        <li>Check domain availability for a campaign site.</li>
        <li>Mock a thumbnail: does it read at 100x140 px?</li>
        <li>Show it to three pilot readers: do they guess the tone?</li>
        <li>Five-season test: does it still work?</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>How do I name a TV show?</summary><p>Short, communicates genre, survives multiple seasons, unique on streaming.</p></details>
      <details><summary>Should it describe the plot?</summary><p>Better to suggest atmosphere than describe the immediate plot.</p></details>
      <details><summary>How long should it be?</summary><p>One to three words for thumbnail clarity.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const PRESTIGE = ['Under the Sun', 'The Kingdom', 'Succession', 'The Coast', 'The Long Summer', 'Solid Ground', 'The Estate'];
  const CRIME = ['The Dark Line', 'The Protocol', 'No Sound', 'North Border', 'The Lead', 'Clean Blood'];
  const COMEDY = ['Best Friends', 'Impossible Neighbors', 'Broken Family', 'New Job', 'Office Crew'];
  const SCIFI = ['The Experiment', 'Subfloor 7', 'Protocol Nine', 'Exit Zero', 'The Capsule', 'Reset'];
  const NOUN = ['Border', 'Summer', 'Bone', 'Fog', 'Claw', 'Echo', 'Tide', 'Coast'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const words = kw.value.split(',').map(s => s.trim()).filter(Boolean);
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let name = '';
      if (s === 'prestige') name = pick(PRESTIGE);
      else if (s === 'crime') name = pick(CRIME);
      else if (s === 'comedy') name = pick(COMEDY);
      else if (s === 'scifi') name = pick(SCIFI);
      else if (s === 'single') name = words.length ? cap(pick(words)) : pick(NOUN);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
