---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Color Palette Generator | Genfy';
const description = 'Generate harmonious color palettes in one click. Analogous, complementary, triadic and monochromatic schemes with HEX, RGB and HSL codes ready to copy.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is a harmonious palette?', acceptedAnswer: { '@type': 'Answer', text: 'A set of colors that share a mathematical relationship on the color wheel (same hue, opposite hues, 120° apart, etc.). That guarantees they combine instead of competing.' } },
    { '@type': 'Question', name: 'What is the 60-30-10 rule?', acceptedAnswer: { '@type': 'Answer', text: 'An interior-design rule adapted to UI: 60% dominant color (background), 30% secondary (structure), 10% accent (CTAs, alerts). It prevents flat or oversaturated interfaces.' } },
    { '@type': 'Question', name: 'How many colors should a palette have?', acceptedAnswer: { '@type': 'Answer', text: 'For branding, 3 to 5 main colors. For a full UI you also need a neutral scale of 8–10 grays and state colors (success, warning, danger).' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Design" title="Color palette generator"
    intro="Generate harmonious palettes in seconds. Pick a scheme (analogous, complementary, triadic or monochromatic), lock the colors you like and download the HEX codes ready to use.">

    <div slot="tool" class="palette-tool">
      <div class="palette-controls">
        <div>
          <label for="pal-base">Base color</label>
          <input id="pal-base" type="color" value="#059669" />
        </div>
        <div>
          <label for="pal-mode">Scheme</label>
          <select id="pal-mode">
            <option value="analogous">Analogous</option>
            <option value="complementary">Complementary</option>
            <option value="triadic">Triadic</option>
            <option value="tetradic">Tetradic</option>
            <option value="monochromatic">Monochromatic</option>
            <option value="random" selected>Random</option>
          </select>
        </div>
        <div class="palette-actions">
          <button id="pal-gen" class="btn btn-primary" type="button">Generate palette</button>
          <button id="pal-copy" class="btn btn-ghost" type="button">Copy all</button>
        </div>
      </div>
      <p class="palette-hint">Tap a card to lock that color (won't change on regenerate). Tap the HEX to copy it.</p>
      <div id="palette" class="palette"></div>
    </div>

    <div slot="content">
      <h2>How a working palette is built</h2>
      <p>
        A color palette isn't picked by taste — it's built on the color wheel. Each scheme
        is a geometric rule that guarantees visual harmony and reduces the risk of choosing
        combinations that create noise or visual fatigue.
      </p>
      <ul>
        <li><strong>Analogous:</strong> 3 colors next to each other on the wheel (e.g. blue, blue-green, green). Calm and cohesive. Great for backgrounds, illustrations and brands aiming for serenity.</li>
        <li><strong>Complementary:</strong> two opposite colors (e.g. blue and orange). Maximum contrast — perfect for CTAs that have to stand out.</li>
        <li><strong>Triadic:</strong> 3 colors 120° apart. Vibrant yet balanced, common in modern branding and kid-friendly design.</li>
        <li><strong>Tetradic:</strong> 4 colors in two complementary pairs. Hard to balance; pick one dominant and three accents.</li>
        <li><strong>Monochromatic:</strong> same hue with different saturation and lightness. Sober, elegant, almost foolproof.</li>
      </ul>

      <h2>The 60-30-10 rule</h2>
      <p>
        Inherited from interior design and adopted by modern UI: 60% dominant color
        (backgrounds and large areas), 30% secondary (cards, sidebars, navigation), 10%
        accent (primary buttons, links, indicators). If your accent occupies more than 15%
        of the screen it stops being an accent and becomes noise.
      </p>

      <h2>HEX vs RGB vs HSL: which to use</h2>
      <p>
        All three represent the same color but solve different problems.
        <strong>HEX</strong> (<code>#059669</code>) is the most compact and the standard
        for handing off colors between design and engineering. <strong>RGB</strong>
        (<code>rgb(5, 150, 105)</code>) supports alpha and works where HEX doesn't.
        <strong>HSL</strong> (<code>hsl(160, 94%, 30%)</code>) is the most useful for
        <em>generating variations</em>: tweaking lightness keeps the hue, which lets you
        build scales like Tailwind's or Material's from a single seed color.
      </p>

      <h2>Accessibility: contrast is not optional</h2>
      <p>
        Before locking a palette, check the contrast between text and background. WCAG 2.1
        requires at least 4.5:1 for normal text and 3:1 for large text (level AA). For AAA,
        7:1 and 4.5:1. A beautiful palette that fails contrast is unusable: it excludes
        low-vision users and anyone using your site in direct sunlight.
      </p>

      <h2>How to apply a palette to a real interface</h2>
      <ol>
        <li><strong>Define the primary.</strong> The color that most represents your brand. Don't start with the secondary.</li>
        <li><strong>Build a neutral scale of 8–10 grays.</strong> Not pure black mixed with white: they should have a subtle tint toward your primary.</li>
        <li><strong>Add state colors:</strong> success (green), warning (amber), danger (red), info (blue). Conventions exist for a reason — follow them.</li>
        <li><strong>Test the palette with text and borders</strong>, not only with flat color blocks. What looks gorgeous in swatches can clash in a paragraph.</li>
        <li><strong>Document names and usage.</strong> An undocumented palette ends with every team picking "the green that looks right."</li>
      </ol>

      <h2>Palettes that don't fail</h2>
      <p>
        When in doubt, look at references: Stripe, Linear, Vercel and Notion build palettes
        around one primary, a cool gray scale, and very few accents. Restraint ages better
        than trends. Before locking five vibrant colors, ask yourself how many you'll
        actually use in production.
      </p>
    </div>

    <div slot="faq">
      <details><summary>What is a harmonious palette?</summary><p>A group of colors that share a mathematical relationship on the color wheel (same hue, opposites, 120° apart, etc.).</p></details>
      <details><summary>What's the 60-30-10 rule?</summary><p>60% dominant, 30% secondary, 10% accent. Prevents flat or oversaturated interfaces.</p></details>
      <details><summary>How many colors should a palette have?</summary><p>For branding, 3 to 5. For a full UI you also need 8–10 grays and state colors.</p></details>
      <details><summary>Can I download the palette?</summary><p>Yes. Hit "Copy all" to grab the HEX codes, or tap each HEX individually.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .palette-controls { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: end; margin-bottom: 1rem; }
  .palette-actions { grid-column: 1 / -1; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .palette-hint { font-size: 0.8125rem; color: var(--text-subtle); margin: 0.5rem 0 1rem; }
  .palette { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.75rem; min-height: 220px; }
  .swatch { position: relative; border-radius: var(--radius); overflow: hidden; border: 1px solid var(--border); cursor: pointer; aspect-ratio: 1 / 1.4; transition: transform var(--t-base) var(--ease); }
  .swatch:hover { transform: translateY(-2px); }
  .swatch[data-locked="true"]::after { content: "🔒"; position: absolute; top: 0.5rem; right: 0.5rem; font-size: 0.875rem; }
  .swatch .hex { position: absolute; bottom: 0; left: 0; right: 0; padding: 0.5rem; font-family: var(--font-mono); font-size: 0.75rem; text-align: center; background: rgba(255,255,255,0.92); color: #09090b; font-weight: 600; letter-spacing: 0.02em; }
  #pal-base { padding: 0.25rem; height: 42px; cursor: pointer; }
  @media (max-width: 600px) { .palette { grid-template-columns: repeat(5, 1fr); gap: 0.4rem; } .palette-controls { grid-template-columns: 1fr; } }
</style>

<script>
  const baseEl = document.getElementById('pal-base') as HTMLInputElement;
  const modeEl = document.getElementById('pal-mode') as HTMLSelectElement;
  const genEl = document.getElementById('pal-gen') as HTMLButtonElement;
  const copyEl = document.getElementById('pal-copy') as HTMLButtonElement;
  const palEl = document.getElementById('palette') as HTMLDivElement;

  type HSL = { h: number; s: number; l: number };
  const locked: (string | null)[] = [null, null, null, null, null];

  function hexToHsl(hex: string): HSL {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    const max = Math.max(r, g, b), min = Math.min(r, g, b);
    let h = 0, s = 0; const l = (max + min) / 2;
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      if (max === r) h = ((g - b) / d + (g < b ? 6 : 0));
      else if (max === g) h = (b - r) / d + 2;
      else h = (r - g) / d + 4;
      h *= 60;
    }
    return { h, s: s * 100, l: l * 100 };
  }
  function hslToHex({ h, s, l }: HSL): string {
    s /= 100; l /= 100;
    const k = (n: number) => (n + h / 30) % 12;
    const a = s * Math.min(l, 1 - l);
    const f = (n: number) => l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
    const toHex = (x: number) => Math.round(x * 255).toString(16).padStart(2, '0');
    return '#' + toHex(f(0)) + toHex(f(8)) + toHex(f(4));
  }
  function build(base: string, mode: string): string[] {
    const hsl = hexToHsl(base);
    const out: string[] = [];
    if (mode === 'random') {
      for (let i = 0; i < 5; i++) {
        out.push(hslToHex({ h: Math.random() * 360, s: 55 + Math.random() * 35, l: 35 + Math.random() * 40 }));
      }
    } else if (mode === 'analogous') {
      for (let i = -2; i <= 2; i++) out.push(hslToHex({ h: (hsl.h + i * 22 + 360) % 360, s: hsl.s, l: hsl.l }));
    } else if (mode === 'complementary') {
      out.push(hslToHex(hsl));
      out.push(hslToHex({ ...hsl, l: Math.min(85, hsl.l + 18) }));
      out.push(hslToHex({ ...hsl, l: Math.max(15, hsl.l - 22) }));
      out.push(hslToHex({ h: (hsl.h + 180) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ h: (hsl.h + 180) % 360, s: hsl.s, l: Math.min(85, hsl.l + 18) }));
    } else if (mode === 'triadic') {
      out.push(hslToHex(hsl));
      out.push(hslToHex({ h: (hsl.h + 120) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ h: (hsl.h + 240) % 360, s: hsl.s, l: hsl.l }));
      out.push(hslToHex({ ...hsl, l: Math.min(90, hsl.l + 25) }));
      out.push(hslToHex({ ...hsl, l: Math.max(10, hsl.l - 25) }));
    } else if (mode === 'tetradic') {
      [0, 90, 180, 270].forEach(d => out.push(hslToHex({ h: (hsl.h + d) % 360, s: hsl.s, l: hsl.l })));
      out.push(hslToHex({ ...hsl, l: Math.min(90, hsl.l + 22) }));
    } else {
      [25, 40, 55, 70, 85].forEach(l => out.push(hslToHex({ ...hsl, l })));
    }
    return out;
  }
  function render(colors: string[]) {
    palEl.innerHTML = '';
    colors.forEach((c, i) => {
      const sw = document.createElement('div');
      sw.className = 'swatch';
      sw.style.background = c;
      sw.dataset.locked = locked[i] ? 'true' : 'false';
      const hex = document.createElement('div');
      hex.className = 'hex';
      hex.textContent = c.toUpperCase();
      sw.appendChild(hex);
      sw.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).classList.contains('hex')) {
          navigator.clipboard.writeText(c.toUpperCase());
          hex.textContent = 'copied!';
          setTimeout(() => { hex.textContent = c.toUpperCase(); }, 900);
        } else {
          locked[i] = locked[i] ? null : c;
          sw.dataset.locked = locked[i] ? 'true' : 'false';
        }
      });
      palEl.appendChild(sw);
    });
  }
  let current: string[] = [];
  function regen() {
    const built = build(baseEl.value, modeEl.value);
    current = built.map((c, i) => locked[i] ?? c);
    render(current);
  }
  genEl.addEventListener('click', regen);
  copyEl.addEventListener('click', () => {
    navigator.clipboard.writeText(current.map(c => c.toUpperCase()).join('\n'));
    copyEl.textContent = 'Copied!';
    setTimeout(() => { copyEl.textContent = 'Copy all'; }, 1200);
  });
  regen();
</script>
