---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Sales Email Subject Line Generator | Genfy';
const description = 'Generate 12 sales email subject lines optimized for opens. Curiosity, benefit, urgency and personalization. For SDRs, founders and sales teams.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How long should a subject line be?', acceptedAnswer: { '@type': 'Answer', text: 'Between 30 and 50 characters. On mobile they cut around 35-40, so the important part needs to be at the start.' } },
    { '@type': 'Question', name: 'Should I use caps or emojis?', acceptedAnswer: { '@type': 'Answer', text: 'ALL CAPS lower opens and raise spam reports. A single emoji at the start can help in B2C, but typically hurts B2B.' } },
    { '@type': 'Question', name: 'What is the best length?', acceptedAnswer: { '@type': 'Answer', text: 'Clarity beats word count. Short 3-5 word subjects often open better than long explanatory ones.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Business" title="Sales Email Subject Line Generator"
    intro="Generate 12 subject lines optimized for opens. We mix curiosity, benefit, urgency and personalization so you can A/B test and pick a winner.">

    <div slot="tool" class="se">
      <label>Prospect's company</label>
      <input id="se-comp" type="text" value="Acme Corp" />

      <label style="margin-top:1rem">Topic / offer</label>
      <input id="se-topic" type="text" value="reduce LinkedIn Ads CAC" />

      <label style="margin-top:1rem">Outcome / striking number</label>
      <input id="se-data" type="text" value="-30% in 60 days" />

      <button id="se-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 12 subjects</button>

      <div id="se-out" class="se-out"></div>
    </div>

    <div slot="content">
      <h2>What makes a subject open</h2>
      <p>
        The subject is the gate to your email. You have 30-50 characters and a fraction of a
        second for the recipient to decide open or archive. The highest-performing subjects aren't
        the cleverest — they're the clearest. If the reader has to think, they don't open.
      </p>

      <h2>The 4 levers that drive opens</h2>
      <ol>
        <li><strong>Curiosity:</strong> leave an open question or unexpected statement. "A question about your CAC".</li>
        <li><strong>Concrete benefit:</strong> the outcome the recipient wants. "30% less CAC in 60 days".</li>
        <li><strong>Urgency or time:</strong> a date or window. "Before the 31st — only if it fits".</li>
        <li><strong>Personalization:</strong> name of the recipient or their company. "Acme + a 2-minute idea".</li>
      </ol>

      <h2>What no longer works</h2>
      <ul>
        <li><strong>Fake "Re:" or "Fwd:".</strong> Lower replies once recipients catch on — and they do.</li>
        <li><strong>"Last chance for X".</strong> If you said it three emails in a row, it wasn't the last.</li>
        <li><strong>"Important: read this now".</strong> Sounds like phishing.</li>
        <li><strong>ALL CAPS.</strong> Spam rate goes up.</li>
        <li><strong>"How X changed my life".</strong> Buzzfeed-style died a decade ago in B2B.</li>
      </ul>

      <h2>How to A/B test subjects</h2>
      <p>If you send more than 100 emails per campaign, A/B testing is mandatory.</p>
      <ol>
        <li>Generate 5-10 subjects with different angles.</li>
        <li>Split your list evenly and send each subject to one group.</li>
        <li>Wait at least 48 hours for opens to stabilize.</li>
        <li>Pick the winner by open + reply, not opens alone. High open + low reply means the subject is overpromising.</li>
        <li>Iterate the winner with light variations to find the ceiling.</li>
      </ol>

      <h2>Operational best practices</h2>
      <ul>
        <li>Most important in the first 35 characters (mobile).</li>
        <li>Avoid exclamation marks (max one).</li>
        <li>Don't use spam triggers: "free", "guaranteed", "100%", "$$$".</li>
        <li>Lowercase-only often works in modern cold outbound.</li>
        <li>Subject ↔ body coherence. If the subject promises X, the first paragraph delivers X.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>How long?</summary><p>30 to 50 characters, the key part in the first 35.</p></details>
      <details><summary>Caps or emojis?</summary><p>ALL CAPS no. Emojis only in B2C, sparingly.</p></details>
      <details><summary>Best length?</summary><p>Short 3-5 word subjects often beat long explanatory ones.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .se-out { display: grid; gap: 0.5rem; margin-top: 1.25rem; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
  .se-item { padding: 0.75rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color 0.1s; font-size: 0.9375rem; }
  .se-item:hover { border-color: var(--primary); }
  .se-tag { font-size: 0.7rem; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; display: block; }
</style>

<script>
  const comp = document.getElementById('se-comp') as HTMLInputElement;
  const topic = document.getElementById('se-topic') as HTMLInputElement;
  const data = document.getElementById('se-data') as HTMLInputElement;
  const out = document.getElementById('se-out')!;
  const gen = document.getElementById('se-gen') as HTMLButtonElement;

  function generate() {
    const lines = [
      { tag: 'Curiosity', text: `idea for ${comp.value}` },
      { tag: 'Curiosity', text: `${comp.value} — a quick question` },
      { tag: 'Benefit', text: `${data.value} on ${topic.value}` },
      { tag: 'Benefit', text: `${topic.value}, no extra hires` },
      { tag: 'Personalization', text: `${comp.value} + 2 minutes` },
      { tag: 'Personalization', text: `thinking about ${comp.value}` },
      { tag: 'Short curiosity', text: `worth 30 seconds?` },
      { tag: 'Soft urgency', text: `before quarter close` },
      { tag: 'Provocative', text: `${topic.value} without touching budget?` },
      { tag: 'Honest', text: `cold email, but useful` },
      { tag: 'Specific', text: `${topic.value} for companies like ${comp.value}` },
      { tag: 'Numeric', text: `3 ideas for ${topic.value}` },
    ];

    out.innerHTML = '';
    lines.forEach(l => {
      const el = document.createElement('div');
      el.className = 'se-item';
      el.innerHTML = `<span class="se-tag">${l.tag}</span><div>${l.text}</div>`;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(l.text); el.style.borderColor = 'var(--primary)'; setTimeout(() => el.style.borderColor = '', 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
