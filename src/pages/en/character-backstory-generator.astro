---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Character Backstory Generator | Genfy';
const description = 'Generate backstories for fiction characters. Mix childhood, wound and secret to get 10 ready-to-use backgrounds instantly.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is a character backstory?', acceptedAnswer: { '@type': 'Answer', text: "It's the prior history that explains why the character behaves the way they do. Includes the founding wound, inherited habits and lingering secrets." } },
    { '@type': 'Question', name: 'How much backstory should I write?', acceptedAnswer: { '@type': 'Answer', text: 'Far more than will appear in the story. The reader only sees about 20%, but the author needs the whole thing for choices to read coherently.' } },
    { '@type': 'Question', name: 'How do I introduce backstory?', acceptedAnswer: { '@type': 'Answer', text: 'Drip-feed. One clue per scene, attached to an object, a gesture or a word the character avoids.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Entertainment" title="Character Backstory Generator"
    intro="Generate your character's prior history. Combine childhood, founding wound and secret to get 10 ready-to-use backstories for your novel or screenplay.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Character role</label>
      <input id="bn-kw" type="text" placeholder="protagonist, antagonist..." value="protagonist" />

      <label for="bn-style" style="margin-top:1rem">Tone</label>
      <select id="bn-style">
        <option value="realist">Contemporary realist</option>
        <option value="dark">Dark / noir</option>
        <option value="bittersweet">Bittersweet / drama</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 10 backstories</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to write a backstory that holds the character up</h2>
      <p>
        Backstory is what the character lived before the story starts. It's not info to dump on
        the reader — it's info for you, the author. Every choice the character makes onstage
        should be traceable to something in the backstory. If your protagonist avoids hospitals,
        there should be a concrete reason in their past, even if you never spell it out.
      </p>
      <ol>
        <li><strong>A founding wound.</strong> A key event between ages 6 and 16 that explains the adult emotional pattern.</li>
        <li><strong>An active secret.</strong> Something the character still hides today. The more mundane, the more interesting.</li>
        <li><strong>A regretted decision.</strong> A past fork in the road where they chose poorly and carry the cost.</li>
        <li><strong>An inherited habit.</strong> Something they do without thinking because they learned it from a parent or sibling.</li>
        <li><strong>A previous job.</strong> What they did before the story shapes how they solve problems.</li>
      </ol>

      <h2>Backstory template</h2>
      <ul>
        <li><strong>Family of origin</strong>: parents, siblings, geography.</li>
        <li><strong>Founding wound</strong>: the event that explains the central fear.</li>
        <li><strong>Education</strong>: schooling or lack of it.</li>
        <li><strong>Previous jobs</strong>: two or three before the story begins.</li>
        <li><strong>Important relationships</strong>: partners, friendships, emotional debts.</li>
        <li><strong>Active secret</strong>: what's still hidden.</li>
        <li><strong>Inherited habit</strong>: gesture, word or ritual learned at home.</li>
      </ul>

      <h2>Common mistakes</h2>
      <p>
        Most common: backstories so dramatic that tragedies pile up to "explain" the character.
        When everything is trauma, nothing is trauma. Another: dumping backstory in chapter one
        through internal monologue. Always drip-feed: one clue per scene, attached to an object,
        a gesture, or an avoided phrase. And a third: backstories that contradict the character's
        age (a 25-year-old with five five-year prior careers).
      </p>

      <h2>After generating</h2>
      <ol>
        <li>Mark the founding wound and verify it connects to the central want.</li>
        <li>List three physical clues (objects, places, scars) that hint at the past.</li>
        <li>Choose what gets revealed and what stays hidden.</li>
        <li>Check coherence with current age and profession.</li>
        <li>Test a scene where the backstory influences action without being explained.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>What is backstory?</summary><p>Prior history that explains why the character behaves as they do.</p></details>
      <details><summary>How much should I write?</summary><p>Far more than appears in the story. Only 20% gets shown.</p></details>
      <details><summary>How to introduce it?</summary><p>Drip-feed via objects, gestures, avoided phrases.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: 1fr; gap: 0.75rem; margin-top: 1.25rem; }
  .bn-item { padding: 1rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color 0.1s; line-height: 1.55; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const REALIST_W = ['lost her father at nine and learned to bury the questions', 'grew up translating for her mother who never spoke the local language', 'was the kid nobody picked for gym teams', 'was raised by a grandfather who slept with his door locked'];
  const REALIST_S = ['never told her partner she dropped out two classes short of graduating', 'hides a debt her siblings believe was settled', 'still bills a client who no longer requires deliverables'];
  const REALIST_J = ['worked three years as a cashier at a supermarket that closed', 'was a freelance translator until a client asked him to sign a text he had not written', 'ran the small-town radio station on an impossible schedule'];
  const DARK_W = ['witnessed a robbery at twelve that the family decided not to report', 'grew up hiding a sibling from a violent father', 'learned to read the lights in her house before walking in', 'spent two months at a boarding school nobody talks about'];
  const DARK_S = ['signed a paper she still remembers and believes is lost', 'has been paying for a silence for three years without knowing whom', 'has changed cities before because of a disappearance'];
  const DARK_J = ['was an officer in a small town before retiring without explanation', 'managed the boarding house until the 2014 fire', 'worked four years for a private security firm'];
  const BITTER_W = ['lost a sister in an accident she could have prevented', 'was raised by an uncle who loved her but never said so', 'cared for her sick mother through her entire adolescence'];
  const BITTER_S = ['never opened the last letter she received from her father', 'keeps a key to a house that no longer exists', 'has been paying rent on an empty apartment for two years'];
  const BITTER_J = ['was a rural schoolteacher until they closed the school', 'worked her whole life at the family print shop before it shuttered', 'was a pediatric nurse until burnout'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const role = kw.value.trim() || 'protagonist';
    const s = style.value;
    let W: string[], S: string[], J: string[];
    if (s === 'dark') { W = DARK_W; S = DARK_S; J = DARK_J; }
    else if (s === 'bittersweet') { W = BITTER_W; S = BITTER_S; J = BITTER_J; }
    else { W = REALIST_W; S = REALIST_S; J = REALIST_J; }
    out.innerHTML = '';
    const seen = new Set<string>();
    let attempts = 0;
    while (seen.size < 10 && attempts < 60) {
      attempts++;
      const text = `This ${role} ${pick(W)}. Before the story ${pick(J)}. Today ${pick(S)}.`;
      if (seen.has(text)) continue;
      seen.add(text);
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = text;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(text); const orig = el.textContent; el.textContent = '✓ copied'; setTimeout(() => el.textContent = orig, 800); });
      out.appendChild(el);
    }
  }
  gen.addEventListener('click', generate);
  generate();
</script>
