---
import Layout from '../../layouts/Layout.astro';
const title = 'Contact — Genfy';
const description = 'Reach out for suggestions, bug reports, partnership inquiries or new generator requests.';
---
<Layout title={title} description={description} lang="en">
  <article>
    <h1>Contact</h1>
    <p>
      Found a bug, want to suggest a new generator, or have a partnership idea? Drop us
      a line. We read every email and reply to the ones that need a reply.
    </p>
    <p>
      <strong>Email:</strong> <a href="mailto:hello@genfy.net">hello@genfy.net</a>
    </p>
    <h2>What helps us help you faster</h2>
    <ul>
      <li><strong>Bug report:</strong> what you were doing, what you expected, what actually happened. Browser, OS and device if you can — most issues are mobile-only or browser-specific.</li>
      <li><strong>Generator request:</strong> tell us the actual job-to-be-done — what you're trying to accomplish in real life. We don't build what we don't understand.</li>
      <li><strong>Partnership / advertising:</strong> what your brand does, what you're proposing, and why it's a fit for our audience.</li>
    </ul>
    <p class="muted">
      Heads up: we don't reply to automated SEO outreach, mass link-building or link-exchange
      requests. Those go straight to the trash.
    </p>
  </article>
</Layout>
