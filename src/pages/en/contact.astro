---
import Layout from '../../layouts/Layout.astro';
const title = 'Contact — Genfy';
const description = 'Reach out for suggestions, bug reports or proposals for new generators.';
---
<Layout title={title} description={description} lang="en">
  <article>
    <h1>Contact</h1>
    <p>
      Found a bug, want to suggest a new generator or have a general question? Write to us.
      We read every message and reply to those that need a reply.
    </p>
    <p>
      <strong>Email:</strong> <a href="mailto:hello@genfy.net">hello@genfy.net</a>
    </p>
    <h2>What to include in your message</h2>
    <ul>
      <li>Bug report: what you were doing, what you expected and what happened. Browser and device if possible.</li>
      <li>New generator request: what you'd use it for, so we understand the real use case.</li>
      <li>Advertising/partnership: details of your proposal and brand.</li>
    </ul>
    <p class="muted">
      We don't reply to automated SEO outreach, mass link-building or link exchange requests.
    </p>
  </article>
</Layout>
