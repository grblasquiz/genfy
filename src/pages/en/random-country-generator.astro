  ];

  const cont = document.getElementById('cn-cont') as HTMLSelectElement;
  const count = document.getElementById('cn-count') as HTMLInputElement;
  const result = document.getElementById('cn-result')!;
  const gen = document.getElementById('cn-gen') as HTMLButtonElement;
  const copy = document.getElementById('cn-copy') as HTMLButtonElement;

  function rand(max: number) {
    const arr = new Uint32Array(1);
    window.crypto.getRandomValues(arr);
    return arr[0] % max;
  }
  function pick() {
    const pool = cont.value === 'all' ? COUNTRIES : COUNTRIES.filter(c => c.cont === cont.value);
    const n = Math.max(1, Math.min(20, parseInt(count.value) || 1));
    const picks: Country[] = [];
    const used = new Set<number>();
    for (let i = 0; i < n && i < pool.length; i++) {
      let idx;
      do { idx = rand(pool.length); } while (used.has(idx) && used.size < pool.length);
      used.add(idx);
      picks.push(pool[idx]);
    }
    result.innerHTML = picks.map(c => `<div class="cn-card"><span class="cn-flag">${c.flag}</span><div class="cn-info"><div class="name">${c.name}</div><div class="meta">Capital: ${c.capital} · ${c.cont}</div></div></div>`).join('');
  }
  gen.addEventListener('click', pick);
  copy.addEventListener('click', () => {
    const names = Array.from(result.querySelectorAll('.name')).map(el => el.textContent).join(', ');
    navigator.clipboard.writeText(names);
    copy.textContent = 'Copied!';
    setTimeout(() => { copy.textContent = 'Copy names'; }, 1200);
  });
  pick();
</script>
