---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Postman Collection Example | Genfy';
const description = 'Generate a Postman v2.1 collection JSON ready to import. Great for kicking off API testing or documenting endpoints.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I import the collection?', acceptedAnswer: { '@type': 'Answer', text: 'In Postman: File > Import > Raw text, paste the JSON, and the collection is created with all the requests.' } },
    { '@type': 'Question', name: 'What is v2.1?', acceptedAnswer: { '@type': 'Answer', text: 'The current Postman collection format. Supports environment variables, scripts, auth and request examples.' } },
    { '@type': 'Question', name: 'Works with Insomnia or Bruno?', acceptedAnswer: { '@type': 'Answer', text: 'Insomnia and Bruno can import Postman v2.1, though some scripts may need adjustments.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell
    lang="en"
    tag="Tech / Dev"
    title="Postman Collection Example"
    intro="Generate a Postman v2.1 collection with full CRUD (GET list, GET one, POST, PUT, DELETE) ready to import."
  >
    <div slot="tool" class="pm-tool">
      <div class="pm-grid">
        <div>
          <label for="pm-name">Collection name</label>
          <input id="pm-name" type="text" value="My API" />
        </div>
        <div>
          <label for="pm-base">Base URL (variable)</label>
          <input id="pm-base" type="text" value="https://api.example.com/v1" />
        </div>
        <div>
          <label for="pm-resource">Resource</label>
          <input id="pm-resource" type="text" value="users" />
        </div>
      </div>
      <div class="pm-actions">
        <button id="pm-gen" class="btn btn-primary" type="button">Generate</button>
        <button id="pm-copy" class="btn btn-ghost" type="button"><span class="copy-icon">Copy</span></button>
      </div>
      <textarea id="pm-out" class="mono" rows="14" readonly></textarea>
    </div>

    <div slot="content">
      <h2>What is a Postman collection?</h2>
      <p>
        A Postman collection is a group of organized requests you can run individually, in
        sequence, or from CI with Newman. It's the most widely used format for sharing APIs
        internally and for QA teams to build regression suites without touching code.
      </p>

      <h2>Variables and environments</h2>
      <p>
        Use variables like <code>&lcub;&lcub;baseUrl&rcub;&rcub;</code> and <code>&lcub;&lcub;token&rcub;&rcub;</code> instead
        of hardcoding. Then define a "dev" environment with <code>baseUrl=https://api-dev...</code>
        and a "prod" with the real URL. Switching is a click. Variables you don't want to commit
        (passwords) go as empty "Initial Value" and local "Current Value".
      </p>

      <h2>JSON structure</h2>
      <p>
        v2.1 has <code>info</code>, <code>item</code> (requests or folders), <code>variable</code>
        and <code>auth</code>. Each request defines method, URL, headers and body. Folders group
        by feature: <code>/users</code>, <code>/orders</code>, <code>/auth</code>.
      </p>

      <h2>Automated tests</h2>
      <p>
        In the Tests tab you can write JS:
        <code>pm.test("status 200", function() &lcub; pm.response.to.have.status(200); &rcub;);</code>.
        Postman runs the script after every request. Combined with Newman, it gives you an
        executable integration suite from GitHub Actions.
      </p>

      <h2>Auth: bearer, basic, OAuth2</h2>
      <p>
        Configure auth at the collection or request level. For JWT, use Bearer Token with the
        <code>&lcub;&lcub;token&rcub;&rcub;</code> variable. For OAuth2, Postman has a wizard that fetches the
        token and stores it in a variable. For Basic, Postman base64-encodes automatically.
      </p>

      <h2>Pre-request scripts</h2>
      <p>
        Useful for refreshing tokens, generating dynamic payloads or setting timestamps. For
        example, on a POST, generate a body with a fresh UUID each time:
        <code>pm.environment.set("orderId", crypto.randomUUID());</code>.
      </p>

      <h2>Newman: the collection in CI</h2>
      <p>
        Newman is Postman's CLI runner. <code>newman run my-collection.json -e dev.json</code>
        runs the full collection and reports results. In GitHub Actions or GitLab CI, this gives
        you smoke tests against staging on every deploy.
      </p>

      <h2>Documentation from the collection</h2>
      <p>
        Postman auto-generates public documentation from the collection. Describe each request in
        the Description field and add response examples. External teams hit a URL with every
        endpoint and can try them inline.
      </p>
    </div>

    <div slot="faq">
      <details><summary>How do I import the collection?</summary><p>File > Import > Raw text, paste the JSON, and it's created automatically.</p></details>
      <details><summary>What is v2.1?</summary><p>The current Postman format, supporting variables, scripts and auth.</p></details>
      <details><summary>Insomnia or Bruno?</summary><p>Both import v2.1 with minor script adjustments.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .pm-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .pm-grid { grid-template-columns: 1fr; } }
  .pm-actions { display: flex; gap: 0.5rem; margin-bottom: 1rem; }
  textarea { font-family: var(--font-mono); font-size: 0.8125rem; background: var(--bg-inset); resize: vertical; width: 100%; }
</style>

<script>
  const name = document.getElementById('pm-name') as HTMLInputElement;
  const base = document.getElementById('pm-base') as HTMLInputElement;
  const resource = document.getElementById('pm-resource') as HTMLInputElement;
  const out = document.getElementById('pm-out') as HTMLTextAreaElement;
  const gen = document.getElementById('pm-gen') as HTMLButtonElement;
  const copy = document.getElementById('pm-copy') as HTMLButtonElement;

  function build() {
    const r = resource.value || 'items';
    const collection = {
      info: { name: name.value, schema: 'https://schema.getpostman.com/json/collection/v2.1.0/collection.json', _postman_id: crypto.randomUUID ? crypto.randomUUID() : 'random-id' },
      variable: [{ key: 'baseUrl', value: base.value }, { key: 'token', value: '' }],
      auth: { type: 'bearer', bearer: [{ key: 'token', value: '{{token}}', type: 'string' }] },
      item: [
        { name: `List ${r}`, request: { method: 'GET', header: [], url: { raw: '{{baseUrl}}/' + r + '?page=1&limit=20', host: ['{{baseUrl}}'], path: [r], query: [{ key: 'page', value: '1' }, { key: 'limit', value: '20' }] } } },
        { name: `Get ${r} by id`, request: { method: 'GET', header: [], url: { raw: '{{baseUrl}}/' + r + '/:id', host: ['{{baseUrl}}'], path: [r, ':id'], variable: [{ key: 'id', value: '1' }] } } },
        { name: `Create ${r}`, request: { method: 'POST', header: [{ key: 'Content-Type', value: 'application/json' }], body: { mode: 'raw', raw: JSON.stringify({ name: 'Example', email: 'example@example.com' }, null, 2) }, url: { raw: '{{baseUrl}}/' + r, host: ['{{baseUrl}}'], path: [r] } } },
        { name: `Update ${r}`, request: { method: 'PUT', header: [{ key: 'Content-Type', value: 'application/json' }], body: { mode: 'raw', raw: JSON.stringify({ name: 'Updated' }, null, 2) }, url: { raw: '{{baseUrl}}/' + r + '/:id', host: ['{{baseUrl}}'], path: [r, ':id'], variable: [{ key: 'id', value: '1' }] } } },
        { name: `Delete ${r}`, request: { method: 'DELETE', header: [], url: { raw: '{{baseUrl}}/' + r + '/:id', host: ['{{baseUrl}}'], path: [r, ':id'], variable: [{ key: 'id', value: '1' }] } } },
      ],
    };
    out.value = JSON.stringify(collection, null, 2);
  }
  gen.addEventListener('click', build);
  [name, base, resource].forEach(el => el.addEventListener('input', build));
  copy.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const icon = copy.querySelector('.copy-icon') as HTMLElement;
    icon.textContent = '✓ Copied';
    setTimeout(() => { icon.textContent = 'Copy'; }, 1400);
  });
  build();
</script>
</content>
</invoke>