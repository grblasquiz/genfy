---
import Layout from '../../layouts/Layout.astro';
import { GENERATORS, urlFor, CATEGORIES_EN, type GeneratorMeta } from '../../lib/generators';
import { SITE_URL } from '../../lib/i18n';

const title = `All online generators (${GENERATORS.length}) | Genfy`;
const description = `Full catalog of ${GENERATORS.length} free online generators: passwords, names, hashtags, QR codes, color palettes, test data and more. No signup.`;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Online generators',
  numberOfItems: GENERATORS.length,
  itemListElement: GENERATORS.slice(0, 50).map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: g.title.en,
    url: `${SITE_URL}${urlFor(g, 'en')}`,
  })),
};

const byCategory = GENERATORS.reduce((acc, g) => {
  (acc[g.category] = acc[g.category] || []).push(g);
  return acc;
}, {} as Record<GeneratorMeta['category'], GeneratorMeta[]>);

const ORDER: GeneratorMeta['category'][] = [
  'security', 'tech', 'data', 'business', 'marketing',
  'design', 'random', 'pets', 'people', 'work', 'content', 'inspiration', 'fun', 'tools',
];
---
<Layout title={title} description={description} lang="en" schema={itemListSchema}>
  <header class="hero">
    <h1>All generators</h1>
    <p class="lead">
      {GENERATORS.length} free tools, no signup, all run in your browser.
      Organized by category so you find what you need fast.
    </p>
  </header>

  {ORDER.filter(c => byCategory[c]?.length).map(cat => (
    <section class="cat-section">
      <h2>{CATEGORIES_EN[cat]} <span class="cat-count">({byCategory[cat].length})</span></h2>
      <div class="grid-cards">
        {byCategory[cat].map(g => (
          <a class="gcard" href={urlFor(g, 'en')}>
            <span class="gcard-emoji">{g.emoji}</span>
            <span class="gcard-title">{g.title.en}</span>
            <span class="gcard-desc">{g.description.en}</span>
            <span class="gcard-arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>
  ))}
</Layout>

<style>
  .hero { padding: 3rem 0 2rem; }
  .hero .lead { font-size: 1.0625rem; color: var(--text-soft); max-width: 60ch; margin-top: 1rem; }
  .cat-section { margin-top: 3rem; }
  .cat-section h2 { font-size: 1.375rem; font-weight: 600; margin: 0 0 1.25rem; border-bottom: 1px solid var(--border-soft); padding-bottom: 0.75rem; }
  .cat-count { color: var(--text-muted); font-weight: 400; font-size: 0.9rem; }
  .gcard { position: relative; display: flex; flex-direction: column; gap: 0.5rem; padding: 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; color: var(--text); transition: border-color var(--t-base) var(--ease), transform var(--t-base) var(--ease), box-shadow var(--t-base) var(--ease); }
  .gcard:hover { border-color: var(--text); transform: translateY(-2px); box-shadow: var(--shadow-md); text-decoration: none; }
  .gcard-emoji { font-size: 1.375rem; line-height: 1; }
  .gcard-title { font-weight: 600; font-size: 0.9375rem; letter-spacing: -0.01em; color: var(--text); }
  .gcard-desc { color: var(--text-soft); font-size: 0.8125rem; line-height: 1.5; }
  .gcard-arrow { position: absolute; top: 1.25rem; right: 1.25rem; color: var(--text-muted); font-size: 0.9rem; transition: transform var(--t-base) var(--ease), color var(--t-base) var(--ease); }
  .gcard:hover .gcard-arrow { color: var(--accent); transform: translateX(3px); }
</style>
