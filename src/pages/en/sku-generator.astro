---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free SKU Generator | Genfy';
const description = 'Generate unique SKU codes for your inventory. Structure: category + brand + attribute + sequence. Great for ecommerce, retail and warehouses.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is a SKU?', acceptedAnswer: { '@type': 'Answer', text: 'Stock Keeping Unit: the unique internal code that identifies a product variant. Not to be confused with barcodes (UPC/EAN), which are for POS scanning.' } },
    { '@type': 'Question', name: 'How is a good SKU structured?', acceptedAnswer: { '@type': 'Answer', text: 'Category + brand/line + attributes (size/color) + sequence. Example: TS-NIK-RD-M-0001 (Tshirt - Nike - Red - Medium - 0001).' } },
    { '@type': 'Question', name: 'How many characters?', acceptedAnswer: { '@type': 'Answer', text: '8-15 characters is the recommended range. Less than 8 limits info; more than 15 becomes hard to handle manually.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Work" title="SKU Generator"
    intro="Build unique, readable SKUs for your inventory. Category, brand, attribute and sequence. Great for ecommerce, retail and warehouses.">

    <div slot="tool" class="sk">
      <div class="sk-row">
        <div>
          <label for="sk-cat">Category (3 letters)</label>
          <input id="sk-cat" type="text" value="TS" maxlength="4" />
        </div>
        <div>
          <label for="sk-brand">Brand/line (3 letters)</label>
          <input id="sk-brand" type="text" value="NIK" maxlength="4" />
        </div>
        <div>
          <label for="sk-attr">Attribute (color/size)</label>
          <input id="sk-attr" type="text" value="RD-M" maxlength="6" placeholder="e.g. RD-M" />
        </div>
      </div>
      <div class="sk-row">
        <div>
          <label for="sk-pad">Sequence digits</label>
          <input id="sk-pad" type="number" value="4" min="3" max="6" />
        </div>
        <div>
          <label for="sk-mode">Mode</label>
          <select id="sk-mode">
            <option value="seq">Sequential</option>
            <option value="random">Random</option>
          </select>
        </div>
        <div>
          <label for="sk-amount">Amount</label>
          <input id="sk-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="sk-gen" class="btn btn-primary" type="button">Generate</button>
      <button id="sk-copy" class="btn btn-ghost" type="button">Copy</button>
      <textarea id="sk-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>SKU vs. barcode: not the same</h2>
      <p>
        The <strong>SKU</strong> (Stock Keeping Unit) is your internal code: you define it,
        you change it when needed, you use it for inventory management. The
        <strong>barcode</strong> (UPC/EAN/GTIN) is a global, registered identifier purchased
        from organizations like GS1 and used for POS scanning anywhere. A black Nike T-shirt
        size M has one EAN worldwide, but can have a different SKU at every retailer.
      </p>

      <h2>Recommended structure</h2>
      <p>
        The standard pattern for readable SKUs is <code>CATEGORY-BRAND-ATTRIBUTE-SEQUENCE</code>.
        Example: <code>TS-NIK-RD-M-0001</code> = "T-shirt, Nike, red, medium, first unit".
        Benefit: just by reading the SKU, anyone with system knowledge knows the product.
        Invaluable when your team grows past having full mental context.
      </p>

      <h2>Rules for sustainable SKUs</h2>
      <ol>
        <li><strong>Short but descriptive.</strong> 8-15 characters is recommended.</li>
        <li><strong>Uppercase and dashes only.</strong> No spaces, slashes, quotes.</li>
        <li><strong>No look-alike characters.</strong> Skip O vs 0, I vs 1 — they cause spreadsheet errors.</li>
        <li><strong>Stable.</strong> Once assigned, don't change it — all your historical reports use it.</li>
        <li><strong>Unique.</strong> Each variant (color, size) gets its own SKU. Never share across variants.</li>
        <li><strong>No price embedded.</strong> Price changes; the SKU shouldn't drift. Keep them separate.</li>
      </ol>

      <h2>Categorization</h2>
      <p>
        Before generating SKUs, define your taxonomy: how do you group products? By family, by
        supplier, by sales channel? A bad taxonomy shows up at month 6 when SKUs no longer
        match the real shape of inventory. The first segment of the SKU should match the
        primary criterion of your business (category, in most cases).
      </p>

      <h2>Examples by industry</h2>
      <ul>
        <li><strong>Apparel:</strong> <code>SHI-LEV-BL-L-0042</code> (Shirt, Levi's, Blue, Large, #42).</li>
        <li><strong>Electronics:</strong> <code>NB-DELL-INSP15-0007</code> (Notebook, Dell, Inspiron 15, #7).</li>
        <li><strong>Grocery:</strong> <code>FOO-MOL-1KG-0123</code> (Food, Molinos, 1kg, #123).</li>
        <li><strong>Beauty:</strong> <code>LIP-MAY-RD02-0009</code> (Lipstick, Maybelline, Red 02, #9).</li>
      </ul>

      <h2>Common mistakes</h2>
      <ul>
        <li><strong>SKUs based on supplier code.</strong> Switch supplier and the system breaks.</li>
        <li><strong>Reusing discontinued SKUs.</strong> Historical reports break.</li>
        <li><strong>Too much hierarchy depth.</strong> 3-4 segments max. More and no one remembers them.</li>
        <li><strong>Changing format mid-catalog.</strong> You end up with two logics living together; nobody knows which is which.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>What is a SKU?</summary><p>Stock Keeping Unit: unique internal code per product variant. Different from a barcode.</p></details>
      <details><summary>How to structure?</summary><p>Category + brand + attribute + sequence, separated by dashes.</p></details>
      <details><summary>How many characters?</summary><p>8-15 is the sweet spot.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .sk-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .sk-row { grid-template-columns: 1fr; } }
</style>

<script>
  const catEl = document.getElementById('sk-cat') as HTMLInputElement;
  const brandEl = document.getElementById('sk-brand') as HTMLInputElement;
  const attrEl = document.getElementById('sk-attr') as HTMLInputElement;
  const padEl = document.getElementById('sk-pad') as HTMLInputElement;
  const modeEl = document.getElementById('sk-mode') as HTMLSelectElement;
  const amountEl = document.getElementById('sk-amount') as HTMLInputElement;
  const out = document.getElementById('sk-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('sk-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('sk-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function clean(s: string) { return s.toUpperCase().replace(/[^A-Z0-9-]/g, ''); }

  function generate() {
    const cat = clean(catEl.value || 'TS');
    const brand = clean(brandEl.value || 'XXX');
    const attr = clean(attrEl.value || '');
    const pad_ = Math.max(3, Math.min(6, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      const seq = mode === 'seq' ? pad(i + 1, pad_) : pad(rint(Math.pow(10, pad_)), pad_);
      const parts = [cat, brand, attr, seq].filter(Boolean);
      arr.push(parts.join('-'));
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
