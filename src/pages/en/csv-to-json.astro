---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'CSV to JSON — Free Converter | Genfy';
const description = 'Turn CSV into a JSON array of objects. Header detection, quote handling and configurable separators. 100% in-browser.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Does it auto-detect the separator?', acceptedAnswer: { '@type': 'Answer', text: 'No. You pick whether your CSV uses comma, semicolon or tab. Wrong choice and rows collapse into a single column.' } },
    { '@type': 'Question', name: 'Does it auto-convert types?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. By default it detects numbers (123, 3.14), booleans (true/false) and null. Everything else stays as string. You can disable detection and keep everything as strings.' } },
    { '@type': 'Question', name: 'Does it support line breaks inside cells?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. If a cell is wrapped in double quotes and contains line breaks, the parser preserves them as part of the value.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Data" title="CSV to JSON converter"
    intro="Paste a CSV and get a JSON array of objects ready for your API or app. Type detection, quote handling and configurable separators.">

    <div slot="tool">
      <div class="cj-row">
        <div>
          <label for="cj-sep">Separator</label>
          <select id="cj-sep">
            <option value=",">Comma (,)</option>
            <option value=";">Semicolon (;)</option>
            <option value="\t">Tab</option>
          </select>
        </div>
        <label class="chk"><input type="checkbox" id="cj-types" checked /> Detect types</label>
      </div>
      <label for="cj-in">CSV</label>
      <textarea id="cj-in" rows="6" style="font-family: var(--font-mono); font-size: 0.9rem;">name,age,active
Ann,30,true
Pete,25,false
"Mary, Smith",35,true</textarea>
      <button id="cj-gen" class="btn btn-primary" type="button" style="margin-top:1rem;">Convert</button>
      <button id="cj-copy" class="btn btn-ghost" type="button">Copy</button>
      <div id="cj-status" class="cj-status"></div>
      <label for="cj-out" style="margin-top:1rem;">JSON</label>
      <textarea id="cj-out" rows="10" readonly style="font-family: var(--font-mono); font-size: 0.9rem;"></textarea>
    </div>

    <div slot="content">
      <h2>From flat to structured</h2>
      <p>
        CSV is the oldest data-exchange format on the web. Excel exports CSV, legacy APIs sometimes only accept CSV, and many analysts prefer CSV because it opens instantly in Sheets or Excel. But when that data needs to enter a modern app, a REST API or a Node script, JSON is the native shape. This converter bridges the two with a parser that respects RFC 4180.
      </p>

      <h2>Rules the parser respects</h2>
      <ul>
        <li>The first row is interpreted as headers (keys of the resulting JSON).</li>
        <li>Values inside double quotes can contain the separator, escaped quotes (<code>""</code>) and line breaks.</li>
        <li>Whitespace at the start or end of a value is preserved (not trimmed).</li>
        <li>Empty rows are ignored.</li>
      </ul>

      <h2>Automatic type detection</h2>
      <p>
        By default, the converter inspects each cell and tries to infer a type:
      </p>
      <ul>
        <li><strong>Numbers:</strong> <code>42</code>, <code>3.14</code>, <code>-7</code>, scientific (<code>1e6</code>).</li>
        <li><strong>Booleans:</strong> lowercase <code>true</code> and <code>false</code>.</li>
        <li><strong>Null:</strong> exact <code>null</code>, also empty cells.</li>
        <li><strong>Strings:</strong> everything else, including ISO date strings.</li>
      </ul>
      <p>
        If your CSV has zip codes starting with zero (<code>05000</code>) or SKU IDs that look numeric but should stay strings, disable type detection. Otherwise leading zeros vanish and integrity breaks.
      </p>

      <h2>Use cases</h2>
      <ul>
        <li><strong>Loading customer data into an app.</strong> Convert the CSV the customer exported into JSON and post directly to your API.</li>
        <li><strong>Migrating from Excel to a CMS.</strong> Sheets exports CSV; your CMS expects JSON.</li>
        <li><strong>Browser-side processing in JavaScript.</strong> Once converted, you can filter, map and reduce with Array methods without external parsers.</li>
        <li><strong>Posting to a REST endpoint.</strong> Many APIs accept POST with JSON — handy to have the format ready before sending.</li>
      </ul>

      <h2>Common conversion errors</h2>
      <ul>
        <li><strong>Wrong separator.</strong> Pick comma when your CSV uses semicolon and every row collapses into one column.</li>
        <li><strong>Wrong encoding.</strong> CSV in Latin-1 (ISO-8859-1) pasted as UTF-8 mangles accents. Convert the file to UTF-8 first.</li>
        <li><strong>Inconsistent quoting.</strong> Hand-built CSVs sometimes mix single and double quotes, confusing the parser.</li>
        <li><strong>Duplicate headers.</strong> If two columns share a name, JSON keeps only one (object keys are unique).</li>
      </ul>

      <h2>Validation tips</h2>
      <p>
        After converting, sanity-check: <code>JSON.parse</code> in the console plus <code>console.table()</code> gives an instant tabular view. If types aren't what you expect, toggle the detection flag. A column you expected as number that came out as string usually has non-numeric characters (spaces, currency symbols) the parser detected.
      </p>
    </div>

    <div slot="faq">
      <details><summary>Does it auto-detect the separator?</summary><p>No. Pick comma, semicolon or tab. Wrong choice collapses rows into one column.</p></details>
      <details><summary>Does it auto-convert types?</summary><p>Yes — numbers, booleans, null. Disable if you need everything as strings.</p></details>
      <details><summary>Does it support line breaks inside cells?</summary><p>Yes, if the cell is wrapped in double quotes.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .cj-row { display: grid; grid-template-columns: auto 1fr; gap: 1.5rem; align-items: end; margin-bottom: 1rem; }
  .chk { display: flex; align-items: center; gap: 0.5rem; margin: 0; }
  .chk input { width: auto; }
  .cj-status { font-family: var(--font-mono); font-size: 0.85rem; margin-top: 0.5rem; min-height: 1.25rem; color: var(--text-soft); }
  @media (max-width: 600px) { .cj-row { grid-template-columns: 1fr; } }
</style>

<script>
  const inEl = document.getElementById('cj-in') as HTMLTextAreaElement;
  const out = document.getElementById('cj-out') as HTMLTextAreaElement;
  const sepEl = document.getElementById('cj-sep') as HTMLSelectElement;
  const typesEl = document.getElementById('cj-types') as HTMLInputElement;
  const status = document.getElementById('cj-status') as HTMLDivElement;
  const genBtn = document.getElementById('cj-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('cj-copy') as HTMLButtonElement;

  function parseCSV(text: string, sep: string): string[][] {
    const rows: string[][] = [];
    let row: string[] = [];
    let cur = '';
    let i = 0, inQ = false;
    while (i < text.length) {
      const ch = text[i];
      if (inQ) {
        if (ch === '"') {
          if (text[i+1] === '"') { cur += '"'; i += 2; continue; }
          inQ = false; i++; continue;
        }
        cur += ch; i++; continue;
      } else {
        if (ch === '"') { inQ = true; i++; continue; }
        if (ch === sep) { row.push(cur); cur = ''; i++; continue; }
        if (ch === '\n' || ch === '\r') {
          row.push(cur); cur = '';
          if (row.length > 1 || row[0] !== '') rows.push(row);
          row = [];
          if (ch === '\r' && text[i+1] === '\n') i++;
          i++; continue;
        }
        cur += ch; i++;
      }
    }
    if (cur !== '' || row.length > 0) { row.push(cur); rows.push(row); }
    return rows;
  }

  function coerce(v: string): any {
    if (v === '' || v === 'null') return null;
    if (v === 'true') return true;
    if (v === 'false') return false;
    if (/^-?\d+$/.test(v)) return parseInt(v, 10);
    if (/^-?\d+\.\d+$/.test(v) || /^-?\d+(\.\d+)?[eE][+-]?\d+$/.test(v)) return parseFloat(v);
    return v;
  }

  function run() {
    const txt = inEl.value;
    if (!txt.trim()) { out.value = ''; status.textContent = ''; return; }
    try {
      const sep = sepEl.value === '\\t' ? '\t' : sepEl.value;
      const rows = parseCSV(txt, sep);
      if (rows.length < 2) { status.textContent = 'Need at least a header and one row'; out.value = ''; return; }
      const headers = rows[0];
      const data = rows.slice(1).map(r => {
        const o: Record<string, any> = {};
        headers.forEach((h, i) => {
          const raw = r[i] ?? '';
          o[h] = typesEl.checked ? coerce(raw) : raw;
        });
        return o;
      });
      out.value = JSON.stringify(data, null, 2);
      status.textContent = `${data.length} rows, ${headers.length} columns`;
    } catch (e: any) {
      out.value = '';
      status.textContent = 'Error: ' + (e.message || 'Invalid CSV');
    }
  }
  inEl.addEventListener('input', run);
  sepEl.addEventListener('change', run);
  typesEl.addEventListener('change', run);
  genBtn.addEventListener('click', run);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  run();
</script>
