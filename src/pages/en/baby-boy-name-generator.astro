---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';
import { BABY_BOY_NAMES, NAME_STYLES } from '../../lib/baby-names';

const title = 'Baby Boy Name Generator | Genfy';
const description = 'Modern, classic or short: find the perfect baby boy name. 50+ ideas in English and Spanish — free instant generator.';
const stylesEN = { modern: NAME_STYLES.en.modern, classic: NAME_STYLES.en.classic, short: NAME_STYLES.en.short };

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I choose my baby\'s name?', acceptedAnswer: { '@type': 'Answer', text: 'Run four filters: pronunciation in other languages, rhythm with the surname, possible playground teasing, and how it sounds in a job interview. If it passes all four, it\'s a candidate.' } },
    { '@type': 'Question', name: 'Classic or modern name?', acceptedAnswer: { '@type': 'Answer', text: 'Classics (William, John, James) age best; moderns (Liam, Noah, Mateo) lead today\'s rankings. Combining a modern first name with a classic middle name is a common strategy.' } },
    { '@type': 'Question', name: 'Does the rhythm with the surname matter?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Names with the same syllable count as the surname tend to sound flat. A contrast — short first + long last, or vice versa — usually reads better.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" withSidebar={true} schema={faqSchema}>
  <GeneratorShell lang="en" tag="Babies" title="Baby Boy Name Generator"
    intro="Modern, classic or short: find the name that fits your baby boy best. Click and get 12 fresh ideas in seconds.">

    <div slot="tool" class="cn">
      <label for="cn-style">Style</label>
      <select id="cn-style">
        {Object.entries(stylesEN).map(([k, v]) => <option value={k}>{v}</option>)}
        <option value="all">Mix of all</option>
      </select>
      <button id="cn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 12 names</button>
      <div id="cn-out" class="cn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick your baby boy's name</h2>
      <p>
        A name follows a person for life and you choose it in a few weeks. Sociolinguists and
        pediatric guides converge on four filters worth running before committing:
      </p>
      <ul>
        <li><strong>Pronunciation.</strong> How does an English speaker say it? A Spanish-speaking grandparent? A teacher in another country? If it generates doubt in any of them, think twice.</li>
        <li><strong>Rhythm with the surname.</strong> Read the full name aloud three times. If it sounds flat, change the syllable count.</li>
        <li><strong>Initials.</strong> Make sure first + middle + last initials don't form awkward acronyms.</li>
        <li><strong>Potential teasing.</strong> Kids will rhyme anything. Spend a session imagining school-age variations.</li>
        <li><strong>Adult version.</strong> How does the name sound said by a 50-year-old doctor? If natural, it works.</li>
      </ul>

      <h2>Styles: modern, classic, short</h2>
      <ul>
        <li><strong>Modern</strong> (Liam, Noah, Mateo, Lucas, Theodore): dominate the last decade's rankings in the US, UK, Canada and most of Latin America.</li>
        <li><strong>Classic</strong> (James, William, John, Henry, Charles): age better than any other group. Pair well with long or unusual surnames.</li>
        <li><strong>Short</strong> (Leo, Max, Eli, Cole, Finn): rising trend. Easy to pronounce in any language, easy to combine with a longer middle name.</li>
      </ul>

      <h2>Trends in boys' names</h2>
      <p>
        In 2024-2025, the US Social Security Administration and the UK Office for National Statistics
        agree on a clear pattern: vowel-ending names (Theo, Hugo, Leo, Mateo, Asher) rise every year.
        New Testament biblical names (Matthew, Luke, Daniel, Samuel) are at all-time highs. Older
        classics like John, Joseph and Charles drop as primary names but rise as middle names.
      </p>

      <h2>Common mistakes</h2>
      <ol>
        <li>Picking a name only because it's trendy: in 10 years it isn't.</li>
        <li>Initials forming awkward acronyms — always test first + middle + last.</li>
        <li>Names too hard to pronounce in a country you'll live in or visit often.</li>
        <li>Not aligning with your partner early: at 38 weeks it's too late.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>How do I choose my baby's name?</summary><p>Pronunciation, rhythm with the surname, possible teasing, and how it sounds in adult life.</p></details>
      <details><summary>Classic or modern?</summary><p>Classics age better; moderns dominate today. Combining them is a common strategy.</p></details>
      <details><summary>Does rhythm with surname matter?</summary><p>Yes. Aim for syllable contrast.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .cn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .cn-item { padding: 0.625rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; text-align: center; cursor: pointer; transition: border-color 0.1s; }
  .cn-item:hover { border-color: var(--primary); }
</style>

<script define:vars={{ DATA: BABY_BOY_NAMES }}>
  const styleEl = document.getElementById('cn-style');
  const out = document.getElementById('cn-out');
  const gen = document.getElementById('cn-gen');

  function pick(arr) { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const s = styleEl.value;
    let pool = [];
    if (s === 'all') pool = [...DATA.modern.en, ...DATA.classic.en, ...DATA.short.en];
    else pool = DATA[s].en;
    const set = new Set();
    let attempts = 0;
    while (set.size < Math.min(12, pool.length) && attempts < 200) { attempts++; set.add(pick(pool)); }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'cn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
