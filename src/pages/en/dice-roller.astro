---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Online Dice Roller — D6, D20 and more | Genfy';
const description = 'Roll one or many dice online with animation. Supports D4, D6, D8, D10, D12, D20 and D100. Perfect for D&D, board games or quick decisions.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Which dice can I roll?', acceptedAnswer: { '@type': 'Answer', text: 'D4, D6 (classic), D8, D10, D12, D20 (D&D) and D100. You can roll several at once (e.g. 3D6 rolls 3 six-sided dice).' } },
    { '@type': 'Question', name: 'What does 4d6 drop lowest mean?', acceptedAnswer: { '@type': 'Answer', text: 'The classic D&D rule for generating ability scores: roll 4 six-sided dice, drop the lowest, sum the remaining 3. Average comes out higher than straight 3d6.' } },
    { '@type': 'Question', name: 'Is it fair?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. We use crypto.getRandomValues with uniform distribution. Fairer than physical dice, which often have small manufacturing asymmetries.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Random" title="Online dice roller"
    intro="A virtual dice tray with D4, D6, D8, D10, D12, D20 and D100. Roll as many as you want at once. Perfect for D&D, board games or just deciding things with a touch more drama than a coin.">

    <div slot="tool" class="dice-tool">
      <div class="dice-controls">
        <div>
          <label for="dice-type">Die type</label>
          <select id="dice-type">
            <option value="4">D4 (4 sides)</option>
            <option value="6" selected>D6 (classic)</option>
            <option value="8">D8</option>
            <option value="10">D10</option>
            <option value="12">D12</option>
            <option value="20">D20 (D&D)</option>
            <option value="100">D100</option>
          </select>
        </div>
        <div>
          <label for="dice-count">Count</label>
          <input id="dice-count" type="number" value="2" min="1" max="20" />
        </div>
        <div>
          <label for="dice-mod">Modifier (+/-)</label>
          <input id="dice-mod" type="number" value="0" />
        </div>
      </div>

      <div id="dice-stage" class="dice-stage"></div>

      <div id="dice-result" class="dice-result">
        <div class="dice-total">—</div>
        <div class="dice-detail">Hit "roll dice" to start</div>
      </div>

      <div class="dice-actions">
        <button id="dice-roll" class="btn btn-primary" type="button">Roll dice</button>
        <button id="dice-d20" class="btn btn-ghost" type="button">Quick D20</button>
        <button id="dice-3d6" class="btn btn-ghost" type="button">3D6 (ability)</button>
      </div>
    </div>

    <div slot="content">
      <h2>Why dice come in so many shapes</h2>
      <p>
        The 6-sided die is the most familiar, but other shapes exist to cover different
        probability distributions. Each is used in tabletop RPGs and simulations where
        the count of possible outcomes matters: a D4 has fewer extremes, a D20 allows
        fine gradation between catastrophic failure and critical success.
      </p>

      <h2>Anatomy of each die</h2>
      <ul>
        <li><strong>D4 (tetrahedron):</strong> 4 triangular faces. Lands point-up; the number is read at the bottom edge. Average: 2.5.</li>
        <li><strong>D6 (cube):</strong> the Monopoly/Yahtzee classic. Average: 3.5.</li>
        <li><strong>D8 (octahedron):</strong> two pyramids glued together. Average: 4.5.</li>
        <li><strong>D10 (trapezohedron):</strong> 10 pentagonal faces. Average: 5.5. Often numbered 0-9 or 1-10.</li>
        <li><strong>D12 (dodecahedron):</strong> 12 pentagonal faces. Average: 6.5.</li>
        <li><strong>D20 (icosahedron):</strong> 20 triangular faces. The king of D&D. Average: 10.5. A "natural 20" is critical success, "natural 1" critical fail.</li>
        <li><strong>D100 (percentile):</strong> two D10 (one for tens, one for units) giving 1-100. For detailed loot tables.</li>
      </ul>

      <h2>4d6 drop lowest: the standard D&D ability score</h2>
      <p>
        When you create a Dungeons & Dragons 5e character, the default rule for each
        ability score (Strength, Dexterity, Constitution, etc.) is to <strong>roll 4
        six-sided dice and sum the highest 3</strong>. The average jumps from 10.5
        (straight 3d6) to about 12.24, producing more capable characters without
        guaranteeing high numbers. Probability of a natural 18: about 1.6%.
      </p>

      <h2>Other useful notations</h2>
      <ul>
        <li><strong>2d20kh1 (advantage):</strong> roll 2 D20 and keep the higher. The "advantage" mechanic in D&D 5e.</li>
        <li><strong>2d20kl1 (disadvantage):</strong> 2 D20, keep the lower. "Disadvantage".</li>
        <li><strong>1d20+5:</strong> roll one D20 and add 5. Character modifiers.</li>
        <li><strong>1d8r1 (reroll):</strong> roll a D8, reroll if it's a 1. For magic weapons that avoid low rolls.</li>
      </ul>

      <h2>Use cases beyond games</h2>
      <ol>
        <li><strong>Deciding what to eat:</strong> 6 options, one D6, done.</li>
        <li><strong>Random presentation order:</strong> N people, each rolls a D20, sort by result.</li>
        <li><strong>Education:</strong> demonstrate uniform distribution and the sum of random variables (2D6 sum is NOT uniform — 7 is the mode).</li>
        <li><strong>Tie-breaking with granularity:</strong> when a coin isn't enough, a D6 or D20 gives more resolution.</li>
      </ol>

      <h2>The 2D6 distribution is not flat</h2>
      <p>
        Fun fact: a single D6 has 1/6 chance per face. Sum two D6 and the result ranges
        2 to 12 with a triangular distribution: 7 is the most probable (6 combinations),
        2 and 12 the rarest (1 each). This is the basis of Catan, where 7 activates the
        robber and 2 or 12 almost never produce resources.
      </p>

      <h2>Why a virtual die is fairer than a physical one</h2>
      <p>
        Physical dice can have manufacturing defects that bias results: uneven density,
        worn corners, faces with less paint than others (high-pip faces are lighter on
        painted dice). Studies with thousands of rolls show 1-3% bias in standard
        branded dice. Virtual dice don't have this problem.
      </p>
    </div>

    <div slot="faq">
      <details><summary>Which dice?</summary><p>D4, D6, D8, D10, D12, D20, D100. Up to 20 at once with modifier.</p></details>
      <details><summary>What's 4d6 drop lowest?</summary><p>Roll 4 six-sided dice, drop the lowest, sum the rest. Standard for D&D ability scores.</p></details>
      <details><summary>Is it fair?</summary><p>Yes. crypto.getRandomValues, uniform distribution. Fairer than physical dice with manufacturing defects.</p></details>
      <details><summary>Works offline?</summary><p>Yes. Once the page loads everything runs locally.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .dice-controls { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  .dice-stage { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; padding: 2rem 1rem; min-height: 140px; background: var(--bg-inset); border-radius: var(--radius-lg); border: 1px solid var(--border); margin-bottom: 1rem; }
  .die { width: 64px; height: 64px; background: linear-gradient(135deg, #fafafa, #e4e4e7); border: 1px solid var(--border-strong); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.5rem; color: #09090b; box-shadow: 0 4px 12px rgba(9,9,11,0.08); animation: die-roll 0.6s var(--ease); }
  .die.crit { background: linear-gradient(135deg, #fef3c7, #fbbf24); color: #78350f; }
  .die.fumble { background: linear-gradient(135deg, #fee2e2, #ef4444); color: #fff; }
  @keyframes die-roll {
    0% { transform: rotate(0) scale(0.5); opacity: 0; }
    50% { transform: rotate(180deg) scale(1.1); }
    100% { transform: rotate(360deg) scale(1); opacity: 1; }
  }
  .dice-result { text-align: center; padding: 1.25rem; background: var(--bg-inset); border-radius: var(--radius-lg); border: 1px solid var(--border); margin-bottom: 1rem; }
  .dice-total { font-size: 2.5rem; font-weight: 800; line-height: 1; font-family: var(--font-mono); }
  .dice-detail { font-size: 0.875rem; color: var(--text-soft); margin-top: 0.25rem; }
  .dice-actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  @media (max-width: 600px) { .dice-controls { grid-template-columns: 1fr 1fr; } }
</style>

<script>
  const typeEl = document.getElementById('dice-type') as HTMLSelectElement;
  const countEl = document.getElementById('dice-count') as HTMLInputElement;
  const modEl = document.getElementById('dice-mod') as HTMLInputElement;
  const stage = document.getElementById('dice-stage')!;
  const total = document.querySelector('.dice-total')!;
  const detail = document.querySelector('.dice-detail')!;
  const rollBtn = document.getElementById('dice-roll') as HTMLButtonElement;

  function rollOne(sides: number) {
    const arr = new Uint32Array(1);
    window.crypto.getRandomValues(arr);
    return (arr[0] % sides) + 1;
  }
  function roll(sides: number, count: number, mod: number) {
    stage.innerHTML = '';
    const rolls: number[] = [];
    for (let i = 0; i < count; i++) {
      const r = rollOne(sides);
      rolls.push(r);
      const die = document.createElement('div');
      die.className = 'die';
      if (sides === 20 && r === 20) die.classList.add('crit');
      if (sides === 20 && r === 1) die.classList.add('fumble');
      die.textContent = String(r);
      stage.appendChild(die);
    }
    const sum = rolls.reduce((a, b) => a + b, 0) + mod;
    total.textContent = String(sum);
    detail.textContent = `${count}d${sides}${mod !== 0 ? (mod > 0 ? '+' + mod : mod) : ''} = [${rolls.join(', ')}]${mod !== 0 ? ` ${mod >= 0 ? '+' : ''}${mod}` : ''}`;
  }
  rollBtn.addEventListener('click', () => roll(parseInt(typeEl.value), Math.max(1, Math.min(20, parseInt(countEl.value) || 1)), parseInt(modEl.value) || 0));
  document.getElementById('dice-d20')!.addEventListener('click', () => { typeEl.value = '20'; countEl.value = '1'; modEl.value = '0'; roll(20, 1, 0); });
  document.getElementById('dice-3d6')!.addEventListener('click', () => { typeEl.value = '6'; countEl.value = '3'; modEl.value = '0'; roll(6, 3, 0); });
</script>
