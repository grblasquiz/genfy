---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Wedding Hashtag Generator | Genfy';
const description = 'Generate unique wedding hashtags. Mix the names of the couple and get 20 creative hashtags for Instagram and TikTok.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Why do I need a wedding hashtag?', acceptedAnswer: { '@type': 'Answer', text: 'A unique hashtag lets you and your guests find all event photos in one place without depending on each person to share directly.' } },
    { '@type': 'Question', name: 'How do I pick one?', acceptedAnswer: { '@type': 'Answer', text: 'Make it unique (check Instagram first), short, easy to type and memorable. A pun on your last names or a nod to your story is a plus.' } },
    { '@type': 'Question', name: 'When do I share it?', acceptedAnswer: { '@type': 'Answer', text: 'On the save the date, the formal invitation and on table cards at the event.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Wedding" title="Wedding Hashtag Generator"
    intro="Mix the couple's names and get 20 unique Instagram hashtags. Perfect for table cards, save the dates and formal invitations.">

    <div slot="tool" class="bn">
      <label for="bn-n1">Name 1</label>
      <input id="bn-n1" type="text" placeholder="Anna" value="Anna" />

      <label for="bn-n2" style="margin-top:1rem">Name 2</label>
      <input id="bn-n2" type="text" placeholder="Bruno" value="Bruno" />

      <label for="bn-style" style="margin-top:1rem">Style</label>
      <select id="bn-style">
        <option value="rhyme">With rhyme (ForeverAnna)</option>
        <option value="merge">Merged (AnnaAndBruno)</option>
        <option value="adjective">With adjective (HappilyEverAB)</option>
        <option value="date">With date (AnnaBruno2026)</option>
        <option value="story">Storytelling (BrunoFoundHisAnna)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 hashtags</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a great wedding hashtag</h2>
      <p>
        A wedding hashtag does one simple job: groups all the photos and videos your guests
        upload during and after the event. Pick well, and it saves hours of asking each
        friend to share their snaps.
      </p>
      <ol>
        <li><strong>Unique.</strong> Verify on Instagram before printing anything.</li>
        <li><strong>Short.</strong> The shorter the better: 30 characters and nobody types it correctly drunk at 3 am.</li>
        <li><strong>Easy to type.</strong> No special characters, no accents, no weird numbers.</li>
        <li><strong>Memorable.</strong> Combining the names with humor or a story nod helps.</li>
        <li><strong>Friendly capitalization.</strong> "AnnaAndBruno2026" reads better than "annaandbruno2026".</li>
      </ol>

      <h2>Classic styles</h2>
      <ul>
        <li><strong>With rhyme:</strong> "ForeverAnna", "GoCrazyDavid". Works if your name rhymes with "forever", "happy", "crazy".</li>
        <li><strong>Merged:</strong> "AnnaAndBruno", "SmithJones2026". The simplest.</li>
        <li><strong>With adjective:</strong> "HappilyEverAB", "WildlyLoveAB". Adds emotional emphasis.</li>
        <li><strong>With date:</strong> "AnnaBruno2026", "SmithJones101225". Useful if you'll reuse on anniversaries.</li>
        <li><strong>Storytelling:</strong> "BrunoFoundHisAnna", "TheDayTheySaidYes". More creative, watch the length.</li>
      </ul>

      <h2>Common mistakes</h2>
      <p>
        Most common: not checking the hashtag is free before printing invitations — if 200
        photos already exist under the same hashtag, yours get lost. Second: picking
        something extremely long. Hour 4 of the party, nobody types
        "#TheWeddingOfAnnaAndBruno2026". Third: special characters — Instagram does not
        accept accents in hashtags.
      </p>

      <h2>How to share it</h2>
      <ol>
        <li>Save the date: include the hashtag at the bottom.</li>
        <li>Formal invitation: on the back of the card or on a separate sheet.</li>
        <li>Table cards: print with legible type.</li>
        <li>Mirror or sign at the entrance: visible on arrival.</li>
        <li>Couple's announcement at the start: "post it all at #..."</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>Why a wedding hashtag?</summary><p>To find all event photos in one place without asking each guest.</p></details>
      <details><summary>How to pick one?</summary><p>Unique, short, easy to type, memorable. No accents or special characters.</p></details>
      <details><summary>When to share it?</summary><p>Save the date, formal invitation, table cards and the couple's announcement.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; font-family: monospace; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const RHYME = ['Forever', 'Happy', 'Crazy', 'Wild', 'Sweet', 'Lovely', 'Always', 'Truly'];
  const ADJ = ['Happily', 'Wildly', 'Sweetly', 'Forever', 'Madly', 'Always', 'Eternally', 'Truly'];

  const n1Input = document.getElementById('bn-n1') as HTMLInputElement;
  const n2Input = document.getElementById('bn-n2') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function clean(s: string) { return s.normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-zA-Z]/g, ''); }
  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const n1 = cap(clean(n1Input.value || 'Anna'));
    const n2 = cap(clean(n2Input.value || 'Bruno'));
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let h = '';
      if (s === 'rhyme') h = '#' + clean(pick(RHYME)) + n1 + n2;
      else if (s === 'merge') {
        const variant = Math.random();
        if (variant < 0.33) h = '#' + n1 + 'And' + n2;
        else if (variant < 0.66) h = '#' + n1 + n2 + '2026';
        else h = '#The' + n1 + n2;
      }
      else if (s === 'adjective') h = '#' + clean(pick(ADJ)) + 'Ever' + n1.charAt(0) + n2.charAt(0);
      else if (s === 'date') h = '#' + n1 + n2 + (Math.random() > 0.5 ? '2026' : '101225');
      else if (s === 'story') {
        const stories = ['FoundHis', 'SaidYesTo', 'MarriedHis', 'LovesHis', 'WeddingOf'];
        h = '#' + n2 + pick(stories) + n1;
      }
      set.add(h);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
