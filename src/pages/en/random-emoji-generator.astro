  const result = document.getElementById('em-result')!;
  const gen = document.getElementById('em-gen') as HTMLButtonElement;
  const copy = document.getElementById('em-copy') as HTMLButtonElement;

  function rand(max: number) {
    const arr = new Uint32Array(1);
    window.crypto.getRandomValues(arr);
    return arr[0] % max;
  }
  function pick() {
    const set = cat.value === 'all' ? all() : EMOJIS[cat.value];
    const n = Math.max(1, Math.min(50, parseInt(count.value) || 1));
    const out: string[] = [];
    for (let i = 0; i < n; i++) out.push(set[rand(set.length)]);
    result.textContent = out.join(' ');
  }
  gen.addEventListener('click', pick);
  copy.addEventListener('click', () => {
    navigator.clipboard.writeText(result.textContent || '');
    copy.textContent = 'Copied!';
    setTimeout(() => { copy.textContent = 'Copy'; }, 1200);
  });
  pick();
