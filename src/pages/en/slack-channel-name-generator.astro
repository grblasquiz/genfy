---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Slack Channel Name Generator | Genfy';
const description = 'Generate consistent Slack channel names. Mix theme, team or type and get 20 ready-to-create suggestions with clear conventions.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What makes a good Slack channel name?', acceptedAnswer: { '@type': 'Answer', text: 'It follows a clear convention (prefixes by type), uses lowercase and hyphens, is descriptive of the topic, and autocompletes easily.' } },
    { '@type': 'Question', name: 'Should I use prefixes?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Conventions like #proj-, #team-, #help- or #social- group similar channels and improve discovery.' } },
    { '@type': 'Question', name: 'How do I prevent proliferation?', acceptedAnswer: { '@type': 'Answer', text: 'Define a convention when launching the workspace, archive channels inactive for 30 days, and review the list every quarter.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Productivity" title="Slack Channel Name Generator"
    intro="Mix channel type and topic and get 20 consistent names for your Slack workspace. Built to improve autocomplete, search and onboarding.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Topic (project, team, theme)</label>
      <input id="bn-kw" type="text" placeholder="growth, design, hiring..." value="growth" />

      <label for="bn-style" style="margin-top:1rem">Channel type</label>
      <select id="bn-style">
        <option value="proj">#proj- (project)</option>
        <option value="team">#team- (team)</option>
        <option value="help">#help- (internal support)</option>
        <option value="social">#social- (casual)</option>
        <option value="ann">#ann- (announcements)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to name Slack channels</h2>
      <p>
        A well-designed channel convention improves team productivity in measurable ways:
        less time searching for where to ask, smoother onboarding, fewer duplicate channels
        with the same purpose.
      </p>
      <ol>
        <li><strong>Prefix by type.</strong> #proj-, #team-, #help-, #social-, #ann-. Visually grouped.</li>
        <li><strong>Lowercase and hyphens.</strong> #proj-launch-q1, not #ProjLaunchQ1.</li>
        <li><strong>Descriptive and specific.</strong> #help-billing beats #help-stuff.</li>
        <li><strong>Short but clear.</strong> Aim for 15-25 characters.</li>
        <li><strong>Written convention.</strong> Document it in #ann-channel-rules.</li>
      </ol>

      <h2>Recommended conventions</h2>
      <ul>
        <li><strong>#proj-:</strong> projects with clear start/end (#proj-mobile-app, #proj-launch-q1).</li>
        <li><strong>#team-:</strong> permanent teams (#team-design, #team-engineering).</li>
        <li><strong>#help-:</strong> internal support (#help-finance, #help-legal, #help-it).</li>
        <li><strong>#social-:</strong> casual (#social-coffee, #social-pets, #social-music).</li>
        <li><strong>#ann-:</strong> announcements, read-only for many (#ann-company, #ann-product).</li>
      </ul>

      <h2>Common mistakes</h2>
      <p>
        Most common: no convention at all — the workspace fills with inconsistently named
        channels and nobody finds anything. Second: cryptic internal names that require
        context — "#g4-q3-c2" tells a new hire nothing. Third: not archiving dead channels —
        your active channel list gets noisy.
      </p>

      <h2>Operational best practices</h2>
      <ol>
        <li>Define the convention before exceeding 30 channels.</li>
        <li>Archive channels with zero messages in 30 days.</li>
        <li>Review channel list every quarter.</li>
        <li>Use clear descriptions and a pinned message with rules.</li>
        <li>Limit who can create channels in large workspaces.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>What makes a good name?</summary><p>Clear convention, lowercase, hyphens, descriptive, autocompletes well.</p></details>
      <details><summary>Prefixes?</summary><p>Yes. #proj-, #team-, #help-, #social- group and improve discovery.</p></details>
      <details><summary>Prevent proliferation?</summary><p>Written convention, automatic archiving, quarterly review.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; font-family: monospace; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const PROJ = ['launch', 'redesign', 'mobile-app', 'pricing', 'expansion', 'migration', 'rebrand', 'rollout', 'q1', 'q2', 'beta'];
  const TEAM = ['design', 'engineering', 'product', 'sales', 'marketing', 'finance', 'people', 'ops', 'data', 'support'];
  const HELP = ['billing', 'finance', 'legal', 'it', 'hr', 'tools', 'design', 'data', 'security', 'office'];
  const SOCIAL = ['coffee', 'pets', 'music', 'books', 'games', 'food', 'travel', 'tv', 'photography', 'kids'];
  const ANN = ['company', 'product', 'release', 'press', 'finance', 'people', 'office'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function slug(s: string) { return s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, ''); }

  function generate() {
    const w = slug(kw.value.trim() || 'growth');
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let name = '';
      if (s === 'proj') name = '#proj-' + w + '-' + pick(PROJ);
      else if (s === 'team') name = '#team-' + pick(TEAM);
      else if (s === 'help') name = '#help-' + pick(HELP);
      else if (s === 'social') name = '#social-' + pick(SOCIAL);
      else if (s === 'ann') name = '#ann-' + pick(ANN);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
