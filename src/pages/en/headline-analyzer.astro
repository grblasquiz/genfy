---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Headline Quality Analyzer | Genfy';
const description = 'Score the quality of any headline for blogs, emails or ads. Length, power words, structure and clarity in one click.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What does the analyzer evaluate?', acceptedAnswer: { '@type': 'Answer', text: 'Length, presence of numbers, power words, emotional triggers, clarity and structure of the headline.' } },
    { '@type': 'Question', name: 'Does it work for emails and ads?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. The rules are similar for subject lines, ads and blog headlines: clarity and a specific promise.' } },
    { '@type': 'Question', name: 'Is the score objective?', acceptedAnswer: { '@type': 'Answer', text: 'It\'s a heuristic guide based on copywriting best practices. The real test is an A/B with your actual audience.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Text" title="Headline Quality Analyzer"
    intro="Paste a headline and get a quality score with concrete suggestions. Built for blog posts, newsletters, ads, email subjects and social posts.">

    <div slot="tool">
      <label for="ha-in">Headline</label>
      <input id="ha-in" type="text" placeholder="e.g. 7 tricks to write better headlines in 2026" />
      <div style="margin-top:0.75rem;">
        <button id="ha-go" class="btn btn-primary" type="button">Analyze</button>
      </div>
      <div id="ha-out" class="ha-out" aria-live="polite"></div>
    </div>

    <div slot="content">
      <h2>Why the headline carries 80% of the work</h2>
      <p>
        David Ogilvy used to say five times as many people read the headline as the body. In a Twitter,
        LinkedIn or Google feed, the headline is all most readers will ever see. If it doesn't catch
        attention and promise something clear, you've lost the fight before starting. That's why headlines
        deserve more time than any paragraph in the body.
      </p>

      <h2>What this analyzer checks</h2>
      <ul>
        <li><strong>Length</strong> — 40 to 70 characters tends to convert best.</li>
        <li><strong>Numbers</strong> — headlines with concrete digits perform better.</li>
        <li><strong>Power words</strong> — strong verbs and emotional adjectives.</li>
        <li><strong>Specificity</strong> — concrete vs. vague promises.</li>
        <li><strong>Clarity</strong> — no convoluted phrasing or double negatives.</li>
        <li><strong>Structure</strong> — known formulas (how, why, lists, questions).</li>
      </ul>

      <h2>Formulas that work</h2>
      <p>
        After decades of testing, certain structures dominate. <em>How</em>: "How to write a headline that
        doubles your CTR". <em>Lists</em>: "7 mistakes you make writing headlines". <em>Why</em>: "Why
        nobody opens your newsletter". <em>Question</em>: "Are your headlines killing your CTR?".
        <em>Negative</em>: "The mistake that ruins 80% of headlines". Not magic recipes, but they work
        because readers parse the format instantly.
      </p>

      <h2>English power words</h2>
      <p>
        Certain words measurably lift CTR: "free", "fast", "ultimate", "essential", "proven", "secret",
        "easy", "now", "new", "best", "avoid", "warning", "incredible", "tested", "guaranteed", "simple",
        "powerful", "key", "urgent", "exclusive". Use them carefully: overuse devalues them. One or two per
        headline is plenty.
      </p>

      <h2>The magic character count</h2>
      <p>
        For Google search, the sweet spot is 50-60 characters (more gets truncated in SERP). For
        Twitter/X, 70-80 works well. For newsletters, subject lines under 40 chars perform better on
        mobile. LinkedIn tolerates up to 100. If your headline is 120 chars chaining three ideas, you
        probably want to split into headline and subhead.
      </p>

      <h2>Common mistakes</h2>
      <ul>
        <li><strong>Generic</strong> — "Tips for founders" vs. "5 tips that saved my client $10K".</li>
        <li><strong>Long and tangled</strong> — 80+ characters with two commas: trim it.</li>
        <li><strong>Clickbait without substance</strong> — over-promising kills trust.</li>
        <li><strong>No promise</strong> — the reader must know what they get from clicking.</li>
        <li><strong>Ambiguous</strong> — if it isn't clear in two seconds, it isn't clear.</li>
      </ul>

      <h2>How to use the score</h2>
      <p>
        The score is a guide, not a verdict. A headline can score 95/100 and flop, or 50/100 and break
        records. The real test is an A/B with your audience. But if the analyzer warns "110 characters and
        no number", the issue is probably real. Use it as a first filter, not a final call.
      </p>

      <h2>Write 10 before picking one</h2>
      <p>
        Pro copywriters write 10-20 versions of the same headline before choosing. The first is always
        the obvious one; the tenth is usually the best. Run each candidate through the analyzer, drop the
        worst and test the top two or three. That discipline is the difference between a blog that grows
        and one that stalls.
      </p>
    </div>

    <div slot="faq">
      <details><summary>What does the analyzer evaluate?</summary><p>Length, numbers, power words, structure and clarity.</p></details>
      <details><summary>Does it work for emails and ads?</summary><p>Yes — same playbook for subjects, ads and headlines.</p></details>
      <details><summary>Is the score objective?</summary><p>A heuristic guide. The real verdict is A/B with real users.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .ha-out { margin-top: 1rem; padding: 1rem; background: var(--bg-soft, #f5f5f7); border-radius: var(--radius-md, 8px); font-size: 0.95rem; min-height: 4rem; }
  .ha-bar { height: 8px; background: #e2e2e8; border-radius: 4px; overflow: hidden; margin: 0.5rem 0; }
  .ha-bar-fill { height: 100%; background: linear-gradient(90deg, #ef4444, #f59e0b, #10b981); transition: width 0.3s; }
</style>

<script>
  const POWER = "free fast ultimate essential proven secret easy now new best avoid warning incredible tested guaranteed simple powerful key urgent exclusive instant boost smart top".split(' ');
  const inEl = document.getElementById('ha-in') as HTMLInputElement;
  const out = document.getElementById('ha-out') as HTMLDivElement;
  const go = document.getElementById('ha-go') as HTMLButtonElement;

  function analyze() {
    const t = inEl.value.trim();
    if (!t) { out.innerHTML = ''; return; }
    let score = 0;
    const tips: string[] = [];
    const len = t.length;
    const words = t.split(/\s+/).length;
    if (len >= 40 && len <= 70) { score += 25; tips.push('Optimal length.'); }
    else if (len < 40) { score += 10; tips.push('A bit short — try adding specificity.'); }
    else { score += 10; tips.push('A bit long — split or trim.'); }
    if (/\d+/.test(t)) { score += 20; tips.push('Contains a number, good.'); } else tips.push('Add a concrete number.');
    const lc = t.toLowerCase();
    const powers = POWER.filter(p => lc.includes(p));
    if (powers.length > 0) { score += 15 + Math.min(10, powers.length * 5); tips.push(`Power words: ${powers.join(', ')}.`); }
    else tips.push('Add a power word (try: free, easy, ultimate).');
    if (/^(how|why|what|when|where|7|5|10|3)/i.test(t)) { score += 15; tips.push('Starts with a recognized formula.'); }
    if (words >= 6 && words <= 12) score += 15;
    if (/\?/.test(t)) tips.push('Direct question: good for curiosity.');
    score = Math.min(100, score);
    const label = score >= 80 ? 'Excellent' : score >= 60 ? 'Good' : score >= 40 ? 'Decent' : 'Needs work';
    out.innerHTML = `<strong>Score: ${score}/100</strong> — ${label}<div class="ha-bar"><div class="ha-bar-fill" style="width: ${score}%"></div></div>${len} characters, ${words} words<ul style="margin-top:0.5rem;">${tips.map(t=>`<li>${t}</li>`).join('')}</ul>`;
  }
  go.addEventListener('click', analyze);
  inEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') analyze(); });
</script>
