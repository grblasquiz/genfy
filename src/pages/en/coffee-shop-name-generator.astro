---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Coffee Shop Name Generator | Genfy';
const description = 'Generate names for your coffee shop or specialty cafe. Mix roast, origin or concept and get 20 ideas for sign, domain and socials.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What\'s the difference between a cafe and a coffee shop?', acceptedAnswer: { '@type': 'Answer', text: 'Coffee shop usually points to a third-wave spot focused on origin beans, pour-over and in-house or trusted roasting. Cafe is broader, covering everything from neighborhood bars to chains.' } },
    { '@type': 'Question', name: 'Should I include "Coffee" in the name?', acceptedAnswer: { '@type': 'Answer', text: 'Helps local SEO because people search "coffee + neighborhood". If your main name is abstract, add "Coffee" as a subtitle on Google Business Profile.' } },
    { '@type': 'Question', name: 'How do I check if it\'s available?', acceptedAnswer: { '@type': 'Answer', text: 'Google Maps within 3 miles, Instagram, TikTok and your local trademark register before investing in signage.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Food &amp; Drink" title="Coffee Shop Name Generator"
    intro="Mix craft, origin or method and get 20 ideas for your specialty coffee shop. Ready to validate domain, handle and Google Business Profile.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Keywords (origin, method, concept)</label>
      <input id="bn-kw" type="text" placeholder="origin, filter, slow..." value="origin, table" />

      <label for="bn-style" style="margin-top:1rem">Style</label>
      <select id="bn-style">
        <option value="craft">Specialty (Origin, Roast)</option>
        <option value="numeric">Numeric (Lot 22, Filter 7)</option>
        <option value="object">Object + Coffee</option>
        <option value="modern">Modern minimalist</option>
        <option value="local">Local + Coffee Co</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a coffee shop name</h2>
      <p>
        A specialty coffee shop lives on Instagram, Google Maps and reviews. The name has to
        survive three uses: the storefront, the stamp on bean bags for retail, and the
        Instagram bio where it competes against thousands of similar accounts.
      </p>
      <ol>
        <li><strong>Conveys craft without pretension.</strong> "Origin", "Roast", "Filter" work; "Master Barista" feels forced.</li>
        <li><strong>Numeric differentiation.</strong> "Lot 22", "Filter 7" add specificity and uniqueness.</li>
        <li><strong>Compatible with bean bags.</strong> Has to print well in 3-color kraft.</li>
        <li><strong>Short IG handle.</strong> Three-word names lose handle space.</li>
        <li><strong>Searchable as coffee.</strong> "X Coffee" or "X Coffee Co" ranks well effortlessly.</li>
      </ol>

      <h2>Third-wave naming styles</h2>
      <ul>
        <li><strong>Specialty:</strong> "Origin", "Roast", "Harvest", "Filter". Connects with serious baristas.</li>
        <li><strong>Numeric:</strong> "Lot 22", "Table 7", "Origin 04". Memorable and unique.</li>
        <li><strong>Object + Coffee:</strong> "Table Coffee", "Spoon Coffee". Functional, easy to print on a mug.</li>
        <li><strong>Modern minimalist:</strong> "Pause", "Slow", "Sprout". Mood-driven.</li>
        <li><strong>Local + Coffee Co:</strong> "Mission Coffee Co", "SoHo Coffee Co". Strong local SEO.</li>
      </ul>

      <h2>What to avoid</h2>
      <p>
        Terms like "Bean", "Beans", "Roasters" and "Brew" are saturated in any major city. Avoid
        the pun trap with "java" or "espresso": ages badly and limits the brand if you add other
        products. And avoid names that work uppercase but break lowercase in a handle: try
        @yourname before deciding.
      </p>

      <h2>Quick validation</h2>
      <ol>
        <li>Google Maps within 3 miles and across your whole city.</li>
        <li>Instagram and TikTok with the exact handle.</li>
        <li>.com and country domain on Namecheap.</li>
        <li>Local trademark register.</li>
        <li>Print on a test bag label.</li>
        <li>Run it past 5 barista friends: does it feel legit?</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>Cafe vs coffee shop?</summary><p>Coffee shop suggests third wave, origin beans, pour-over methods. Cafe is broader.</p></details>
      <details><summary>Include "Coffee" in the name?</summary><p>Helps local SEO. If abstract, add as subtitle on Google Business Profile.</p></details>
      <details><summary>How do I check availability?</summary><p>Google Maps, Instagram, TikTok and the local trademark register.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const CRAFT = ['Origin', 'Roast', 'Filter', 'Harvest', 'Lot', 'Cup', 'Sprout', 'Cradle', 'Root', 'Sieve'];
  const OBJ = ['Table', 'Spoon', 'Kettle', 'Bench', 'Shelf', 'Jar', 'Mug'];
  const MODERN = ['Pause', 'Slow', 'Sprout', 'Awake', 'Calm', 'Steam', 'Mist', 'Zero', 'Dew'];
  const LOCAL = ['Mission', 'SoHo', 'Brera', 'Capitol', 'River', 'Park', 'Market', 'Hudson', 'Pier'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function num() { const i = new Uint32Array(1); crypto.getRandomValues(i); return (i[0] % 99) + 1; }

  function generate() {
    const words = kw.value.split(',').map(s => s.trim()).filter(Boolean);
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      const w = words.length ? pick(words) : 'Coffee';
      let name = '';
      if (s === 'craft') name = pick(CRAFT) + ' Coffee';
      else if (s === 'numeric') name = pick(CRAFT) + ' ' + num();
      else if (s === 'object') name = pick(OBJ) + ' Coffee';
      else if (s === 'modern') name = pick(MODERN) + ' Coffee';
      else if (s === 'local') name = pick(LOCAL) + ' Coffee Co';
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
