---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Random User Agent Generator | Genfy';
const description = 'Generate realistic User Agent strings for Chrome, Firefox, Safari and Edge across operating systems. Useful for testing, scraping research and QA.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is the User Agent?', acceptedAnswer: { '@type': 'Answer', text: 'A text string the browser sends in every HTTP request to identify which browser, version and operating system it came from. Servers use it to adapt responses.' } },
    { '@type': 'Question', name: 'Why generate User Agents?', acceptedAnswer: { '@type': 'Answer', text: 'For functional tests that depend on the UA, log fixtures, bot-detection validation and simulating varied traffic in non-production environments.' } },
    { '@type': 'Question', name: 'Does it help avoid scraping blocks?', acceptedAnswer: { '@type': 'Answer', text: 'Changing the UA is just one signal a site may use to detect bots. Today, sites combine UA with TLS fingerprinting, mouse behavior and more. UA alone guarantees nothing.' } },
    { '@type': 'Question', name: 'Is the User Agent being phased out?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Chrome and others are migrating to User-Agent Client Hints (Sec-CH-UA). Traditional UA still works but its content keeps shrinking and becoming more predictable.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell
    lang="en"
    tag="Tech"
    title="Random User Agent Generator"
    intro="Realistic User Agents for Chrome, Firefox, Safari and Edge on Windows, macOS, Linux, Android and iOS. For testing, fixtures, logs and varied-traffic simulation."
  >
    <div slot="tool" class="ua-tool">
      <div class="ua-controls">
        <div>
          <label for="ua-browser">Browser</label>
          <select id="ua-browser">
            <option value="any" selected>Any</option>
            <option value="chrome">Chrome</option>
            <option value="firefox">Firefox</option>
            <option value="safari">Safari</option>
            <option value="edge">Edge</option>
          </select>
        </div>
        <div>
          <label for="ua-os">OS</label>
          <select id="ua-os">
            <option value="any" selected>Any</option>
            <option value="windows">Windows</option>
            <option value="mac">macOS</option>
            <option value="linux">Linux</option>
            <option value="android">Android</option>
            <option value="ios">iOS</option>
          </select>
        </div>
        <div>
          <label for="ua-count">Quantity</label>
          <input id="ua-count" type="number" min="1" max="100" value="10" />
        </div>
      </div>

      <button id="ua-gen" class="btn btn-primary" type="button">Generate User Agents</button>

      <textarea id="ua-out" class="mono" rows="14" readonly></textarea>
      <button id="ua-copy" class="btn btn-ghost" type="button"><span class="copy-icon">Copy all</span></button>
    </div>

    <div slot="content">
      <h2>What the User Agent is</h2>
      <p>
        The User Agent is a string your browser sends in every HTTP request, in the
        <code>User-Agent</code> header. It identifies the software making the request:
        browser, version, operating system, and sometimes extra details like rendering engine.
      </p>
      <p>A typical Chrome on Windows 11 UA looks like:</p>
      <ul>
        <li><code>Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/121.0.0.0 Safari/537.36</code></li>
      </ul>
      <p>
        That structure is historical. <em>Mozilla/5.0</em> leads because old servers expected
        "Mozilla" before serving modern content. <em>AppleWebKit</em> and <em>KHTML</em> appear
        because Chrome derived from WebKit, which derived from KHTML. It's a 30-year fossil of
        compatibility.
      </p>

      <h2>Legitimate use cases</h2>
      <ol>
        <li><strong>Automated testing.</strong> Verify your system correctly detects mobile/desktop, specific browser and serves the right bundle.</li>
        <li><strong>Log fixtures.</strong> Populate analytics tables with varied UAs to test dashboards.</li>
        <li><strong>Bot detection.</strong> Validate your service rejects suspicious UAs (empty, "curl/7.x", "python-requests/").</li>
        <li><strong>Visual demos.</strong> Show screenshots with realistic UAs instead of "user-agent-1".</li>
        <li><strong>Bug reports.</strong> If a user reports a bug "in their browser", reproduce with their exact UA.</li>
      </ol>

      <h2>The future: Client Hints</h2>
      <p>
        Chrome and others are reducing the detail in the traditional User Agent as an
        anti-fingerprinting measure. Instead, they promote <strong>User-Agent Client
        Hints</strong>: separate HTTP headers (<code>Sec-CH-UA</code>,
        <code>Sec-CH-UA-Platform</code>, <code>Sec-CH-UA-Mobile</code>) the server explicitly
        requests when it needs them.
      </p>
      <p>
        In practice, the traditional UA still works and will keep working for a while, but it
        carries less and less useful information. If your logic depends on the UA for anything
        serious, start migrating to Client Hints.
      </p>

      <h2>When NOT to use fake User Agents</h2>
      <ul>
        <li><strong>To violate terms of service.</strong> If a site bans scraping in its ToS, faking the UA doesn't legalize it.</li>
        <li><strong>To access geo-restricted content.</strong> The UA doesn't include geo. You need a VPN, and that's regulated by your country's laws.</li>
        <li><strong>To impersonate a real user.</strong> If the UA goes alongside another user's cookies, that's fraud.</li>
        <li><strong>To evade usage metrics.</strong> If your app charges per device, faking UAs may violate the contract.</li>
      </ul>

      <h2>Modern bot detection</h2>
      <p>
        Ten years ago, the User Agent was enough to separate humans from bots. Today, serious
        anti-bot systems (Cloudflare, hCaptcha, Akamai) use dozens of signals:
      </p>
      <ul>
        <li>TLS fingerprint (JA3/JA4): how your client negotiates the handshake.</li>
        <li>HTTP/2 fingerprint: order and priority of headers.</li>
        <li>Client Hints: the server requests a value and compares it to expectations.</li>
        <li>Mouse and keyboard behavior.</li>
        <li>Canvas fingerprint, WebGL fingerprint.</li>
        <li>Persistent cookies.</li>
      </ul>
      <p>
        Just changing the UA and expecting to pass as human doesn't work against these systems.
        Talk to the site if you need programmatic access — most have an API.
      </p>

      <h2>UA vs userAgentData</h2>
      <p>
        In modern browsers you can use <code>navigator.userAgentData</code> for structured info
        instead of parsing the string. It returns an object with <code>brands</code>,
        <code>mobile</code>, <code>platform</code>. It's the JS equivalent of Client Hints.
        Compatibility: all recent Chromium; Firefox and Safari haven't shipped it yet.
      </p>
    </div>

    <div slot="faq">
      <details><summary>What is the User Agent?</summary><p>String the browser sends in every HTTP request to identify itself. The server uses it to adapt the response.</p></details>
      <details><summary>Why generate them?</summary><p>Functional tests, log fixtures, bot detection, demos and bug reports.</p></details>
      <details><summary>Help avoid scraping blocks?</summary><p>Only partially. Today UA combines with TLS fingerprint and behavior. UA alone guarantees nothing.</p></details>
      <details><summary>Being phased out?</summary><p>Yes. Migration to User-Agent Client Hints (Sec-CH-UA). Traditional UA still works with shrinking content.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .ua-controls { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .ua-controls { grid-template-columns: 1fr; } }
  textarea { font-family: var(--font-mono); font-size: 0.75rem; background: var(--bg-inset); resize: vertical; margin: 1rem 0 0.75rem; word-break: break-all; }
</style>

<script>
  const CHROME_VERS = ['120.0.0.0','121.0.0.0','122.0.0.0','123.0.0.0','124.0.0.0','125.0.0.0','126.0.0.0'];
  const FF_VERS = ['122.0','123.0','124.0','125.0','126.0','127.0'];
  const SAFARI_VERS = ['16.6','17.0','17.1','17.2','17.3','17.4'];
  const EDGE_VERS = ['120.0.0.0','121.0.0.0','122.0.0.0','123.0.0.0','124.0.0.0'];
  const IOS_VERS = ['16_6','17_0','17_2','17_4'];
  const ANDROID_VERS = ['12','13','14'];
  const OSX_VERS = ['10_15_7','12_7','13_5','14_2'];

  function rand(min: number, max: number): number { const a = new Uint32Array(1); crypto.getRandomValues(a); return min + (a[0] % (max - min + 1)); }
  function pick<T>(arr: T[]): T { return arr[rand(0, arr.length - 1)]; }

  function build(browser: string, os: string): string {
    if (browser === 'chrome') {
      const v = pick(CHROME_VERS);
      if (os === 'windows') return `Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Safari/537.36`;
      if (os === 'mac') return `Mozilla/5.0 (Macintosh; Intel Mac OS X ${pick(OSX_VERS)}) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Safari/537.36`;
      if (os === 'linux') return `Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Safari/537.36`;
      if (os === 'android') return `Mozilla/5.0 (Linux; Android ${pick(ANDROID_VERS)}; SM-S918B) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Mobile Safari/537.36`;
      return `Mozilla/5.0 (iPhone; CPU iPhone OS ${pick(IOS_VERS)} like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) CriOS/${v} Mobile/15E148 Safari/604.1`;
    }
    if (browser === 'firefox') {
      const v = pick(FF_VERS);
      if (os === 'windows') return `Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:${v}) Gecko/20100101 Firefox/${v}`;
      if (os === 'mac') return `Mozilla/5.0 (Macintosh; Intel Mac OS X ${pick(OSX_VERS).replace(/_/g, '.')}; rv:${v}) Gecko/20100101 Firefox/${v}`;
      if (os === 'linux') return `Mozilla/5.0 (X11; Linux x86_64; rv:${v}) Gecko/20100101 Firefox/${v}`;
      if (os === 'android') return `Mozilla/5.0 (Android ${pick(ANDROID_VERS)}; Mobile; rv:${v}) Gecko/${v} Firefox/${v}`;
      return `Mozilla/5.0 (iPhone; CPU iPhone OS ${pick(IOS_VERS)} like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) FxiOS/${v} Mobile/15E148 Safari/605.1.15`;
    }
    if (browser === 'safari') {
      const v = pick(SAFARI_VERS);
      if (os === 'mac' || os === 'windows' || os === 'linux') return `Mozilla/5.0 (Macintosh; Intel Mac OS X ${pick(OSX_VERS)}) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/${v} Safari/605.1.15`;
      return `Mozilla/5.0 (iPhone; CPU iPhone OS ${pick(IOS_VERS)} like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/${v} Mobile/15E148 Safari/604.1`;
    }
    const v = pick(EDGE_VERS);
    if (os === 'windows' || os === 'linux') return `Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Safari/537.36 Edg/${v}`;
    return `Mozilla/5.0 (Macintosh; Intel Mac OS X ${pick(OSX_VERS)}) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/${v} Safari/537.36 Edg/${v}`;
  }

  const browser = document.getElementById('ua-browser') as HTMLSelectElement;
  const os = document.getElementById('ua-os') as HTMLSelectElement;
  const count = document.getElementById('ua-count') as HTMLInputElement;
  const out = document.getElementById('ua-out') as HTMLTextAreaElement;
  const gen = document.getElementById('ua-gen') as HTMLButtonElement;
  const copy = document.getElementById('ua-copy') as HTMLButtonElement;

  function generate() {
    const n = Math.min(100, Math.max(1, parseInt(count.value || '10', 10)));
    const browsers = ['chrome','firefox','safari','edge'];
    const oses = ['windows','mac','linux','android','ios'];
    const lines: string[] = [];
    for (let i = 0; i < n; i++) {
      const b = browser.value === 'any' ? pick(browsers) : browser.value;
      const o = os.value === 'any' ? pick(oses) : os.value;
      lines.push(build(b, o));
    }
    out.value = lines.join('\n');
  }
  gen.addEventListener('click', generate);
  [browser, os, count].forEach(el => el.addEventListener('change', generate));
  copy.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const icon = copy.querySelector('.copy-icon') as HTMLElement;
    icon.innerHTML = '<span class="copy-toast">✓ Copied</span>';
    copy.dataset.copied = 'true';
    setTimeout(() => { icon.textContent = 'Copy all'; delete copy.dataset.copied; }, 1400);
  });
  generate();
</script>
