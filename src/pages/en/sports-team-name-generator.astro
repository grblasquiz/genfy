---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Sports Team Name Generator | Genfy';
const description = 'Generate unique names for your soccer, volleyball, basketball or any sports team. Mix city, animal or concept and get 20 memorable ideas.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What makes a good team name?', acceptedAnswer: { '@type': 'Answer', text: 'Memorable, easy to chant from the stands, unique in your local league, and looks good on a jersey or crest.' } },
    { '@type': 'Question', name: 'Should I use animals?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, predator or resilient animals (wolves, hawks, bulls) are classics for a reason: they communicate strength and are easy to illustrate.' } },
    { '@type': 'Question', name: 'How do I register it?', acceptedAnswer: { '@type': 'Answer', text: 'For official competition, register with the local federation; for merch, with the USPTO or your country\'s trademark office.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Sports" title="Sports Team Name Generator"
    intro="Mix city, animal or concept and get 20 memorable names for your soccer, volleyball, basketball or any sports team. Ready for crest and jersey.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Keywords (city, color, concept)</label>
      <input id="bn-kw" type="text" placeholder="brooklyn, blue, fire..." value="brooklyn" />

      <label for="bn-style" style="margin-top:1rem">Style</label>
      <select id="bn-style">
        <option value="animal">City + animal (Brooklyn Wolves)</option>
        <option value="historic">Historic (Spartans, Vikings)</option>
        <option value="action">Action (Fire, Storm, Thunder)</option>
        <option value="color">Color + animal (Blue Hawks)</option>
        <option value="local">Local + United / FC</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a team name</h2>
      <p>
        A good team name does three jobs: chants well from the stands, looks great on crest
        and jersey, and differentiates the team from others in the league. What separates
        "Tigers FC" from the thousands of "Tigers" worldwide is the local qualifier, color or
        a concrete identity detail.
      </p>
      <ol>
        <li><strong>Memorable from 50 yards.</strong> What chants well with an open mouth.</li>
        <li><strong>Illustrative.</strong> Has to translate into a simple crest.</li>
        <li><strong>Unique in your league.</strong> Don't blur with the other neighborhood team.</li>
        <li><strong>Historic, not spiritual.</strong> "Spartans" or "Vikings" work; "Olympians" or "Titans" are saturated and mix deities.</li>
        <li><strong>Broadcast-friendly.</strong> If televised, it has to roll off the tongue.</li>
      </ol>

      <h2>Classic styles</h2>
      <ul>
        <li><strong>City + animal:</strong> "Brooklyn Wolves", "Capitol Hawks". Most used for a reason.</li>
        <li><strong>Historic:</strong> "Spartans", "Vikings", "Trojans". Communicates resilience.</li>
        <li><strong>Action:</strong> "Fire", "Storm", "Thunder". Triggers emotion.</li>
        <li><strong>Color + animal:</strong> "Blue Hawks", "Red Wolves". Color + identity.</li>
        <li><strong>Local + United / FC:</strong> "Brooklyn United", "Capitol FC". European premium feel.</li>
      </ul>

      <h2>What to avoid</h2>
      <p>
        Avoid Greek, Roman or Norse deity references: "Olympians", "Titans" or "Thunder Gods"
        are saturated and mix religion with sport. Better historical (Spartans, Trojans,
        Vikings) or natural (wolves, hawks, tigers). Also avoid joke names that age badly.
      </p>

      <h2>Validation</h2>
      <ol>
        <li>Check the local league: any other?</li>
        <li>Test a simple crest: does it work in black and white?</li>
        <li>Try the chant: "let's go X!"</li>
        <li>Print on a T-shirt and ask for feedback.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>What makes a good name?</summary><p>Memorable, easy to chant, unique in league, beautiful on crest.</p></details>
      <details><summary>Animals work?</summary><p>Yes, predators or resilient ones. Wolves, hawks, bulls work.</p></details>
      <details><summary>How to register?</summary><p>Local federation for competition, USPTO for merch.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const ANIMAL = ['Wolves', 'Hawks', 'Tigers', 'Bulls', 'Eagles', 'Pumas', 'Bison', 'Buffaloes', 'Ravens', 'Foxes', 'Boars', 'Lynx'];
  const HIST = ['Spartans', 'Vikings', 'Trojans', 'Centurions', 'Gladiators', 'Knights', 'Warriors', 'Legion', 'Crusaders'];
  const ACTION = ['Fire', 'Storm', 'Thunder', 'Lightning', 'Fury', 'Tempest', 'Wind', 'Avalanche', 'Tide', 'Eruption'];
  const COLOR = ['Blue', 'Red', 'Green', 'Black', 'White', 'Yellow', 'Maroon', 'Sky', 'Amber'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1).toLowerCase(); }
  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const w = kw.value.trim() || 'Brooklyn';
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let name = '';
      if (s === 'animal') name = cap(w) + ' ' + pick(ANIMAL);
      else if (s === 'historic') name = cap(w) + ' ' + pick(HIST);
      else if (s === 'action') name = cap(w) + ' ' + pick(ACTION);
      else if (s === 'color') name = pick(COLOR) + ' ' + pick(ANIMAL);
      else if (s === 'local') name = cap(w) + ' ' + pick(['United', 'FC', 'Athletic', 'City', 'Town']);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
