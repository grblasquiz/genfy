---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Robot Name Generator | Genfy';
const description = 'Generate names for robots, androids and AIs in your story, game or product. Combine alphanumeric codes and model names in seconds.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I name a robot without sounding cliche?', acceptedAnswer: { '@type': 'Answer', text: 'Combine an alphanumeric code (R-X4, K-9) with a functional suffix (Forge, Helix, Sentinel). Avoid overly human names for non-humanoid robots.' } },
    { '@type': 'Question', name: 'Human name or alphanumeric?', acceptedAnswer: { '@type': 'Answer', text: 'Depends on the role. Domestic service bots work with human names. Military or industrial bots feel more believable with codes.' } },
    { '@type': 'Question', name: 'Can I use an existing robot name?', acceptedAnswer: { '@type': 'Answer', text: 'Better not. R2-D2, WALL-E and Bender are trademarked. Invent fresh combinations.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Entertainment" title="Robot Name Generator"
    intro="Generate names for robots, androids and AIs across stories, games and products. Combine alphanumeric codes and model names for 20 ready-to-use ideas.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Function or use (optional)</label>
      <input id="bn-kw" type="text" placeholder="combat, support, exploration..." value="exploration" />

      <label for="bn-style" style="margin-top:1rem">Style</label>
      <select id="bn-style">
        <option value="model">Model code (R-X4 Forge)</option>
        <option value="suffix">Name + number (Helix-9)</option>
        <option value="acronym">Acronym (S.E.N.T.I.N.E.L.)</option>
        <option value="friendly">Human name (Bobby, Klar)</option>
        <option value="industrial">Industrial (Unit-44, Bay-7)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 names</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to name a robot without falling into cliche</h2>
      <p>
        Robot naming has a common trap: copying R2-D2 or WALL-E and assuming any alphanumeric
        code works. The truth is, a good robot name says something about its function. R-X4 Forge
        suggests an industrial bot; Helix-9 suggests a medical assistant. If your name doesn't
        tell you what the robot does, it's incomplete.
      </p>
      <ol>
        <li><strong>Start with function.</strong> Combat, support, domestic, exploration? That sets the tone.</li>
        <li><strong>Pick a consistent format.</strong> If your universe uses code + number, keep it across the fleet.</li>
        <li><strong>Avoid overly human names for non-humanoid bots.</strong> "Thomas" doesn't fit an industrial arm.</li>
        <li><strong>Test in dialogue.</strong> Easy to shout in a tense scene? If not, drop it.</li>
        <li><strong>Check collisions.</strong> Google in exact quotes for famous robots.</li>
      </ol>

      <h2>Robot naming styles</h2>
      <ul>
        <li><strong>Model code</strong>: letter-number + functional suffix (R-X4 Forge, K-2 Sentinel). Military or industrial.</li>
        <li><strong>Name + number</strong>: an evocative word plus a digit (Helix-9, Vortex-3). Good for assistants and explorers.</li>
        <li><strong>Acronym</strong>: each letter has a real meaning (S.E.N.T.I.N.E.L. = System...). Heavy but realistic.</li>
        <li><strong>Short human name</strong>: companion or domestic assistants (Bobby, Klar, Mira).</li>
        <li><strong>Industrial</strong>: Unit-44, Bay-7, Mark-12. Numbered fleets and production.</li>
      </ul>

      <h2>Robot-name mistakes</h2>
      <p>
        Most common: domestic-service robots with military names ("Drone-X9 Forge" is wrong for a
        vacuum). Another: mixing real languages without a system (a "Hikari-Bravo-Sigma" robot
        sounds pretentious). And a third: unpronounceable codes (R-7XK4-Z9F) that the reader
        re-reads every time. A robot name has to roll off the tongue.
      </p>

      <h2>After generating</h2>
      <ol>
        <li>Pick the five that fit the defined function best.</li>
        <li>Confirm easy pronunciation.</li>
        <li>Test command lines: "___, attack!" / "___, scan the area". Does it work?</li>
        <li>Keep coherence: all robots in the same series follow the same pattern.</li>
        <li>Check for franchise collisions.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>How do I name a robot without cliche?</summary><p>Alphanumeric code + functional suffix. Avoid human names for non-humanoid bots.</p></details>
      <details><summary>Human or alphanumeric?</summary><p>Depends on the role: domestic = human, industrial = code.</p></details>
      <details><summary>Can I use existing names?</summary><p>Better not. R2-D2, WALL-E are trademarked.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; transition: border-color 0.1s; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const LET = ['R', 'K', 'X', 'D', 'V', 'M', 'T', 'Z', 'B', 'S'];
  const SUF = ['Forge', 'Sentinel', 'Vector', 'Cipher', 'Helix', 'Pylon', 'Vortex', 'Tracker', 'Drift', 'Echo', 'Patrol', 'Field'];
  const HUM = ['Bobby', 'Klar', 'Mira', 'Tilo', 'Bren', 'Velo', 'Niko', 'Drix'];
  const ROLE = ['Unit', 'Bay', 'Mark', 'Series', 'Block'];
  const ACR = ['S.E.N.T.I.N.E.L.', 'V.E.C.T.O.R.', 'H.E.L.I.X.', 'F.O.R.G.E.', 'D.R.I.F.T.'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function num(max = 99) { const i = new Uint32Array(1); crypto.getRandomValues(i); return (i[0] % max) + 1; }

  function generate() {
    const s = style.value;
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      let name = '';
      if (s === 'model') name = pick(LET) + '-' + pick(LET) + num(9) + ' ' + pick(SUF);
      else if (s === 'suffix') name = pick(SUF) + '-' + num(99);
      else if (s === 'acronym') name = pick(ACR);
      else if (s === 'friendly') name = pick(HUM);
      else if (s === 'industrial') name = pick(ROLE) + '-' + num(99);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
