---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Podcast Episode Title Generator | Genfy';
const description = 'Generate episode titles optimized for Spotify and Apple Podcasts. Mix your topic with proven formats and get 20 ready-to-use ideas.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'How do I pick a good podcast episode title?', acceptedAnswer: { '@type': 'Answer', text: 'Lead with the keyword, make a concrete promise, include the guest name when relevant, and keep it short enough to read on mobile.' } },
    { '@type': 'Question', name: 'Should I include the episode number?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, regulars love it — but never at the start. If "EP 47" leads, Spotify truncates your keyword.' } },
    { '@type': 'Question', name: 'How long should the title be?', acceptedAnswer: { '@type': 'Answer', text: 'Under 60 characters. Spotify and Apple cut at 45-60 depending on device.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Entertainment" title="Podcast Episode Title Generator"
    intro="Generate episode titles optimized for Spotify, Apple Podcasts and YouTube. Mix topic, guest and format for 20 ideas in seconds.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Episode topic</label>
      <input id="bn-kw" type="text" placeholder="productivity, savings, travel..." value="productivity" />

      <label for="bn-style" style="margin-top:1rem">Format</label>
      <select id="bn-style">
        <option value="howto">How to X</option>
        <option value="number">Numbered lists (5 habits for...)</option>
        <option value="guest">With a guest (Martha on X)</option>
        <option value="question">Direct question</option>
        <option value="reaction">Reaction / analysis</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 titles</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>How to title a podcast episode (without losing listeners)</h2>
      <p>
        Episode titles compete in a small list with hundreds of others. Your job is to win the
        click in three seconds. Most useful rule: keyword first. If the user searches "savings",
        your episode "How to save 30% without arguing" wins. "EP 47: Chat with John about money"
        loses.
      </p>
      <ol>
        <li><strong>Keyword first.</strong> What people search goes up front.</li>
        <li><strong>Concrete promise.</strong> "How to sleep better in 7 days" beats "Sleep talk".</li>
        <li><strong>Under 60 characters.</strong> Spotify mobile cuts there.</li>
        <li><strong>Guest names help SEO if known.</strong> Otherwise, lead with the topic.</li>
        <li><strong>Avoid emojis.</strong> They break Apple Podcasts grids.</li>
      </ol>

      <h2>Formats that work in podcast</h2>
      <ul>
        <li><strong>How to X</strong>: most-searched format on Apple and Spotify.</li>
        <li><strong>Numbered lists</strong>: 5 habits, 7 mistakes, 3 lessons. More clicks on YouTube thumbnails.</li>
        <li><strong>With a guest</strong>: Name + topic (Martha Garcia on leadership). Only if the guest is known.</li>
        <li><strong>Question</strong>: Why can't you save? What does your boss do well? Pulls curiosity.</li>
        <li><strong>Reaction / analysis</strong>: what happened with X. Good for current events.</li>
      </ul>

      <h2>Common mistakes</h2>
      <p>
        Most common: leading with episode number or show name. People already know which podcast
        they're in. Another: generic titles ("Episode 4: an interesting talk") that say nothing
        to the algorithm. And a third: putting the guest name at the end, after mobile truncates.
        If the guest matters, lead or near-lead with their name.
      </p>

      <h2>After generating</h2>
      <ol>
        <li>Confirm under 60 characters.</li>
        <li>Test on Spotify mobile: does it read fully?</li>
        <li>Compare to three competing titles on the same topic. Does yours win the click?</li>
        <li>Add the episode number at the end, never the start.</li>
        <li>Stay consistent — repeat listeners recognize your style.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>How do I pick a good title?</summary><p>Keyword first, concrete promise, under 60 chars.</p></details>
      <details><summary>Episode number?</summary><p>Yes, but at the end.</p></details>
      <details><summary>How long?</summary><p>Under 60 characters.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.75rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 500; cursor: pointer; transition: border-color 0.1s; line-height: 1.4; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const HOWTO = ['How to X', 'How to stop X', 'How to start with X', 'How to master X in 30 days', 'How to X without burning out'];
  const NUM = ['5 habits for X', '7 mistakes with X', '3 lessons on X', '10 truths about X', '4 myths about X'];
  const GUEST = ['Martha on X', 'John Garcia: how to X', 'Sophie explains X', 'Paul and X: the truth', 'Camille: what I learned from X'];
  const Q = ['Why does nobody talk about X?', 'What happened with X?', 'Does X really work?', 'When to stop X?', 'How do you know it is X?'];
  const REACT = ['What I learned about X', 'X changed how I work', 'My take on X', 'Why X matters today'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const topic = kw.value.trim() || 'productivity';
    const s = style.value;
    let SRC: string[];
    if (s === 'number') SRC = NUM;
    else if (s === 'guest') SRC = GUEST;
    else if (s === 'question') SRC = Q;
    else if (s === 'reaction') SRC = REACT;
    else SRC = HOWTO;
    out.innerHTML = '';
    const set = new Set<string>();
    let attempts = 0;
    while (set.size < 20 && attempts < 200) {
      attempts++;
      const t = pick(SRC).replace(/X/g, topic);
      set.add(t);
    }
    [...set].forEach(text => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = text;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(text); const orig = el.textContent; el.textContent = '✓ copied'; setTimeout(() => el.textContent = orig, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
