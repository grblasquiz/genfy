---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Theater Play Title Generator | Genfy';
const description = 'Generate stage play titles for drama, comedy, musical and kids theater. Catchy ideas ready for marquee, program or pitch.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What makes a good play title?', acceptedAnswer: { '@type': 'Answer', text: 'A strong title hints at tone, genre and conflict in a few words. It works if the audience can repeat it and it fits on a marquee.' } },
    { '@type': 'Question', name: 'How long should the title be?', acceptedAnswer: { '@type': 'Answer', text: 'Between 2 and 6 words is ideal. Longer becomes hard to remember and to print on programs, posters or tickets.' } },
    { '@type': 'Question', name: 'Can I register it?', acceptedAnswer: { '@type': 'Answer', text: 'Short titles are hard to trademark, but you can register the full script with the Dramatists Guild, the Library of Congress or your country IP office.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Creative" title="Theater Play Title Generator"
    intro="Mix genre, theme and structure to land memorable titles. Works for drama, comedy, musical and kids theater.">

    <div slot="tool" class="tt">
      <label for="tt-genre">Genre</label>
      <select id="tt-genre">
        <option value="drama">Drama</option>
        <option value="comedy">Comedy</option>
        <option value="musical">Musical</option>
        <option value="kids">Kids</option>
      </select>

      <label for="tt-tema" style="margin-top:1rem">Central theme (word)</label>
      <input id="tt-tema" type="text" value="silence" placeholder="love, debt, journey..." />

      <button id="tt-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 20 titles</button>
      <div id="tt-out" class="tt-out"></div>
    </div>

    <div slot="content">
      <h2>What makes a play title work</h2>
      <p>A good title does three jobs: anticipates tone, hints at the conflict and sticks in the audience's head. "Death of a Salesman" announces tragedy and a profession. "The Play That Goes Wrong" promises comedy in one phrase. "Hamilton" leans on a name with weight. If your title can't answer at least one of those questions in five words, it's leaning too abstract.</p>
      <h2>Structures that work on a marquee</h2>
      <ol>
        <li><strong>Concrete noun + adjective:</strong> "The Blue Room", "The Lost Letter".</li>
        <li><strong>Question or short phrase:</strong> "Who Killed Paul?", "Waiting for Rain".</li>
        <li><strong>Proper name:</strong> "Marta", "Antigone". Symbolic load if the name carries it.</li>
        <li><strong>Three words + rhythm:</strong> "Glass, Sea, Hollow". More poetic, suits experimental theater.</li>
        <li><strong>Phrase with double meaning:</strong> great for comedy and musical.</li>
      </ol>
      <h2>Mistakes that sink a title before opening night</h2>
      <ul>
        <li><strong>Too abstract:</strong> "To Exist". Doesn't sell tickets, communicates nothing.</li>
        <li><strong>Too long:</strong> the marquee designer will hate you and the audience won't remember it on the way out.</li>
        <li><strong>Cloned from a famous play:</strong> Google first. If the top three results are another show, change it.</li>
        <li><strong>Mixed genres:</strong> a serious title with comedy wink confuses. Stay coherent with the actual content.</li>
      </ul>
      <h2>Adapting the title to the format</h2>
      <p>For independent theater, short, poetic titles work best on social and flyers. For commercial theater, prefer descriptive titles that signal genre ("The Dinner Party"). For musicals, add rhythm and a musical or emotional reference. For kids theater, concrete words and alliteration: "Sammy the Sleepy Snake", "Lila and the Lemon Tree".</p>
      <h2>Validation before printing</h2>
      <p>Once chosen, run this test: ask three people to read the title and say what kind of show they expect. If all three nail the tone, you're fine. If two say "comedy" and you wrote a drama, the title is lying. Change it before printing 500 programs.</p>
    </div>

    <div slot="faq">
      <details><summary>What makes a good title?</summary><p>It hints at tone, genre and conflict in a few words and reads on a marquee.</p></details>
      <details><summary>How long should it be?</summary><p>2 to 6 words is the sweet spot.</p></details>
      <details><summary>Can I register it?</summary><p>The full script can be registered with the Library of Congress; short titles are hard to trademark.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .tt-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .tt-item { padding: 0.75rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; }
  .tt-item:hover { border-color: var(--primary); }
</style>

<script>
  const D_NOUN = ['Room', 'Silence', 'Shadow', 'Threshold', 'Winter', 'Door', 'Echo', 'Hollow', 'Map', 'Clock', 'Garden', 'House'];
  const D_ADJ = ['Lost', 'Dark', 'Closed', 'Final', 'Broken', 'Cold', 'Mute', 'Late', 'Distant', 'Quiet'];
  const C_PHRASE = ['Knock Knock, Who Opened', "Don't Call Me Charles", 'Five Minutes Before', 'Two Old Men in the Lift', 'The Wednesday Dinner'];
  const M_NOUN = ['Song', 'Festival', 'Cabaret', 'Dance', 'Waltz', 'Tango', 'Lullaby', 'Piano'];
  const KIDS = ['The Frog', 'The Cloud', 'The Balloon', 'The Mice', 'The Pirate', 'The Mermaid', 'The Fox', 'The Firefly'];
  const KIDS_TAIL = ['who lost his voice', 'and the borrowed moon', 'in the sleeping forest', 'who wanted to fly', 'of the blue rooftop', 'who counted to ten'];

  const genre = document.getElementById('tt-genre') as HTMLSelectElement;
  const tema = document.getElementById('tt-tema') as HTMLInputElement;
  const gen = document.getElementById('tt-gen') as HTMLButtonElement;
  const out = document.getElementById('tt-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function cap(s: string) { return s.charAt(0).toUpperCase() + s.slice(1); }

  function generate() {
    const g = genre.value;
    const t = (tema.value || '').trim().toLowerCase();
    const set = new Set<string>(); let tries = 0;
    while (set.size < 20 && tries < 200) {
      tries++;
      let title = '';
      if (g === 'drama') {
        const variants = [
          `The ${pick(D_ADJ)} ${pick(D_NOUN)}`,
          `${cap(t || pick(D_NOUN))} at the Threshold`,
          `The House of ${pick(D_NOUN)}`,
          `${pick(D_NOUN)}, ${pick(D_NOUN)}, ${pick(D_NOUN)}`,
          `Before ${pick(D_NOUN)}`,
        ];
        title = pick(variants);
      } else if (g === 'comedy') {
        const variants = [...C_PHRASE, `My ${pick(D_NOUN)} and I`, `${cap(t || 'Paul')} Wasn't Invited`, `How to Lose a ${pick(D_NOUN)} in 90 Minutes`];
        title = pick(variants);
      } else if (g === 'musical') {
        title = `The ${pick(M_NOUN)} of ${cap(t || pick(D_NOUN))}`;
      } else {
        title = `${pick(KIDS)} ${pick(KIDS_TAIL)}`;
      }
      set.add(title);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'tt-item'; el.textContent = n; el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
