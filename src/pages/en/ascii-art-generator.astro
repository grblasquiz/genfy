      P:['_ ','|_)','|  '],
      Q:[' _ ','/ \\','\\_X'],
      R:['_ ','|_)','| \\'],
      S:[' _','(_',' _)'],
      T:['___',' | ',' | '],
      U:['| |','| |','\\_/'],
      V:['\\ /','\\ /',' V '],
      W:['|  |','|/\\|','/  \\'],
      X:['\\ /',' X ','/ \\'],
      Y:['\\ /',' V ',' | '],
      Z:['___',' / ','/__'],
      ' ':['  ','  ','  '],
      '0':[' _ ','/ \\','\\_/'],
      '1':[' /|','  |','  |'],
      '2':[' _ ',' _)','/__'],
      '3':[' _ ',' _)',' _)'],
      '4':['| |','|_|','  |'],
      '5':[' _ ','|_ ',' _)'],
      '6':[' _ ','|_ ','|_)'],
      '7':['___','  /',' / '],
      '8':[' _ ','(_)','(_)'],
      '9':[' _ ','(_|','  |'],
    },
  };

  const textEl = document.getElementById('aa-text') as HTMLInputElement;
  const fontEl = document.getElementById('aa-font') as HTMLSelectElement;
  const out = document.getElementById('aa-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('aa-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('aa-copy') as HTMLButtonElement;

  function generate() {
    const txt = (textEl.value || '').toUpperCase().slice(0, 20);
    const font = FONTS[fontEl.value];
    if (!font) { out.value = ''; return; }
    const rows = (font['A'] || []).length;
    const lines: string[] = [];
    for (let r = 0; r < rows; r++) {
      let line = '';
      for (const ch of txt) {
        const glyph = font[ch] || font[' '];
        line += (glyph[r] || '') + '  ';
      }
      lines.push(line);
    }
    out.value = lines.join('\n');
  }

  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent;
    copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
