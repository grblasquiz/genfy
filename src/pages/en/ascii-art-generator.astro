      F:['███████','██     ','█████  ','██     ','██     '],
      G:[' ██████','██     ','██  ███','██   ██',' ██████'],
      H:['██   ██','██   ██','███████','██   ██','██   ██'],
      I:['██','██','██','██','██'],
      J:['     ██','     ██','     ██','██   ██',' █████ '],
      K:['██  ██ ','██ ██  ','████   ','██ ██  ','██  ██ '],
