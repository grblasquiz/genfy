---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';

const title = 'Free Invoice Number Generator | Genfy';
const description = 'Generate professional invoice numbers: sequential with prefix and year, random or with checksum. Useful for freelancers, SMBs and agencies.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'What is the most common format?', acceptedAnswer: { '@type': 'Answer', text: 'INV-YYYY-#### is the international standard: "INV" prefix, year, and a zero-padded sequential number. A-2026-0001 is also common when multiple series exist.' } },
    { '@type': 'Question', name: 'Can invoice numbers skip values?', acceptedAnswer: { '@type': 'Answer', text: 'It depends on jurisdiction. In most countries invoicing must be sequential for tax audit purposes. Confirm with your accountant.' } },
    { '@type': 'Question', name: 'What is the checksum for?', acceptedAnswer: { '@type': 'Answer', text: 'It detects typos when someone transcribes the invoice number. Useful for automated billing systems and payment portals.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="en" tag="Work" title="Invoice Number Generator"
    intro="Build invoice number formats ready to use: prefix, year, sequential or random. Great for freelancers, SMBs and agencies.">

    <div slot="tool" class="iv">
      <div class="iv-row">
        <div>
          <label for="iv-prefix">Prefix</label>
          <input id="iv-prefix" type="text" value="INV" maxlength="6" />
        </div>
        <div>
          <label for="iv-year">Year</label>
          <input id="iv-year" type="number" value="2026" min="2000" max="2100" />
        </div>
        <div>
          <label for="iv-pad">Sequential digits</label>
          <input id="iv-pad" type="number" value="4" min="3" max="8" />
        </div>
      </div>
      <div class="iv-row">
        <div>
          <label for="iv-mode">Mode</label>
          <select id="iv-mode">
            <option value="seq">Sequential</option>
            <option value="random">Random</option>
            <option value="checksum">With checksum</option>
          </select>
        </div>
        <div>
          <label for="iv-start">Start (sequential)</label>
          <input id="iv-start" type="number" value="1" min="1" />
        </div>
        <div>
          <label for="iv-amount">Amount</label>
          <input id="iv-amount" type="number" value="10" min="1" max="100" />
        </div>
      </div>
      <button id="iv-gen" class="btn btn-primary" type="button">Generate</button>
      <button id="iv-copy" class="btn btn-ghost" type="button">Copy</button>
      <textarea id="iv-out" rows="12" readonly style="margin-top:1rem; font-family: var(--font-mono);"></textarea>
    </div>

    <div slot="content">
      <h2>How to choose a professional format</h2>
      <p>
        The invoice number isn't a cosmetic detail: it's the key that ties your bookkeeping,
        your AR system and your tax audit together. The most widespread standard is
        <strong>INV-YYYY-####</strong>: "INV" prefix, four-digit year, and a zero-padded
        sequence (0001, 0002, etc.). It's readable, sorts chronologically, and leaves room for
        up to 9,999 invoices per year. Above that, expand to 5 digits.
      </p>

      <h2>Generator modes</h2>
      <ul>
        <li><strong>Sequential.</strong> The standard for legal invoicing: starts at the number you choose and adds 1.</li>
        <li><strong>Random.</strong> Useful for quotes, internal POs or test data, where there's no sequential requirement.</li>
        <li><strong>With checksum.</strong> Adds a final digit calculated by Luhn (the same as credit cards) to detect transcription errors.</li>
      </ul>

      <h2>Why invoicing is sequential</h2>
      <p>
        In the US (state requirements vary), UK (HMRC), Spain (Hacienda), Mexico (SAT) and
        most jurisdictions, invoicing has to be sequential. If you issued INV-2026-0005, the
        next has to be INV-2026-0006. Skipping or reusing numbers raises tax audit flags. So
        the sequential mode is correct for your official ledger; random is for internal docs.
      </p>

      <h2>The checksum (Luhn) and why</h2>
      <p>
        Luhn appends a digit calculated from the rest of the number. If someone mistypes a
        digit (or swaps two), the checksum doesn't validate and the system rejects the entry
        before processing. Same principle as credit cards and European IBANs. It's not crypto
        security — it's a guard against human error.
      </p>

      <h2>Best practices</h2>
      <ol>
        <li><strong>Reset the sequence each year.</strong> Easier to archive and report.</li>
        <li><strong>Use series per document type.</strong> Invoice, credit note, quote, receipt — each with its prefix and counter.</li>
        <li><strong>Keep a central registry.</strong> Spreadsheet or system. Knowing your next number prevents duplicates.</li>
        <li><strong>Don't embed customer data in the number.</strong> Keep it neutral; the customer goes in the body, not in the ID.</li>
        <li><strong>Backup.</strong> If your system goes down, you want to know where the numbering left off. Export your series monthly.</li>
      </ol>

      <h2>Ready-to-copy formats</h2>
      <ul>
        <li><code>INV-2026-0001</code> — Anglo standard.</li>
        <li><code>2026/000001</code> — Simple European format, year/sequence.</li>
        <li><code>2026-0001-A</code> — When you have multiple series.</li>
        <li><code>INV0001-2026</code> — When the sequence is the focus.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>Common format?</summary><p>INV-YYYY-####: prefix, year, zero-padded sequence.</p></details>
      <details><summary>Can numbers skip?</summary><p>Most jurisdictions require sequential numbering. Check with your accountant.</p></details>
      <details><summary>Why checksum?</summary><p>To catch transcription errors in automated billing systems.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .iv-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .iv-row { grid-template-columns: 1fr; } }
</style>

<script>
  const prefixEl = document.getElementById('iv-prefix') as HTMLInputElement;
  const yearEl = document.getElementById('iv-year') as HTMLInputElement;
  const padEl = document.getElementById('iv-pad') as HTMLInputElement;
  const modeEl = document.getElementById('iv-mode') as HTMLSelectElement;
  const startEl = document.getElementById('iv-start') as HTMLInputElement;
  const amountEl = document.getElementById('iv-amount') as HTMLInputElement;
  const out = document.getElementById('iv-out') as HTMLTextAreaElement;
  const genBtn = document.getElementById('iv-gen') as HTMLButtonElement;
  const copyBtn = document.getElementById('iv-copy') as HTMLButtonElement;

  function rint(max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return i[0] % max; }
  function pad(n: number, w: number) { return String(n).padStart(w, '0'); }
  function luhnCheckDigit(num: string): string {
    let sum = 0; let alt = false;
    for (let i = num.length - 1; i >= 0; i--) {
      let d = parseInt(num.charAt(i), 10);
      if (alt) { d *= 2; if (d > 9) d -= 9; }
      sum += d; alt = !alt;
    }
    return String((10 - (sum % 10)) % 10);
  }
  function generate() {
    const prefix = (prefixEl.value || 'INV').toUpperCase();
    const year = parseInt(yearEl.value || '2026', 10);
    const pad_ = Math.max(3, Math.min(8, parseInt(padEl.value || '4', 10)));
    const mode = modeEl.value;
    const start = Math.max(1, parseInt(startEl.value || '1', 10));
    const n = Math.max(1, Math.min(100, parseInt(amountEl.value || '10', 10)));
    const arr: string[] = [];
    for (let i = 0; i < n; i++) {
      let core = '';
      if (mode === 'seq') core = pad(start + i, pad_);
      else core = pad(rint(Math.pow(10, pad_)), pad_);
      let id = `${prefix}-${year}-${core}`;
      if (mode === 'checksum') {
        const digits = (year + core).replace(/\D/g, '');
        id = `${prefix}-${year}-${core}-${luhnCheckDigit(digits)}`;
      }
      arr.push(id);
    }
    out.value = arr.join('\n');
  }
  genBtn.addEventListener('click', generate);
  copyBtn.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const t = copyBtn.textContent; copyBtn.textContent = 'Copied!';
    setTimeout(() => { copyBtn.textContent = t; }, 1200);
  });
  generate();
</script>
