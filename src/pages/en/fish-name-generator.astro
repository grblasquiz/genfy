---
import Layout from '../../layouts/Layout.astro';
import GeneratorShell from '../../components/GeneratorShell.astro';
import { FISH_NAMES, AQUATIC_STYLES } from '../../lib/aquatic-names';

const title = 'Fish Name Generator | Genfy';
const description = 'By color, cute or funny: find the perfect name for your fish. 60+ ideas in English and Spanish — free instant generator.';
const stylesEN = { color: AQUATIC_STYLES.en.color, cute: AQUATIC_STYLES.en.cute, funny: AQUATIC_STYLES.en.funny };

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: 'Is it worth naming a fish?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Fish don\'t learn names, but they associate your voice with food, which reduces stress when you approach the tank.' } },
    { '@type': 'Question', name: 'How do I name an orange fish?', acceptedAnswer: { '@type': 'Answer', text: 'By color: Goldie, Tangerine, Coral, Pumpkin. Or by personality: Splash if active, Calm if mellow.' } },
    { '@type': 'Question', name: 'Serious or funny names for fish?', acceptedAnswer: { '@type': 'Answer', text: 'Funny tends to win for fish — they\'re the most visual pet to play with. Sushi, Bubbles, Captain Bubbles all work.' } },
  ],
};
---
<Layout title={title} description={description} lang="en" withSidebar={true} schema={faqSchema}>
  <GeneratorShell lang="en" tag="Pets" title="Fish Name Generator"
    intro="By color, cute or funny: find the name that fits your fish best. Click and get 12 fresh ideas in seconds.">

    <div slot="tool" class="cn">
      <label for="cn-style">Style</label>
      <select id="cn-style">
        {Object.entries(stylesEN).map(([k, v]) => <option value={k}>{v}</option>)}
        <option value="all">Mix of all</option>
      </select>
      <button id="cn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generate 12 names</button>
      <div id="cn-out" class="cn-out"></div>
    </div>

    <div slot="content">
      <h2>How to pick a fish name</h2>
      <p>
        Fish don't learn their names like dogs do, but the name still matters: you'll say it when
        showing them to guests, write it on notes for whoever feeds them while you're away, and
        you'll talk to the tank more than you think. A few tips:
      </p>
      <ul>
        <li><strong>By color or look.</strong> Most common pick for fish. Goldie, Coral, Silver, Spot — direct and memorable.</li>
        <li><strong>By personality.</strong> Hyperactive swimmer: Splash. Floats calmly: Calm. Hides: Shy.</li>
        <li><strong>By species.</strong> A combative betta deserves a name with presence. A tiny tetra works with something sweet.</li>
        <li><strong>Short wins.</strong> Especially if you have several — long names get confused fast.</li>
      </ul>

      <h2>Names by style</h2>
      <ul>
        <li><strong>By color</strong> (Goldie, Silver, Coral, Bubbles, Inky): classic, descriptive, easy to remember.</li>
        <li><strong>Cute</strong> (Bubbles, Finny, Pip, Mochi): perfect for tiny or colorful fish.</li>
        <li><strong>Funny</strong> (Sushi, Sashimi, Captain Bubbles, Fishstick): for people with a sense of humor.</li>
      </ul>

      <h2>Trends in fish names</h2>
      <p>
        US and UK aquarium forums and pet stores show that the top names for goldfish are Goldie,
        Sushi, Bubbles, Coral and Splash. For bettas, names with presence (King, Captain, Rex) and
        color names (Bluey, Inky) lead the lists. For schooling fish, most owners don't name them
        individually — they use collectives ("the boys", "the stripes").
      </p>

      <h2>Common mistakes</h2>
      <ol>
        <li>Long names for fish you can barely tell apart.</li>
        <li>Cooking-related names on fragile species like bettas — feels cute, but ages weird if the fish is short-lived.</li>
        <li>Not writing down which fish has which name when you have several.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>Is it worth naming a fish?</summary><p>Yes. Fish don't learn names, but they associate your voice with food, which reduces stress when you approach the tank.</p></details>
      <details><summary>How do I name an orange fish?</summary><p>By color: Goldie, Tangerine, Coral, Pumpkin. Or by personality.</p></details>
      <details><summary>Serious or funny names for fish?</summary><p>Funny tends to win for fish. Sushi, Bubbles, Captain Bubbles work.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .cn-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .cn-item { padding: 0.625rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; text-align: center; cursor: pointer; transition: border-color 0.1s; }
  .cn-item:hover { border-color: var(--primary); }
</style>

<script define:vars={{ DATA: FISH_NAMES }}>
  const styleEl = document.getElementById('cn-style');
  const out = document.getElementById('cn-out');
  const gen = document.getElementById('cn-gen');

  function pick(arr) { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }

  function generate() {
    const s = styleEl.value;
    let pool = [];
    if (s === 'all') pool = [...DATA.color.en, ...DATA.cute.en, ...DATA.funny.en];
    else pool = DATA[s].en;
    const set = new Set();
    let attempts = 0;
    while (set.size < Math.min(12, pool.length) && attempts < 200) { attempts++; set.add(pick(pool)); }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'cn-item';
      el.textContent = n;
      el.title = 'Click to copy';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
