---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Problema matemático aleatorio | Genfy';
const description = 'Generá problemas matemáticos al azar. Suma, resta, multiplicación, división. Niveles de dificultad para chicos y adultos.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Para qué sirve un generador de problemas?', acceptedAnswer: { '@type': 'Answer', text: 'Para practicar cálculo mental, preparar fichas escolares, ejercitar agilidad numérica y entrenar para exámenes.' } },
    { '@type': 'Question', name: '¿Qué operaciones incluye?', acceptedAnswer: { '@type': 'Answer', text: 'Suma, resta, multiplicación y división, con tres niveles de dificultad para adaptar a edad y nivel.' } },
    { '@type': 'Question', name: '¿Muestra la respuesta?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. Podés mostrar u ocultar la respuesta para usarla como autoevaluación o como ficha imprimible.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Educación" title="Problema matemático aleatorio"
    intro="Generá problemas matemáticos al azar para practicar cálculo mental. Tres niveles de dificultad y cuatro operaciones. Ideal para chicos, docentes y adultos que quieran mantener la agilidad.">

    <div slot="tool">
      <div class="rw-row">
        <div>
          <label for="mp-op">Operación</label>
          <select id="mp-op">
            <option value="all">Mezcla</option>
            <option value="add">Suma</option>
            <option value="sub">Resta</option>
            <option value="mul">Multiplicación</option>
            <option value="div">División</option>
          </select>
        </div>
        <div>
          <label for="mp-lvl">Dificultad</label>
          <select id="mp-lvl">
            <option value="easy">Fácil</option>
            <option value="med" selected>Media</option>
            <option value="hard">Difícil</option>
          </select>
        </div>
      </div>
      <div style="margin-top:0.75rem;">
        <button id="mp-go" class="btn btn-primary" type="button">Nuevo problema</button>
        <button id="mp-show" class="btn btn-ghost" type="button">Mostrar respuesta</button>
      </div>
      <div id="mp-out" class="mp-out" aria-live="polite"></div>
    </div>

    <div slot="content">
      <h2>Por qué la matemática mental sigue siendo importante</h2>
      <p>
        Existen calculadoras en cada teléfono, pero la agilidad mental para hacer cuentas rápidas no es
        obsoleta: te ayuda en la negociación de un precio, al dividir la cuenta en un restaurante, al
        validar si un descuento publicitado realmente conviene. Más importante: la práctica numérica
        regular mantiene flexibilidad cognitiva, atención y memoria de trabajo. Es ejercicio para el
        cerebro.
      </p>

      <h2>Los tres niveles del generador</h2>
      <ul>
        <li><strong>Fácil</strong> — números de un dígito (suma y resta hasta 20, multiplicación hasta 5x5). Ideal para primer ciclo de primaria.</li>
        <li><strong>Media</strong> — dos dígitos en suma/resta, tablas hasta 10. Segundo y tercer ciclo de primaria, repaso adulto.</li>
        <li><strong>Difícil</strong> — dos a tres dígitos, multiplicaciones grandes, divisiones con resto. Secundaria, preparación de exámenes y desafíos para adultos.</li>
      </ul>

      <h2>Para docentes</h2>
      <p>
        Generar fichas de ejercicios manualmente es trabajo lento. Con esta herramienta podés crear 30
        problemas en 30 segundos, copiarlos en un documento y tener la guía lista. Como cada problema es
        aleatorio, no hay dos hojas iguales — útil cuando querés evitar que los chicos copien entre ellos.
        También sirve como "kit de calentamiento" al inicio de la clase: cinco problemas mientras se
        sientan y abren los útiles.
      </p>

      <h2>Para padres en casa</h2>
      <p>
        Una rutina simple: cinco problemas por día, tres veces por semana. En un mes, los chicos mejoran
        notoriamente velocidad y precisión. Importante: no cronometres al principio — la velocidad sale
        después de la confianza. Primero que se sientan capaces, después que sean rápidos. Si un nivel se
        siente cómodo durante una semana, subí al siguiente.
      </p>

      <h2>Para adultos</h2>
      <p>
        Si llevás años usando solo calculadora, la agilidad numérica se atrofia. Recuperarla toma poco:
        cinco minutos diarios durante un mes. Empezá en nivel medio, salí al difícil cuando sientas
        comodidad. Los beneficios cognitivos se han documentado en estudios sobre prevención de deterioro:
        ejercicio aritmético regular se asocia a mejor performance en tareas atencionales.
      </p>

      <h2>Trucos de cálculo mental</h2>
      <ul>
        <li><strong>Suma con redondeo</strong> — para 47+38, hacé 50+38=88 y restá 3 = 85.</li>
        <li><strong>Multiplicar por 5</strong> — multiplicá por 10 y dividí por 2: 36x5 = 360/2 = 180.</li>
        <li><strong>Multiplicar por 11</strong> — sumá los dígitos y poné el resultado al medio: 23x11 = 2(2+3)3 = 253.</li>
        <li><strong>Cuadrados terminados en 5</strong> — el dígito por (dígito+1), pegá 25: 35² = 3x4=12, pegá 25 → 1225.</li>
        <li><strong>División por 9</strong> — restá 1 al dividendo, sumá los dígitos para verificar.</li>
      </ul>

      <h2>Cuándo no insistir</h2>
      <p>
        Si un alumno se traba mucho en un nivel, bajalo. Frustrarse a los 8 años con problemas que no puede
        resolver crea aversión a la matemática que dura décadas. Mejor que tenga éxito en nivel fácil un
        mes y suba con confianza, que se trabe en medio y odie la materia. La progresión es psicológica
        antes que cognitiva.
      </p>

      <h2>Una nota sobre cálculo y currículum</h2>
      <p>
        Los planes educativos modernos tienden a desplazar el cálculo mental hacia menos peso, a favor del
        razonamiento abstracto. Es una tendencia razonable: la matemática es más que aritmética. Pero la
        aritmética sigue siendo el ladrillo: sin agilidad numérica, los conceptos posteriores se hacen más
        difíciles porque la memoria de trabajo se gasta en los cálculos básicos. Una rutina ligera de
        ejercicio aritmético complementa cualquier programa.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Para qué sirve un generador de problemas?</summary><p>Práctica de cálculo mental, fichas escolares, exámenes, agilidad numérica.</p></details>
      <details><summary>¿Qué operaciones incluye?</summary><p>Suma, resta, multiplicación y división con tres niveles de dificultad.</p></details>
      <details><summary>¿Muestra la respuesta?</summary><p>Sí, podés mostrarla u ocultarla según uso (autoevaluación o ficha imprimible).</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .rw-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; align-items: end; }
  .mp-out { margin-top: 1rem; padding: 1.5rem; background: var(--bg-soft, #f5f5f7); border-radius: var(--radius-md, 8px); font-family: var(--font-mono); font-size: 1.5rem; min-height: 5rem; text-align: center; }
  @media (max-width: 600px) { .rw-row { grid-template-columns: 1fr; } }
</style>

<script>
  const opEl = document.getElementById('mp-op') as HTMLSelectElement;
  const lvlEl = document.getElementById('mp-lvl') as HTMLSelectElement;
  const out = document.getElementById('mp-out') as HTMLDivElement;
  const go = document.getElementById('mp-go') as HTMLButtonElement;
  const show = document.getElementById('mp-show') as HTMLButtonElement;
  let answer = 0;
  let problemHTML = '';

  function rint(min: number, max: number) { const i = new Uint32Array(1); crypto.getRandomValues(i); return min + (i[0] % (max - min + 1)); }
  function gen() {
    const lvl = lvlEl.value;
    let op = opEl.value;
    if (op === 'all') op = ['add','sub','mul','div'][rint(0,3)];
    let a = 0, b = 0, sym = '', res = 0;
    if (op === 'add') {
      if (lvl === 'easy') { a = rint(1,10); b = rint(1,10); }
      else if (lvl === 'med') { a = rint(10,50); b = rint(10,50); }
      else { a = rint(100,500); b = rint(100,500); }
      sym = '+'; res = a + b;
    } else if (op === 'sub') {
      if (lvl === 'easy') { a = rint(5,15); b = rint(1,a); }
      else if (lvl === 'med') { a = rint(20,80); b = rint(1,a); }
      else { a = rint(200,800); b = rint(50,a); }
      sym = '−'; res = a - b;
    } else if (op === 'mul') {
      if (lvl === 'easy') { a = rint(2,5); b = rint(2,5); }
      else if (lvl === 'med') { a = rint(2,10); b = rint(2,10); }
      else { a = rint(11,25); b = rint(2,15); }
      sym = '×'; res = a * b;
    } else {
      const divr = lvl === 'easy' ? rint(2,5) : lvl === 'med' ? rint(2,10) : rint(3,12);
      const quo = lvl === 'easy' ? rint(2,5) : lvl === 'med' ? rint(2,12) : rint(10,30);
      a = divr * quo; b = divr;
      sym = '÷'; res = quo;
    }
    answer = res;
    problemHTML = `${a} ${sym} ${b} = ?`;
    out.textContent = problemHTML;
  }
  go.addEventListener('click', gen);
  show.addEventListener('click', () => { out.textContent = problemHTML.replace('?', String(answer)); });
  gen();
</script>
