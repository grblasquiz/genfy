---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de tema de conversación gratis | Genfy';
const description = 'Generá temas para empezar conversaciones interesantes en cenas, citas, dinámicas grupales o entrevistas. 15 ideas listas al instante.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cómo arranco una conversación interesante?', acceptedAnswer: { '@type': 'Answer', text: 'Evitá las preguntas cerradas (sí/no) y las del clima. Empezá con preguntas abiertas que requieran una historia personal corta.' } },
    { '@type': 'Question', name: '¿Sirve para citas?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. La clave en una cita es alternar entre temas livianos y temas que revelen valores, sin entrar de golpe en lo personal.' } },
    { '@type': 'Question', name: '¿Cómo evito que la conversación se caiga?', acceptedAnswer: { '@type': 'Answer', text: 'Hacé seguimiento de las respuestas con preguntas más profundas. Lo que mata una conversación es saltar de tema en tema sin escuchar.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Entretenimiento" title="Generador de tema de conversación"
    intro="Encontrá temas para arrancar conversaciones en cenas, citas, dinámicas grupales o entrevistas. Generá 15 preguntas o disparadores listos para usar.">

    <div slot="tool" class="bn">
      <label for="bn-kw">Contexto (opcional)</label>
      <input id="bn-kw" type="text" placeholder="cena, primera cita, oficina..." value="cena" />

      <label for="bn-style" style="margin-top:1rem">Profundidad</label>
      <select id="bn-style">
        <option value="light">Liviano (rompehielos)</option>
        <option value="medium">Medio (intereses)</option>
        <option value="deep">Profundo (valores)</option>
        <option value="creative">Creativo (hipotético)</option>
      </select>

      <button id="bn-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 15 temas</button>

      <div id="bn-out" class="bn-out"></div>
    </div>

    <div slot="content">
      <h2>Cómo arrancar una conversación que enganche</h2>
      <p>
        Una buena conversación no se trata de hablar bien: se trata de hacer las preguntas
        adecuadas en el momento adecuado. La diferencia entre una cena memorable y una
        olvidable casi siempre está en quién hace la primera pregunta no genérica. "¿Qué hacés?"
        es una pregunta que cierra. "¿Qué fue lo último que te enganchó tanto que perdiste la
        noción del tiempo?" es una pregunta que abre.
      </p>
      <ol>
        <li><strong>Evitá preguntas cerradas.</strong> Las que se contestan con sí o no matan la conversación.</li>
        <li><strong>Buscá preguntas que pidan una historia.</strong> Las mejores conversaciones se dan cuando alguien narra algo personal corto.</li>
        <li><strong>Hacé seguimiento.</strong> No saltes de tema. Profundizá en lo que el otro dijo.</li>
        <li><strong>Mostrá curiosidad real.</strong> La gente nota cuándo estás esperando tu turno para hablar.</li>
        <li><strong>Compartí algo propio.</strong> Una buena conversación es ida y vuelta. No interrogues.</li>
      </ol>

      <h2>Niveles de profundidad de tema</h2>
      <ul>
        <li><strong>Livianos (rompehielos)</strong>: comida, viajes recientes, recomendaciones de series, hobbies. Útiles para los primeros 10 minutos.</li>
        <li><strong>Medios (intereses)</strong>: proyectos personales, libros que cambian, decisiones recientes. Ideales para construir confianza.</li>
        <li><strong>Profundos (valores)</strong>: prioridades de vida, cambios importantes, definiciones personales. Reservar para cuando hay confianza previa.</li>
        <li><strong>Creativos (hipotéticos)</strong>: "si tuvieras que…", "qué harías si…". Funcionan para grupos y dinámicas.</li>
      </ul>

      <h2>Errores frecuentes en conversación</h2>
      <p>
        El más común: empezar con preguntas demasiado profundas a personas que recién conocés.
        "¿Cuál fue el peor momento de tu vida?" en una primera cita arruina cualquier velada.
        Otro error: no escuchar y volver siempre al propio tema. La gente nota cuando estás
        esperando tu turno. Y un tercero: opinar sobre lo que la otra persona contó antes de
        terminar de escucharla. Las mejores conversaciones se dan cuando hay espacio para que
        cada uno termine su historia.
      </p>

      <h2>Después de generar</h2>
      <ol>
        <li>Empezá por temas livianos para calibrar la energía del otro.</li>
        <li>Si fluye, sumá un tema medio. Si no, quedate en livianos un rato más.</li>
        <li>Hacé seguimiento de cada respuesta con una pregunta más específica.</li>
        <li>Compartí algo propio relacionado antes de saltar a otro tema.</li>
        <li>Cerrá con un tema creativo si la energía está alta.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>¿Cómo arranco una conversación interesante?</summary><p>Evitá preguntas cerradas y temas del clima. Buscá preguntas que requieran una historia personal corta.</p></details>
      <details><summary>¿Sirve para citas?</summary><p>Sí. Alterná entre temas livianos y temas que revelen valores, sin entrar de golpe en lo personal.</p></details>
      <details><summary>¿Cómo evito que se caiga?</summary><p>Hacé seguimiento de las respuestas con preguntas más profundas.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .bn-out { display: grid; grid-template-columns: 1fr; gap: 0.6rem; margin-top: 1.25rem; }
  .bn-item { padding: 0.85rem 1rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color 0.1s; line-height: 1.5; }
  .bn-item:hover { border-color: var(--primary); }
</style>

<script>
  const LIGHT = ['¿Cuál fue lo mejor que comiste esta semana?', '¿Qué serie estás viendo y la recomendarías?', '¿Cuál fue el último viaje que te dejó pensando?', '¿Tenés alguna canción que escuchaste cien veces este año?', '¿Qué libro te leíste en los últimos meses que te haya enganchado?', 'Si pudieras teletransportarte ahora a un lugar, ¿cuál?'];
  const MEDIUM = ['¿En qué proyecto personal estás invirtiendo tiempo este año?', '¿Cuál fue la última decisión importante que tomaste y por qué?', '¿Qué hábito nuevo intentaste sostener y cómo te fue?', '¿Cuál es el mejor consejo que te dieron en los últimos años?', '¿Hay algo que querés aprender que aún no empezaste?'];
  const DEEP = ['¿Cómo definirías "vivir bien" hoy, comparado con cinco años atrás?', '¿Qué es algo que cambió de opinión recientemente?', '¿Hay algo que tu familia te enseñó que ahora cuestionás?', '¿Qué te hace sentir orgulloso de cómo vivís hoy?', 'Si tuvieras que dejar tres reglas a alguien que recién empieza tu carrera, ¿cuáles?'];
  const CREATIVE = ['Si pudieras desayunar una vez con cualquier persona viva, ¿quién?', 'Si tuvieras que vivir un año en otro país sin internet, ¿dónde?', 'Si pudieras pasar un día siendo otra profesión, ¿cuál?', '¿Qué cosa cotidiana harías por primera vez si tuvieras 10 años menos?'];

  const kw = document.getElementById('bn-kw') as HTMLInputElement;
  const style = document.getElementById('bn-style') as HTMLSelectElement;
  const gen = document.getElementById('bn-gen') as HTMLButtonElement;
  const out = document.getElementById('bn-out')!;

  function shuffle<T>(arr: T[]): T[] { const a = [...arr]; for (let i = a.length - 1; i > 0; i--) { const r = new Uint32Array(1); crypto.getRandomValues(r); const j = r[0] % (i + 1); [a[i], a[j]] = [a[j], a[i]]; } return a; }

  function generate() {
    const s = style.value;
    let SRC: string[];
    if (s === 'medium') SRC = [...MEDIUM, ...LIGHT];
    else if (s === 'deep') SRC = [...DEEP, ...MEDIUM];
    else if (s === 'creative') SRC = [...CREATIVE, ...LIGHT];
    else SRC = [...LIGHT, ...CREATIVE];
    const items = shuffle(SRC).slice(0, 15);
    out.innerHTML = '';
    items.forEach(text => {
      const el = document.createElement('div');
      el.className = 'bn-item';
      el.textContent = text;
      el.title = 'Click para copiar';
      el.addEventListener('click', () => { navigator.clipboard.writeText(text); const orig = el.textContent; el.textContent = '✓ copiado'; setTimeout(() => el.textContent = orig, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
