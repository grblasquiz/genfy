---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de nombre de superhéroe gratis | Genfy';
const description = 'Creá nombres originales de superhéroe combinando alias, poderes y prefijos. Ideal para cómics, juegos de rol, fanfic, novelas y guiones.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Cómo construyo un buen nombre de superhéroe?', acceptedAnswer: { '@type': 'Answer', text: 'Mezclá un atributo físico o moral (sombra, hierro, tormenta) con una acción o objeto (puño, velo, escudo). Buscá dos sílabas fuertes y evitá nombres ya registrados de cómics conocidos.' } },
    { '@type': 'Question', name: '¿Puedo usar estos nombres comercialmente?', acceptedAnswer: { '@type': 'Answer', text: 'Las combinaciones son originales, pero antes de publicar verificá que no coincidan con marcas registradas en USPTO o INPI, sobre todo si el personaje aparecerá en cómic, videojuego o merchandising.' } },
    { '@type': 'Question', name: '¿Sirve para juegos de rol y videojuegos?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, los nombres funcionan para D&D, partidas de mesa, MMORPG, novelas gráficas y proyectos de animación independientes.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Creatividad" title="Generador de nombre de superhéroe"
    intro="Combiná atributo, objeto y estilo para conseguir alias originales de superhéroe. Útil para cómics, novelas, guiones, juegos de rol y fanfics.">

    <div slot="tool" class="sh">
      <label for="sh-style">Estilo</label>
      <select id="sh-style">
        <option value="compound">Compuesto inglés (ShadowFist)</option>
        <option value="esp">Compuesto español (Puño Sombra)</option>
        <option value="title">Con título (El, La, Capitán)</option>
        <option value="single">Una sola palabra fuerte</option>
      </select>

      <label for="sh-tone" style="margin-top:1rem">Tono</label>
      <select id="sh-tone">
        <option value="dark">Oscuro / nocturno</option>
        <option value="bright">Heroico / luminoso</option>
        <option value="tech">Tecnológico</option>
        <option value="elemental">Elemental</option>
      </select>

      <button id="sh-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 20 nombres</button>
      <div id="sh-out" class="sh-out"></div>
    </div>

    <div slot="content">
      <h2>Por qué un buen alias define al personaje</h2>
      <p>El nombre de un superhéroe es marca, lema y promesa narrativa al mismo tiempo. Cuando escuchás "Manto de Hierro" ya tenés expectativas de durabilidad, defensa y cierta frialdad emocional. Si en cambio leés "Brisa Diurna", el lector espera velocidad, juventud y movimientos limpios. Esa carga semántica funciona como atajo: te ahorra tres páginas de exposición.</p>
      <h2>Las cuatro fórmulas más usadas en el género</h2>
      <ol>
        <li><strong>Compuesto inglés.</strong> Dos palabras pegadas en CamelCase: ShadowFist, IronStrike, NightVeil. Suena moderno y cabe en logo cuadrado.</li>
        <li><strong>Compuesto castellano.</strong> Sustantivo + adjetivo: Puño Sombra, Garra Veloz, Hierro Mudo. Funciona muy bien en cómic latinoamericano y novela gráfica en español.</li>
        <li><strong>Con título.</strong> "El", "La", "Capitán", "Doctor", "Maestra". Da sensación de jerarquía o respeto público dentro del universo.</li>
        <li><strong>Una sola palabra.</strong> Un único sustantivo cargado: Tempestbreaker, Voltcage, Granito. Apuntan a impacto inmediato.</li>
      </ol>
      <h2>Cómo evitar el cliché y los problemas legales</h2>
      <p>Hay tres trampas frecuentes. La primera es repetir nombres ya tomados por Marvel, DC o editoriales mainstream: revisá Wikipedia y bases de marcas antes de fijar el alias. La segunda es caer en clichés mitológicos: si tu superhéroe se llama como una deidad antigua, además del problema cultural y religioso, perdés originalidad porque ya lo hicieron mil veces. La tercera es elegir un nombre demasiado largo: si pasa de cuatro sílabas el lector lo abrevia y la marca pierde control.</p>
      <h2>Tono y coherencia con el universo</h2>
      <ul>
        <li><strong>Oscuro / nocturno:</strong> ideal para vigilantes urbanos, antihéroes, historia noir.</li>
        <li><strong>Luminoso / heroico:</strong> mejor para protagonistas inspiracionales, cómic familiar, all ages.</li>
        <li><strong>Tecnológico:</strong> personajes con armadura, hacking, IA o ciencia avanzada.</li>
        <li><strong>Elemental:</strong> control de fuego, agua, viento, electricidad, sin tocar mitologías.</li>
      </ul>
      <h2>Validación antes de publicar</h2>
      <p>Una vez que tengas tu top 5, hacé esta checklist: pronunciable a la primera, no choca con marca registrada, no significa nada negativo en otro idioma, queda bien en una portada de 15×23 cm, y el dueño del nombre suena distinto al villano principal. Si pasa los cinco filtros, podés llevarlo al guion final.</p>
    </div>

    <div slot="faq">
      <details><summary>¿Cómo construyo un buen nombre de superhéroe?</summary><p>Mezclá un atributo (sombra, hierro, tormenta) con una acción u objeto (puño, velo, escudo). Buscá dos sílabas fuertes.</p></details>
      <details><summary>¿Puedo usarlos comercialmente?</summary><p>Verificá marcas registradas antes de publicar cómic, juego o merchandising.</p></details>
      <details><summary>¿Sirve para juegos de rol?</summary><p>Sí, funciona para D&D, partidas de mesa, MMORPG y novelas gráficas.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .sh-out { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 0.5rem; margin-top: 1.25rem; }
  .sh-item { padding: 0.625rem 0.875rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); font-weight: 600; cursor: pointer; }
  .sh-item:hover { border-color: var(--primary); }
</style>

<script>
  const ATTR_DARK = ['Shadow', 'Night', 'Dusk', 'Onyx', 'Raven', 'Cinder', 'Ember', 'Ash', 'Iron', 'Steel', 'Black', 'Veil'];
  const ATTR_BRIGHT = ['Solar', 'Dawn', 'Bright', 'Star', 'Light', 'Silver', 'Gold', 'White', 'Crystal', 'Prism', 'Beacon', 'Shine'];
  const ATTR_TECH = ['Volt', 'Cyber', 'Nano', 'Quantum', 'Pulse', 'Circuit', 'Chrome', 'Titan', 'Vector', 'Beta', 'Synth', 'Servo'];
  const ATTR_ELEM = ['Storm', 'Flame', 'Frost', 'Tide', 'Quake', 'Gale', 'Spark', 'Bolt', 'Stone', 'Wave', 'Drift', 'Blaze'];
  const NOUN_EN = ['Fist', 'Strike', 'Veil', 'Cage', 'Edge', 'Breaker', 'Wing', 'Claw', 'Heart', 'Mark', 'Wall', 'Shield', 'Howl', 'Walker', 'Hunter', 'Warden'];
  const ATTR_ES = ['Sombra', 'Hierro', 'Acero', 'Garra', 'Niebla', 'Tormenta', 'Llama', 'Hielo', 'Cuarzo', 'Carbón', 'Plomo', 'Bronce'];
  const NOUN_ES = ['Puño', 'Filo', 'Velo', 'Manto', 'Salto', 'Eco', 'Paso', 'Faro', 'Hueco', 'Trazo', 'Muro', 'Lazo'];
  const TITLES = ['El', 'La', 'Capitán', 'Capitana', 'Doctor', 'Doctora', 'Maestro', 'Maestra', 'Señor', 'Señora'];
  const SINGLE = ['Tempestbreaker', 'Voltcage', 'Granito', 'Niebla', 'Cobalto', 'Ariete', 'Centella', 'Plomada', 'Yunque', 'Cantera', 'Brasa', 'Vendaval', 'Lanzallamas', 'Ironclad', 'Stormwall', 'Coldsnap'];

  const style = document.getElementById('sh-style') as HTMLSelectElement;
  const tone = document.getElementById('sh-tone') as HTMLSelectElement;
  const gen = document.getElementById('sh-gen') as HTMLButtonElement;
  const out = document.getElementById('sh-out')!;

  function pick<T>(arr: T[]): T { const i = new Uint32Array(1); crypto.getRandomValues(i); return arr[i[0] % arr.length]; }
  function attrPool(t: string) {
    if (t === 'dark') return ATTR_DARK;
    if (t === 'bright') return ATTR_BRIGHT;
    if (t === 'tech') return ATTR_TECH;
    return ATTR_ELEM;
  }

  function generate() {
    const s = style.value, t = tone.value;
    const set = new Set<string>(); let tries = 0;
    while (set.size < 20 && tries < 200) {
      tries++;
      let name = '';
      if (s === 'compound') name = pick(attrPool(t)) + pick(NOUN_EN);
      else if (s === 'esp') name = pick(ATTR_ES) + ' ' + pick(NOUN_ES);
      else if (s === 'title') name = pick(TITLES) + ' ' + pick(ATTR_ES);
      else name = pick(SINGLE);
      set.add(name);
    }
    out.innerHTML = '';
    [...set].forEach(n => {
      const el = document.createElement('div');
      el.className = 'sh-item'; el.textContent = n; el.title = 'Click para copiar';
      el.addEventListener('click', () => { navigator.clipboard.writeText(n); el.textContent = '✓ ' + n; setTimeout(() => el.textContent = n, 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
