---
import Layout from '../../layouts/Layout.astro';
import { GENERATORS, urlFor } from '../../lib/generators';
import { SITE_URL } from '../../lib/i18n';

const lang = 'es' as const;
const title = 'Embed widgets — Generadores Genfy en tu sitio | Genfy';
const description = 'Embebé cualquier generador de Genfy en tu sitio o blog con un iframe. Gratis, sin tracking, con backlink discreto. Tamaño recomendado: 360×520.';

const featured = GENERATORS.slice(0, 12);
---
<Layout title={title} description={description} lang={lang}>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="crumb-current">Embed</span>
  </nav>

  <header class="emb-hero">
    <h1>Embebé generadores de Genfy en tu sitio</h1>
    <p class="lead">Cualquier generador de Genfy se puede mostrar como widget vía iframe. Gratis, sin tracking propio en el embed, con un backlink discreto al final.</p>
  </header>

  <section class="emb-section">
    <h2>Cómo embeberlo</h2>
    <p>Copiá este snippet y reemplazá <code>SLUG</code> por el slug del generador (ejemplo: <code>generador-de-contrasenas</code>):</p>
    <pre><code>&lt;iframe
  src="https://genfy.net/embed/SLUG"
  width="360"
  height="520"
  style="border: 1px solid #e4e4e7; border-radius: 12px;"
  loading="lazy"
  title="Generador Genfy"&gt;
&lt;/iframe&gt;</code></pre>
    <p>Tamaño recomendado: <strong>360×520</strong>. Responsive: ajustá <code>width="100%"</code> y <code>max-width: 480px</code>.</p>
  </section>

  <section class="emb-section">
    <h2>Generadores populares para embeber</h2>
    <p class="muted">Click en cualquiera para previsualizar el embed.</p>
    <div class="emb-grid">
      {featured.map(g => (
        <div class="emb-card">
          <div class="emb-card-head">
            <span class="emb-card-emoji">{g.emoji}</span>
            <a href={urlFor(g, lang)}><strong>{g.title.es}</strong></a>
          </div>
          <a class="emb-card-link" href={`/embed/${g.slug.es}`} target="_blank" rel="noopener">Ver embed →</a>
          <details>
            <summary>Snippet</summary>
            <pre><code>{`<iframe src="${SITE_URL}/embed/${g.slug.es}" width="360" height="520" style="border:1px solid #e4e4e7;border-radius:12px" loading="lazy" title="${g.title.es}"></iframe>`}</code></pre>
          </details>
        </div>
      ))}
    </div>
  </section>

  <section class="emb-section">
    <h2>Términos</h2>
    <ul>
      <li>Uso gratuito incluyendo sitios comerciales.</li>
      <li>El embed incluye un link "Embedded generator from Genfy" — pedimos no removerlo.</li>
      <li>El embed no carga ads ni tracking propio. El sitio anfitrión es responsable de su propio aviso de cookies.</li>
      <li>Genfy puede actualizar el contenido del embed sin previo aviso.</li>
    </ul>
  </section>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; color: var(--text-muted); font-size: 0.8125rem; margin: 1.5rem 0 0; flex-wrap: wrap; }
  .crumbs a { color: var(--text-subtle); text-decoration: none; }
  .crumbs a:hover { color: var(--text); }
  .crumb-sep { color: var(--text-muted); }
  .crumb-current { color: var(--text); font-weight: 500; }
  .emb-hero { padding: 2rem 0 2rem; max-width: 720px; }
  .emb-hero h1 { font-size: clamp(2rem, 4vw, 2.75rem); margin: 0 0 0.875rem; letter-spacing: -0.02em; }
  .lead { font-size: 1.0625rem; color: var(--text-soft); margin: 0; line-height: 1.55; }
  .emb-section { margin-bottom: 3rem; max-width: 760px; }
  .emb-section h2 { font-size: 1.375rem; margin: 0 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-soft); }
  .emb-section p { color: var(--text); line-height: 1.65; max-width: 64ch; }
  .emb-section pre { background: var(--bg-inset); padding: 1rem; border-radius: var(--radius); overflow-x: auto; font-size: 0.8125rem; line-height: 1.5; }
  .emb-section code { font-family: var(--font-mono); }
  .emb-grid { display: grid; grid-template-columns: 1fr; gap: 0.625rem; }
  @media (min-width: 600px) { .emb-grid { grid-template-columns: 1fr 1fr; } }
  .emb-card { padding: 1rem 1.125rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); }
  .emb-card-head { display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem; }
  .emb-card-link { font-size: 0.875rem; color: var(--accent); text-decoration: none; display: inline-block; margin-bottom: 0.5rem; }
  .emb-card details summary { cursor: pointer; font-size: 0.8125rem; color: var(--text-muted); margin-bottom: 0.5rem; }
  .emb-card pre { font-size: 0.75rem; padding: 0.625rem; }
  .muted { color: var(--text-muted); font-size: 0.875rem; }
</style>
