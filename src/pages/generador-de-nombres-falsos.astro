---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de nombres falsos para test | Genfy';
const description = 'Generá nombres y apellidos realistas en español para testing, fixtures y datos de prueba. Hispano, anglosajón o mixto. Nada se envía al servidor.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Para qué sirve un generador de nombres falsos?', acceptedAnswer: { '@type': 'Answer', text: 'Para poblar bases de datos de prueba, fixtures de tests automatizados, prototipos de UI y demos sin usar datos personales reales.' } },
    { '@type': 'Question', name: '¿Coinciden los nombres con personas reales?', acceptedAnswer: { '@type': 'Answer', text: 'Las combinaciones se generan aleatoriamente desde listas de nombres y apellidos comunes. Estadísticamente alguna combinación puede coincidir con personas reales: usá los datos solo para testing.' } },
    { '@type': 'Question', name: '¿Puedo usarlos en producción?', acceptedAnswer: { '@type': 'Answer', text: 'No. Estos datos son solo para entornos de desarrollo, staging o demos. Nunca los uses como nombre real de un usuario en producción.' } },
    { '@type': 'Question', name: '¿Por qué no usar Faker directamente?', acceptedAnswer: { '@type': 'Answer', text: 'Faker es excelente cuando ya escribiste código. Este generador sirve cuando necesitás 5 o 50 nombres rápido, sin instalar nada, ideal para diseñadores, QA y prototipos.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell
    lang="es"
    tag="Datos / Testing"
    title="Generador de nombres falsos"
    intro="Creá nombres y apellidos realistas para entornos de prueba. Útil para fixtures, seeds, prototipos de UI y demos. Nunca uses datos reales en testing."
  >
    <div slot="tool" class="names-tool">
      <div class="names-controls">
        <div>
          <label for="names-style">Estilo</label>
          <select id="names-style">
            <option value="es" selected>Hispano</option>
            <option value="en">Anglosajón</option>
            <option value="mix">Mixto</option>
          </select>
        </div>
        <div>
          <label for="names-gender">Género</label>
          <select id="names-gender">
            <option value="any" selected>Cualquiera</option>
            <option value="m">Masculino</option>
            <option value="f">Femenino</option>
          </select>
        </div>
        <div>
          <label for="names-count">Cantidad</label>
          <input id="names-count" type="number" min="1" max="100" value="10" />
        </div>
      </div>

      <div class="names-toggles">
        <label><input type="checkbox" id="names-two-last" /> Dos apellidos</label>
        <label><input type="checkbox" id="names-with-email" /> Incluir email</label>
      </div>

      <button id="names-gen" class="btn btn-primary" type="button">Generar nombres</button>

      <textarea id="names-out" class="mono" rows="12" readonly></textarea>
      <button id="names-copy" class="btn btn-ghost" type="button"><span class="copy-icon">Copiar todos</span></button>
    </div>

    <div slot="content">
      <h2>Cuándo necesitás nombres de prueba</h2>
      <p>
        Cualquier proyecto que toque datos personales se beneficia de tener nombres falsos a
        mano: tests automatizados, seeds para entornos de staging, capturas para presentaciones,
        prototipos de pantallas y demos para clientes. Usar nombres reales o nombres
        propios del equipo introduce dos problemas: privacidad y sesgos en las pruebas
        ("siempre funciona con Juan Pérez").
      </p>
      <p>
        Las listas de este generador combinan los nombres más comunes en países hispanohablantes
        (Argentina, México, España, Colombia, Chile) con apellidos también frecuentes. La
        variante anglosajona usa nombres y apellidos típicos de Estados Unidos y Reino Unido.
      </p>

      <h2>Qué incluye cada nombre</h2>
      <ul>
        <li><strong>Nombre:</strong> uno o dos nombres de pila según preferencia.</li>
        <li><strong>Apellido:</strong> uno o dos apellidos.</li>
        <li><strong>Email opcional:</strong> derivado del nombre, en dominios de prueba estándar (<code>example.com</code>, <code>test.com</code>).</li>
      </ul>

      <h2>Buenas prácticas para datos de testing</h2>
      <ol>
        <li><strong>Nunca uses datos reales en staging.</strong> Anonimizá o usá datos sintéticos como los que genera este tool. Si una persona externa accede al entorno, no debería ver información identificable.</li>
        <li><strong>Marcá los datos como sintéticos.</strong> Un flag en la base, un dominio claramente falso (<code>@example.com</code>) o un prefijo en el nombre evita confusiones.</li>
        <li><strong>Probá casos límite.</strong> Nombres muy largos, con tildes, eñes, apóstrofes y caracteres no latinos. La mayoría de los bugs en formularios aparece con datos atípicos.</li>
        <li><strong>Variá el set.</strong> Si todos tus nombres de testing son <code>Juan Pérez</code>, no estás probando ordenamientos, búsquedas ni edge cases reales.</li>
      </ol>

      <h2>Sobre nombres y privacidad</h2>
      <p>
        Aunque las combinaciones sean aleatorias, estadísticamente algún <code>Juan García</code>
        existe en el mundo real. Por eso conviene:
      </p>
      <ul>
        <li>Usar los datos solo en entornos no productivos.</li>
        <li>Combinarlos con direcciones de prueba (<code>123 Test Street</code>) y emails con dominio fake.</li>
        <li>Documentar en el repo o wiki que esos datos son sintéticos.</li>
        <li>Nunca enviar emails reales a esos contactos generados.</li>
      </ul>

      <h2>Cuándo Faker es mejor opción</h2>
      <p>
        Si ya tenés tests automatizados o un seed script, instalá Faker (<code>@faker-js/faker</code>
        para Node, <code>faker</code> para Python, <code>FactoryBot</code> + <code>Faker</code>
        para Ruby). Te da más control: locale específico, tipos de datos avanzados (direcciones,
        teléfonos, IBAN), reproducibilidad por semilla.
      </p>
      <p>
        Este generador es útil cuando necesitás algo rápido sin involucrar código: un diseñador
        que llena mockups, un PM que arma una demo, un QA que rellena un formulario manual.
      </p>

      <h2>Cómo lo usamos para testing real</h2>
      <p>
        En proyectos serios, una combinación práctica:
      </p>
      <ol>
        <li>Faker en los tests (rápido, reproducible, integrado).</li>
        <li>Este generador para fixtures grandes copy-paste (CSV de 50 filas para importar).</li>
        <li>Datos sintéticos completos (nombre + dirección + email + teléfono) para seeds de staging.</li>
        <li>Validación con Cypress o Playwright contra los nombres generados.</li>
      </ol>
    </div>

    <div slot="faq">
      <details><summary>¿Para qué sirve?</summary><p>Para poblar tests, fixtures, prototipos y demos sin usar datos personales reales.</p></details>
      <details><summary>¿Pueden coincidir con personas reales?</summary><p>Estadísticamente sí, alguna combinación puede coincidir. Usá los datos solo en entornos de testing.</p></details>
      <details><summary>¿Puedo usarlos en producción?</summary><p>No. Solo desarrollo, staging o demos. Nunca como nombre real de un usuario.</p></details>
      <details><summary>¿Por qué no Faker?</summary><p>Faker es ideal cuando ya escribís código. Este generador es para uso ad-hoc rápido.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .names-controls { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .names-controls { grid-template-columns: 1fr; } }
  .names-toggles { display: flex; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .names-toggles label { display: flex; align-items: center; gap: 0.5rem; font-weight: 400; font-size: 0.9375rem; color: var(--text-soft); cursor: pointer; margin: 0; }
  textarea { font-family: var(--font-mono); font-size: 0.875rem; background: var(--bg-inset); resize: vertical; margin: 1rem 0 0.75rem; }
</style>

<script>
  const ES_M = ['Juan','Carlos','Luis','Pedro','Miguel','Diego','Andres','Pablo','Daniel','Javier','Francisco','Antonio','Manuel','Roberto','Alejandro','Martin','Sergio','Gonzalo','Federico','Mariano','Nicolas','Lucas','Mateo','Ignacio','Tomas','Santiago','Joaquin','Esteban','Ricardo','Hugo'];
  const ES_F = ['Maria','Ana','Laura','Carmen','Lucia','Sofia','Elena','Patricia','Marta','Cristina','Paula','Carolina','Andrea','Daniela','Camila','Valentina','Florencia','Julieta','Agustina','Victoria','Isabel','Rocio','Beatriz','Gabriela','Mariana','Antonella','Catalina','Emilia','Renata','Claudia'];
  const ES_LAST = ['Garcia','Rodriguez','Gonzalez','Fernandez','Lopez','Martinez','Sanchez','Perez','Gomez','Martin','Jimenez','Ruiz','Hernandez','Diaz','Moreno','Alvarez','Romero','Torres','Vazquez','Ramirez','Gil','Vargas','Castro','Ortega','Rubio','Marin','Suarez','Ortiz','Iglesias','Medina'];
  const EN_M = ['John','James','Robert','Michael','William','David','Richard','Joseph','Thomas','Charles','Christopher','Daniel','Matthew','Anthony','Mark','Donald','Steven','Andrew','Paul','Joshua','Kenneth','Kevin','Brian','Edward','Ronald','Jason','Justin','Brandon','Tyler','Adam'];
  const EN_F = ['Mary','Patricia','Jennifer','Linda','Elizabeth','Barbara','Susan','Jessica','Sarah','Karen','Nancy','Lisa','Margaret','Betty','Sandra','Ashley','Kimberly','Emily','Donna','Michelle','Carol','Amanda','Melissa','Deborah','Stephanie','Rebecca','Laura','Sharon','Cynthia','Amy'];
  const EN_LAST = ['Smith','Johnson','Williams','Brown','Jones','Miller','Davis','Wilson','Anderson','Thomas','Taylor','Moore','Martin','Jackson','Thompson','White','Harris','Clark','Lewis','Walker','Hall','Allen','Young','King','Wright','Scott','Green','Baker','Adams','Nelson'];

  const style = document.getElementById('names-style') as HTMLSelectElement;
  const gender = document.getElementById('names-gender') as HTMLSelectElement;
  const count = document.getElementById('names-count') as HTMLInputElement;
  const twoLast = document.getElementById('names-two-last') as HTMLInputElement;
  const withEmail = document.getElementById('names-with-email') as HTMLInputElement;
  const out = document.getElementById('names-out') as HTMLTextAreaElement;
  const gen = document.getElementById('names-gen') as HTMLButtonElement;
  const copy = document.getElementById('names-copy') as HTMLButtonElement;

  function pick<T>(arr: T[]): T { const a = new Uint32Array(1); crypto.getRandomValues(a); return arr[a[0] % arr.length]; }

  function generate() {
    const n = Math.min(100, Math.max(1, parseInt(count.value || '10', 10)));
    const lines: string[] = [];
    for (let i = 0; i < n; i++) {
      let useEs = style.value === 'es';
      if (style.value === 'mix') useEs = Math.random() > 0.5;
      let g = gender.value;
      if (g === 'any') g = Math.random() > 0.5 ? 'm' : 'f';
      const firstPool = useEs ? (g === 'm' ? ES_M : ES_F) : (g === 'm' ? EN_M : EN_F);
      const lastPool = useEs ? ES_LAST : EN_LAST;
      const first = pick(firstPool);
      const last1 = pick(lastPool);
      const last2 = twoLast.checked ? ' ' + pick(lastPool) : '';
      let line = `${first} ${last1}${last2}`;
      if (withEmail.checked) {
        const local = `${first}.${last1}`.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        line += ` | ${local}@example.com`;
      }
      lines.push(line);
    }
    out.value = lines.join('\n');
  }
  gen.addEventListener('click', generate);
  [style, gender, count, twoLast, withEmail].forEach(el => el.addEventListener('change', generate));
  copy.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const icon = copy.querySelector('.copy-icon') as HTMLElement;
    icon.innerHTML = '<span class="copy-toast">✓ Copiado</span>';
    copy.dataset.copied = 'true';
    setTimeout(() => { icon.textContent = 'Copiar todos'; delete copy.dataset.copied; }, 1400);
  });
  generate();
</script>
