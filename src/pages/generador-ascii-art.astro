      M:['#   #','## ##','# # #','#   #','#   #'],
      N:['#   #','##  #','# # #','#  ##','#   #'],
      O:[' ### ','#   #','#   #','#   #',' ### '],
      P:['#### ','#   #','#### ','#    ','#    '],
      Q:[' ### ','#   #','# # #','#  # ',' ## #'],
      R:['#### ','#   #','#### ','#  # ','#   #'],
