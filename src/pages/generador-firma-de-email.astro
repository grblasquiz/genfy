---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de firma de email | Genfy';
const description = 'Creá una firma de email profesional con HTML listo para Gmail, Outlook y Apple Mail. Vista previa en tiempo real. Copiá HTML o texto.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Funciona en Gmail y Outlook?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. El HTML está pensado con compatibilidad para Gmail, Outlook 365, Apple Mail, Yahoo y Thunderbird.' } },
    { '@type': 'Question', name: '¿Qué información debe incluir una firma?', acceptedAnswer: { '@type': 'Answer', text: 'Nombre, cargo, empresa, web/email/teléfono. Lo demás (LinkedIn, frase, logo) es opcional. Más de 6 líneas se vuelve molesto.' } },
    { '@type': 'Question', name: '¿Puedo agregar logo?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, ingresá la URL pública de la imagen (debe estar alojada en un servidor accesible). El generador la incluirá en el HTML.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Trabajo / Work" title="Generador de firma de email"
    intro="Creá tu firma profesional con vista previa en vivo. HTML compatible con Gmail, Outlook, Apple Mail y Thunderbird. Copiá HTML o texto plano.">

    <div slot="tool" class="es">
      <div class="es-row">
        <div>
          <label for="es-name">Nombre completo</label>
          <input id="es-name" type="text" value="Martín Rodríguez" />
        </div>
        <div>
          <label for="es-role">Cargo</label>
          <input id="es-role" type="text" value="Director de Marketing" />
        </div>
      </div>
      <div class="es-row">
        <div>
          <label for="es-company">Empresa</label>
          <input id="es-company" type="text" value="Acme S.A." />
        </div>
        <div>
          <label for="es-phone">Teléfono</label>
          <input id="es-phone" type="text" value="+54 11 1234-5678" />
        </div>
      </div>
      <div class="es-row">
        <div>
          <label for="es-email">Email</label>
          <input id="es-email" type="email" value="martin@acme.com" />
        </div>
        <div>
          <label for="es-web">Web</label>
          <input id="es-web" type="text" value="acme.com" />
        </div>
      </div>
      <div class="es-row">
        <div>
          <label for="es-linkedin">LinkedIn (URL)</label>
          <input id="es-linkedin" type="text" placeholder="https://linkedin.com/in/usuario" />
        </div>
        <div>
          <label for="es-logo">Logo (URL pública)</label>
          <input id="es-logo" type="text" placeholder="https://acme.com/logo.png" />
        </div>
      </div>
      <div class="es-row">
        <div>
          <label for="es-color">Color de acento</label>
          <input id="es-color" type="color" value="#0066cc" />
        </div>
        <div>
          <label for="es-style">Estilo</label>
          <select id="es-style">
            <option value="classic">Clásico</option>
            <option value="minimal">Minimalista</option>
            <option value="card">Bloque</option>
          </select>
        </div>
      </div>
      <button id="es-gen" class="btn btn-primary" type="button">Actualizar vista previa</button>
      <button id="es-copy-html" class="btn btn-ghost" type="button">Copiar HTML</button>
      <button id="es-copy-text" class="btn btn-ghost" type="button">Copiar texto plano</button>

      <div style="margin-top:1.5rem;">
        <label>Vista previa</label>
        <div id="es-preview" class="es-preview"></div>
      </div>
      <div style="margin-top:1rem;">
        <label for="es-html">HTML</label>
        <textarea id="es-html" rows="8" readonly style="font-family: var(--font-mono); font-size: 0.85rem;"></textarea>
      </div>
    </div>

    <div slot="content">
      <h2>Qué tiene que tener (y qué no) una firma profesional</h2>
      <p>
        Una firma efectiva es funcional, no decorativa. Debe responder en menos de 2 segundos
        tres preguntas: quién sos, dónde trabajás, cómo te contacto. Todo lo demás (frase
        motivacional, lema corporativo, redes sociales secundarias, logo gigante, advertencias
        legales largas) compite con esa información esencial. Si tu firma ocupa más espacio
        visual que el cuerpo del mail, está mal.
      </p>

      <h2>Estilos</h2>
      <ul>
        <li><strong>Clásico.</strong> Datos uno arriba del otro, separador horizontal, color de acento. Funciona en cualquier industria.</li>
        <li><strong>Minimalista.</strong> Nombre + cargo + email. Sin teléfono, sin logo. Para perfiles senior que se comunican principalmente por mail.</li>
        <li><strong>Bloque.</strong> Logo a la izquierda, datos a la derecha. Ideal para empresas con marca visual fuerte.</li>
      </ul>

      <h2>Compatibilidad por cliente</h2>
      <p>
        Outlook 365 y Outlook desktop renderizan HTML de forma muy distinta a Gmail (Outlook
        usa el motor de Word, que no soporta CSS moderno). Por eso el HTML que genera este
        herramienta usa solo tablas, atributos inline y estilos básicos — exactamente como las
        firmas profesionales de servicios pagos. Apple Mail, Yahoo y Thunderbird son más
        permisivos.
      </p>

      <h2>Cómo instalar tu firma</h2>
      <ol>
        <li><strong>Gmail.</strong> Configuración → General → Firma → Crear nueva → pegá el HTML directamente.</li>
        <li><strong>Outlook 365 web.</strong> Configuración → Correo → Componer y responder → Firma de correo electrónico → pegá el HTML.</li>
        <li><strong>Outlook desktop.</strong> Archivo → Opciones → Correo → Firmas → pegá el HTML.</li>
        <li><strong>Apple Mail.</strong> Mail → Preferencias → Firmas → "+" → pegá el HTML como rich text.</li>
      </ol>

      <h2>Sobre el logo</h2>
      <p>
        El logo tiene que estar alojado en una URL pública estable. Si lo subís a tu sitio o a
        un CDN, el receptor del mail lo verá. Si está en un servidor privado o local, se va a
        romper. Tamaño recomendado: 80-120 px de alto, formato PNG con fondo transparente.
        Evitá imágenes grandes — sumás peso al mail y muchos clientes los bloquean por
        defecto.
      </p>

      <h2>Errores comunes</h2>
      <ul>
        <li><strong>Frases personales.</strong> "Este planeta es prestado, cuidalo" en una firma corporativa distrae.</li>
        <li><strong>Imagen como firma completa.</strong> Si la firma es una imagen, los clientes que bloquean imágenes ven nada.</li>
        <li><strong>Disclaimer legal de 200 palabras.</strong> En la mayoría de empresas no aporta nada. Recortá al mínimo viable.</li>
        <li><strong>Múltiples redes sociales.</strong> Pone máximo una. LinkedIn para B2B; Instagram solo si vendés visualmente.</li>
        <li><strong>Color extremo.</strong> Texto rojo brillante o fondos oscuros se ven mal en muchos clientes. Usá color de acento sutil.</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>¿Funciona en Gmail/Outlook?</summary><p>Sí, el HTML está pensado con compatibilidad amplia.</p></details>
      <details><summary>¿Qué incluir?</summary><p>Nombre, cargo, empresa, contacto. El resto opcional.</p></details>
      <details><summary>¿Logo?</summary><p>Sí, ingresá la URL pública de la imagen.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .es-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .es-row { grid-template-columns: 1fr; } }
  .es-preview { padding: 1.5rem; background: #fff; color: #000; border: 1px solid var(--border); border-radius: var(--radius-lg); margin-top: 0.5rem; }
</style>

<script>
  const ids = ['es-name','es-role','es-company','es-phone','es-email','es-web','es-linkedin','es-logo','es-color','es-style'];
  const get = (id: string) => (document.getElementById(id) as HTMLInputElement).value;
  const preview = document.getElementById('es-preview') as HTMLElement;
  const htmlOut = document.getElementById('es-html') as HTMLTextAreaElement;
  const genBtn = document.getElementById('es-gen') as HTMLButtonElement;
  const copyHtml = document.getElementById('es-copy-html') as HTMLButtonElement;
  const copyText = document.getElementById('es-copy-text') as HTMLButtonElement;

  function escapeHtml(s: string) { return s.replace(/[&<>"]/g, c => ({ '&':'&amp;','<':'<','>':'>','"':'&quot;' }[c] as string)); }

  function buildClassic() {
    const name = escapeHtml(get('es-name'));
    const role = escapeHtml(get('es-role'));
    const company = escapeHtml(get('es-company'));
    const phone = escapeHtml(get('es-phone'));
    const email = escapeHtml(get('es-email'));
    const web = escapeHtml(get('es-web'));
    const linkedin = escapeHtml(get('es-linkedin'));
    const logo = escapeHtml(get('es-logo'));
    const color = escapeHtml(get('es-color'));
    const logoCell = logo ? `<td valign="top" style="padding-right:16px;border-right:2px solid ${color};"><img src="${logo}" alt="${company}" height="56" style="display:block;border:0;outline:none;text-decoration:none;"/></td>` : '';
    return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:Arial,Helvetica,sans-serif;color:#222;font-size:14px;line-height:1.4;"><tr>${logoCell}<td valign="top" style="${logo ? 'padding-left:16px;' : ''}"><div style="font-weight:700;color:#111;font-size:15px;">${name}</div><div style="color:#666;">${role}${company ? ' · ' + company : ''}</div><div style="margin-top:6px;color:#444;">${phone ? phone + ' &nbsp;|&nbsp; ' : ''}<a href="mailto:${email}" style="color:${color};text-decoration:none;">${email}</a>${web ? ' &nbsp;|&nbsp; <a href="https://' + web + '" style="color:' + color + ';text-decoration:none;">' + web + '</a>' : ''}</div>${linkedin ? '<div style="margin-top:4px;"><a href="' + linkedin + '" style="color:' + color + ';text-decoration:none;">LinkedIn</a></div>' : ''}</td></tr></table>`;
  }
  function buildMinimal() {
    const name = escapeHtml(get('es-name'));
    const role = escapeHtml(get('es-role'));
    const company = escapeHtml(get('es-company'));
    const email = escapeHtml(get('es-email'));
    const color = escapeHtml(get('es-color'));
    return `<div style="font-family:Arial,Helvetica,sans-serif;color:#111;font-size:14px;line-height:1.4;"><div style="font-weight:700;">${name}</div><div style="color:#666;">${role}${company ? ', ' + company : ''}</div><div><a href="mailto:${email}" style="color:${color};text-decoration:none;">${email}</a></div></div>`;
  }
  function buildCard() {
    const name = escapeHtml(get('es-name'));
    const role = escapeHtml(get('es-role'));
    const company = escapeHtml(get('es-company'));
    const phone = escapeHtml(get('es-phone'));
    const email = escapeHtml(get('es-email'));
    const web = escapeHtml(get('es-web'));
    const logo = escapeHtml(get('es-logo'));
    const color = escapeHtml(get('es-color'));
    return `<table cellpadding="0" cellspacing="0" border="0" style="font-family:Arial,Helvetica,sans-serif;background:#f7f7f7;border-radius:8px;padding:14px;"><tr>${logo ? '<td valign="middle" style="padding-right:14px;"><img src="' + logo + '" alt="' + company + '" height="48" style="display:block;border:0;"/></td>' : ''}<td valign="middle" style="font-size:14px;color:#222;line-height:1.4;"><div style="font-weight:700;color:${color};font-size:15px;">${name}</div><div style="color:#555;">${role}${company ? ' · ' + company : ''}</div><div style="color:#666;font-size:13px;margin-top:4px;">${phone}${phone && email ? ' &nbsp;·&nbsp; ' : ''}<a href="mailto:${email}" style="color:${color};text-decoration:none;">${email}</a></div>${web ? '<div style="font-size:13px;"><a href="https://' + web + '" style="color:' + color + ';text-decoration:none;">' + web + '</a></div>' : ''}</td></tr></table>`;
  }
  function buildText() {
    const name = get('es-name'); const role = get('es-role'); const company = get('es-company');
    const phone = get('es-phone'); const email = get('es-email'); const web = get('es-web');
    const linkedin = get('es-linkedin');
    const lines = [name, [role, company].filter(Boolean).join(' · '), [phone, email].filter(Boolean).join(' | '), web, linkedin].filter(Boolean);
    return lines.join('\n');
  }
  function build() {
    const style = get('es-style');
    return style === 'minimal' ? buildMinimal() : style === 'card' ? buildCard() : buildClassic();
  }
  function update() {
    const html = build();
    preview.innerHTML = html;
    htmlOut.value = html;
  }
  ids.forEach(id => document.getElementById(id)?.addEventListener('input', update));
  genBtn.addEventListener('click', update);
  copyHtml.addEventListener('click', async () => {
    if (!htmlOut.value) return;
    await navigator.clipboard.writeText(htmlOut.value);
    const t = copyHtml.textContent; copyHtml.textContent = '¡Copiado!';
    setTimeout(() => { copyHtml.textContent = t; }, 1200);
  });
  copyText.addEventListener('click', async () => {
    await navigator.clipboard.writeText(buildText());
    const t = copyText.textContent; copyText.textContent = '¡Copiado!';
    setTimeout(() => { copyText.textContent = t; }, 1200);
  });
  update();
</script>
