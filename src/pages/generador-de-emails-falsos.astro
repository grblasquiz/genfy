---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de emails falsos para testing | Genfy';
const description = 'Generá emails falsos con dominios estándar de prueba (example.com, test.com). Para fixtures, formularios y QA. No envía correo a nadie.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Estos emails reciben correo?', acceptedAnswer: { '@type': 'Answer', text: 'No. Los dominios example.com, example.net y example.org están reservados por la IANA precisamente para usar en documentación y testing. Cualquier email a esos dominios rebota.' } },
    { '@type': 'Question', name: '¿Diferencia con un email temporal?', acceptedAnswer: { '@type': 'Answer', text: 'Un email temporal real (10minutemail, mailinator) sí recibe correo durante un rato. Estos emails falsos no reciben nada: son solo strings con formato de email para llenar formularios y bases de datos.' } },
    { '@type': 'Question', name: '¿Cuándo usar example.com vs test.com?', acceptedAnswer: { '@type': 'Answer', text: 'example.com está garantizado por la IANA. test.com no es un TLD reservado y podría ser registrado por alguien. Para fixtures críticos, preferí example.com.' } },
    { '@type': 'Question', name: '¿Pasan validaciones de email?', acceptedAnswer: { '@type': 'Answer', text: 'Pasan validaciones de formato (regex). Validaciones de existencia (DNS lookup, MX record) los rechazan. Es lo esperable: querés datos de testing, no emails que reciban spam.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell
    lang="es"
    tag="Datos / Testing"
    title="Generador de emails falsos"
    intro="Direcciones de email sintéticas para fixtures, tests y prototipos. Usan los dominios reservados por IANA para documentación, así nadie recibe correo por accidente."
  >
    <div slot="tool" class="email-tool">
      <div class="email-controls">
        <div>
          <label for="email-style">Estilo del local</label>
          <select id="email-style">
            <option value="name" selected>Basado en nombre</option>
            <option value="random">Aleatorio</option>
            <option value="user">user1, user2…</option>
          </select>
        </div>
        <div>
          <label for="email-domain">Dominio</label>
          <select id="email-domain">
            <option value="example.com" selected>example.com</option>
            <option value="example.net">example.net</option>
            <option value="example.org">example.org</option>
            <option value="test.local">test.local</option>
            <option value="invalid">.invalid (TLD reservado)</option>
          </select>
        </div>
        <div>
          <label for="email-count">Cantidad</label>
          <input id="email-count" type="number" min="1" max="200" value="10" />
        </div>
      </div>

      <button id="email-gen" class="btn btn-primary" type="button">Generar emails</button>

      <textarea id="email-out" class="mono" rows="14" readonly></textarea>
      <button id="email-copy" class="btn btn-ghost" type="button"><span class="copy-icon">Copiar todos</span></button>
    </div>

    <div slot="content">
      <h2>Por qué existen los dominios .example</h2>
      <p>
        La IANA (Internet Assigned Numbers Authority) reserva los dominios <code>example.com</code>,
        <code>example.net</code> y <code>example.org</code> en la RFC 2606 específicamente para
        usar en documentación, ejemplos y casos donde no se quiere apuntar a un dominio real.
        Eso garantiza dos cosas: nadie puede registrarlos (no van a aparecer apuntando a otro
        sitio), y los servidores de email los rechazan automáticamente.
      </p>
      <p>
        Lo mismo aplica a TLDs reservados como <code>.test</code>, <code>.invalid</code>,
        <code>.localhost</code> y <code>.local</code>: ninguno resuelve en internet pública,
        son seguros para datos sintéticos.
      </p>

      <h2>Diferencia con emails temporales reales</h2>
      <p>
        Un email temporal real (Mailinator, 10minutemail, Tempmail) es una bandeja de entrada
        pública: cualquiera puede ver los mensajes que llegan. Sirven para registrarse en
        servicios sin dar tu email real, pero no para testing automatizado: no controlás el
        timing de la entrega y no son privados.
      </p>
      <p>
        Los emails generados acá son distintos: <strong>no reciben nada</strong>. Son cadenas
        con formato válido pero sin bandeja detrás. Si tu test envía correo a uno de estos,
        rebota. Eso es lo que querés en CI/CD: ningún sistema externo se ve afectado por tu
        suite de tests.
      </p>

      <h2>Cuándo usar cada estilo de email local</h2>
      <ul>
        <li><strong>Basado en nombre</strong> (<code>juan.perez@example.com</code>): cuando querés que el email "se vea" como real, asociado a un nombre. Útil para demos y screenshots.</li>
        <li><strong>Aleatorio</strong> (<code>kx7p2qm9@example.com</code>): cuando solo necesitás unicidad y volumen. Útil para fixtures que prueban listas largas.</li>
        <li><strong>user1, user2…</strong>: cuando importa el orden y la trazabilidad. Útil para tests donde tenés que referirte a "el cuarto usuario" sin ambigüedad.</li>
      </ul>

      <h2>Errores comunes con datos de email en testing</h2>
      <ol>
        <li><strong>Usar tu email real.</strong> Si una corrida de tests salta un guard y manda correos, llenás tu inbox o, peor, le mandás spam a un compañero.</li>
        <li><strong>Usar dominios que parecen falsos pero son reales.</strong> <code>fake.com</code>, <code>nope.com</code> y muchos otros son dominios registrados. Quedate con <code>example.com</code>.</li>
        <li><strong>Hardcodear un solo email para todo.</strong> Si todos los usuarios de tests tienen el mismo email, no detectás bugs de unicidad en la base.</li>
        <li><strong>No marcar los emails como sintéticos.</strong> Un flag <code>is_test_data</code> en la base te permite limpiar después.</li>
      </ol>

      <h2>Buenas prácticas para envío en entornos no productivos</h2>
      <p>
        Aún con emails sintéticos, conviene blindarse contra envíos accidentales:
      </p>
      <ul>
        <li>En desarrollo y staging, configurá un <strong>mail catcher</strong> (MailHog, Mailtrap, mailpit). Captura todo lo que el sistema "envía" sin que llegue a nadie.</li>
        <li>Whiteliste solo emails internos al sistema de envío fuera de producción.</li>
        <li>Implementá un <strong>kill switch</strong>: una variable de entorno que apaga el envío real en cualquier ambiente que no sea producción.</li>
        <li>Logueá todo intento de envío para detectar fugas.</li>
      </ul>

      <h2>Validación de email a tener en cuenta</h2>
      <p>
        Tu generador da emails con formato válido (<code>nombre@dominio.tld</code>). Distintas
        librerías validan distinto:
      </p>
      <ul>
        <li><strong>Regex simple</strong> (HTML5, frontend): los acepta sin problema.</li>
        <li><strong>RFC 5321 estricto</strong>: los acepta.</li>
        <li><strong>Validación con DNS/MX lookup</strong>: <code>example.com</code> tiene MX (apunta a sí mismo), pero la dirección concreta no existe. Algunas librerías van a rechazarlos.</li>
        <li><strong>Validación SMTP</strong>: rebota.</li>
      </ul>
      <p>
        Para tests donde necesites un email "que pase validación profunda", usá un email real
        descartable. Para todo lo demás, estos sintéticos alcanzan.
      </p>
    </div>

    <div slot="faq">
      <details><summary>¿Reciben correo?</summary><p>No. Los dominios example.* están reservados por IANA y todo correo rebota.</p></details>
      <details><summary>¿Diferencia con email temporal?</summary><p>Un email temporal sí recibe correo unos minutos. Estos no reciben nada, son solo strings con formato válido.</p></details>
      <details><summary>¿example.com vs test.com?</summary><p>example.com está reservado por IANA. test.com no, podría ser registrado. Quedate con example.com para fixtures críticos.</p></details>
      <details><summary>¿Pasan validaciones?</summary><p>Las de formato sí. Las de DNS/MX o SMTP los rechazan, que es lo deseable.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .email-controls { display: grid; grid-template-columns: 1.3fr 1fr 0.8fr; gap: 1rem; margin-bottom: 1rem; }
  @media (max-width: 600px) { .email-controls { grid-template-columns: 1fr; } }
  textarea { font-family: var(--font-mono); font-size: 0.875rem; background: var(--bg-inset); resize: vertical; margin: 1rem 0 0.75rem; }
</style>

<script>
  const FIRST = ['juan','maria','carlos','ana','luis','laura','pedro','sofia','diego','lucia','andres','elena','pablo','camila','daniel','victoria','martin','agustina','tomas','julieta','santiago','renata','federico','catalina'];
  const LAST = ['garcia','rodriguez','gonzalez','fernandez','lopez','martinez','sanchez','perez','gomez','diaz','moreno','alvarez','romero','torres','vazquez','ramirez'];
  const style = document.getElementById('email-style') as HTMLSelectElement;
  const domain = document.getElementById('email-domain') as HTMLSelectElement;
  const count = document.getElementById('email-count') as HTMLInputElement;
  const out = document.getElementById('email-out') as HTMLTextAreaElement;
  const gen = document.getElementById('email-gen') as HTMLButtonElement;
  const copy = document.getElementById('email-copy') as HTMLButtonElement;
  function pick<T>(arr: T[]): T { const a = new Uint32Array(1); crypto.getRandomValues(a); return arr[a[0] % arr.length]; }
  function rand(min: number, max: number): number { const a = new Uint32Array(1); crypto.getRandomValues(a); return min + (a[0] % (max - min + 1)); }
  function randStr(n: number): string { const c = 'abcdefghijklmnopqrstuvwxyz0123456789'; const a = new Uint32Array(n); crypto.getRandomValues(a); let s = ''; for (let i = 0; i < n; i++) s += c[a[i] % c.length]; return s; }
  function generate() {
    const n = Math.min(200, Math.max(1, parseInt(count.value || '10', 10)));
    const d = domain.value === 'invalid' ? 'test.invalid' : domain.value;
    const lines: string[] = [];
    for (let i = 0; i < n; i++) {
      let local = '';
      if (style.value === 'name') {
        const f = pick<string>(FIRST), l = pick<string>(LAST);
        const variants = [`${f}.${l}`, `${f}${l}`, `${f}_${l}`, `${f[0]}${l}`, `${f}.${l}${rand(10,99)}`];
        local = pick(variants);
      } else if (style.value === 'random') {
        local = randStr(rand(7, 11));
      } else {
        local = `user${i+1}`;
      }
      lines.push(`${local}@${d}`);
    }
    out.value = lines.join('\n');
  }
  gen.addEventListener('click', generate);
  [style, domain, count].forEach(el => el.addEventListener('change', generate));
  copy.addEventListener('click', async () => {
    if (!out.value) return;
    await navigator.clipboard.writeText(out.value);
    const icon = copy.querySelector('.copy-icon') as HTMLElement;
    icon.innerHTML = '<span class="copy-toast">✓ Copiado</span>';
    copy.dataset.copied = 'true';
    setTimeout(() => { icon.textContent = 'Copiar todos'; delete copy.dataset.copied; }, 1400);
  });
  generate();
</script>
