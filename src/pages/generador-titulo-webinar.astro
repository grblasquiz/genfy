---
import Layout from '../layouts/Layout.astro';
import GeneratorShell from '../components/GeneratorShell.astro';

const title = 'Generador de título de webinar | Genfy';
const description = 'Generá títulos de webinar que llenan registros. 10 fórmulas probadas con número, beneficio y urgencia, listas para landing, ad y email de invitación.';

const faqSchema = {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Qué hace bueno a un título de webinar?', acceptedAnswer: { '@type': 'Answer', text: 'Un beneficio concreto, una fecha y un orador con autoridad. "Cómo reducir CAC 30% en LinkedIn Ads — jueves 16, 16hs" gana contra "Webinar de growth marketing".' } },
    { '@type': 'Question', name: '¿Cuánto antes promocionar un webinar?', acceptedAnswer: { '@type': 'Answer', text: 'Lo ideal son 14 días con campañas distintas: anuncio inicial, recordatorio a 7 días, recordatorio a 24hs y email "está empezando" 30 minutos antes.' } },
    { '@type': 'Question', name: '¿Cuánto debe durar?', acceptedAnswer: { '@type': 'Answer', text: '45-60 minutos: 35-40 de contenido + 10-15 de Q&A. Más allá, la asistencia cae fuerte. Si tenés más para decir, dividilo en 2 sesiones.' } },
  ],
};
---
<Layout title={title} description={description} lang="es" schema={faqSchema} withSidebar={true}>
  <GeneratorShell lang="es" tag="Empresa / Business" title="Generador de título de webinar"
    intro="Generá 10 títulos para tu próximo webinar. Combinaciones de beneficio, número, fecha y autoridad. Listas para landing, ad y email de invitación.">

    <div slot="tool" class="wb">
      <label>Tema</label>
      <input id="wb-topic" type="text" value="reducir CAC en LinkedIn Ads" />

      <label style="margin-top:1rem">Audiencia</label>
      <input id="wb-aud" type="text" value="CMOs B2B" />

      <label style="margin-top:1rem">Resultado / promesa</label>
      <input id="wb-result" type="text" value="bajar CAC 30%" />

      <label style="margin-top:1rem">Orador / autoridad</label>
      <input id="wb-speaker" type="text" value="Ex-CMO de Acme Corp" />

      <button id="wb-gen" class="btn btn-primary" type="button" style="margin-top:1rem">Generar 10 títulos</button>

      <div id="wb-out" class="wb-out"></div>
    </div>

    <div slot="content">
      <h2>Por qué el título decide la asistencia</h2>
      <p>
        Un buen webinar puede traer 50-200 leads calificados, pero solo si el título engancha. Los
        registros se deciden en 8 segundos: el visitante mira el título, evalúa si vale 60 minutos
        de su tiempo, y decide. Si tu título no responde a la pregunta "¿qué me llevo a casa?",
        bajás 50% de los registros sin importar lo bueno que sea el contenido.
      </p>

      <h2>La fórmula de un buen título</h2>
      <ol>
        <li><strong>Beneficio concreto:</strong> "Bajá tu CAC 30% en 60 días".</li>
        <li><strong>Especificidad:</strong> el canal, la herramienta o el segmento. "En LinkedIn Ads".</li>
        <li><strong>Autoridad:</strong> quien habla. "Con el ex-CMO de Acme Corp".</li>
        <li><strong>Fecha y hora:</strong> opcional en el título, obligatorio en la landing.</li>
        <li><strong>Limitación:</strong> "Solo 100 cupos" o "En vivo, sin grabación" para sumar urgencia.</li>
      </ol>

      <h2>Fórmulas que funcionan</h2>
      <ul>
        <li><strong>Cómo + resultado + tiempo:</strong> "Cómo bajar tu CAC 30% en 60 días".</li>
        <li><strong>Pregunta:</strong> "¿Por qué tu CAC sube todos los meses? Y qué hacer al respecto".</li>
        <li><strong>Detrás de escena:</strong> "Cómo Acme Corp redujo CAC 30% — y cómo replicarlo".</li>
        <li><strong>Errores:</strong> "5 errores típicos en LinkedIn Ads (y cómo evitarlos)".</li>
        <li><strong>Mesa redonda:</strong> "3 CMOs comparten qué les funcionó este trimestre".</li>
      </ul>

      <h2>Errores típicos en webinars</h2>
      <ol>
        <li>Títulos genéricos: "Webinar de marketing digital" — no convierte.</li>
        <li>No mencionar al orador. Su autoridad es 30% de la decisión.</li>
        <li>Hora rara para tu audiencia. Confirmá zona horaria del público objetivo.</li>
        <li>Sin Q&A. La interacción es lo que diferencia un webinar de un video grabado.</li>
        <li>No grabar / no enviar la grabación. Perdés 60-70% de la audiencia que no asistió en vivo.</li>
      </ol>

      <h2>Cómo maximizar registros</h2>
      <ul>
        <li>Landing dedicada con título grande, fecha, agenda y bio del orador.</li>
        <li>Campañas en LinkedIn Ads y email a tu base con 14 días de anticipación.</li>
        <li>Recordatorios automatizados: día -1, día 0 (6hs antes), 30 minutos antes.</li>
        <li>Compañero de equipo + invitado externo aumenta conversión 25-40%.</li>
        <li>Después del webinar, mandá grabación + slides + un activo descargable. Convierte 2-3x más.</li>
      </ul>

      <h2>Métricas que importan</h2>
      <ul>
        <li><strong>Tasa de registro:</strong> visitantes / registros. 25-35% es saludable.</li>
        <li><strong>Show-up rate:</strong> registrados / asistentes en vivo. 30-50% es típico.</li>
        <li><strong>Engagement rate:</strong> tiempo promedio mirando, número de preguntas.</li>
        <li><strong>SQL conversion:</strong> de cada 100 asistentes, ¿cuántos pasan a oportunidad real?</li>
      </ul>
    </div>

    <div slot="faq">
      <details><summary>¿Qué hace bueno al título?</summary><p>Beneficio concreto + especificidad + autoridad + fecha.</p></details>
      <details><summary>¿Cuánto antes promocionar?</summary><p>14 días con campañas y recordatorios escalonados.</p></details>
      <details><summary>¿Cuánto debe durar?</summary><p>45-60 minutos. Más allá, la asistencia cae.</p></details>
    </div>
  </GeneratorShell>
</Layout>

<style>
  .wb-out { display: grid; gap: 0.5rem; margin-top: 1.25rem; }
  .wb-item { padding: 0.875rem 1rem; background: var(--bg-soft); border: 1px solid var(--border); border-radius: var(--radius-sm); cursor: pointer; transition: border-color 0.1s; line-height: 1.5; }
  .wb-item:hover { border-color: var(--primary); }
  .wb-tag { font-size: 0.75rem; color: var(--text-soft); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 0.25rem; display: block; }
</style>

<script>
  const topic = document.getElementById('wb-topic') as HTMLInputElement;
  const aud = document.getElementById('wb-aud') as HTMLInputElement;
  const result = document.getElementById('wb-result') as HTMLInputElement;
  const speaker = document.getElementById('wb-speaker') as HTMLInputElement;
  const out = document.getElementById('wb-out')!;
  const gen = document.getElementById('wb-gen') as HTMLButtonElement;

  function generate() {
    const tp = topic.value;
    const a = aud.value;
    const r = result.value;
    const sp = speaker.value;

    const lines = [
      { tag: 'Cómo + resultado', text: `Cómo ${r} en ${tp}, sin sumar headcount.` },
      { tag: 'Pregunta', text: `¿Por qué ${tp} se vuelve más caro cada trimestre? Y qué hacer al respecto.` },
      { tag: 'Detrás de escena', text: `Detrás del número: cómo ${sp} logró ${r} y cómo replicarlo.` },
      { tag: 'Errores', text: `5 errores típicos en ${tp} que ${a} cometen (y cómo evitarlos).` },
      { tag: 'Mesa redonda', text: `3 ${a} comparten qué les funcionó este trimestre en ${tp}.` },
      { tag: 'Estilo masterclass', text: `Masterclass: ${tp} para ${a}, con ${sp}.` },
      { tag: 'Antes / después', text: `Antes y después: ${r} en 60 días con un plan paso a paso.` },
      { tag: 'Específico al canal', text: `${r} sin tocar tu budget actual de ${tp}.` },
      { tag: 'Tendencia', text: `${tp} ${new Date().getFullYear() + 1}: lo que cambió y cómo adaptar tu estrategia.` },
      { tag: 'Para skeptics', text: `${r} es real: ${sp} muestra los números detrás de ${tp}.` },
    ];

    out.innerHTML = '';
    lines.forEach(l => {
      const el = document.createElement('div');
      el.className = 'wb-item';
      el.innerHTML = `<span class="wb-tag">${l.tag}</span><div>${l.text}</div>`;
      el.title = 'Click para copiar';
      el.addEventListener('click', () => { navigator.clipboard.writeText(l.text); el.style.borderColor = 'var(--primary)'; setTimeout(() => el.style.borderColor = '', 800); });
      out.appendChild(el);
    });
  }
  gen.addEventListener('click', generate);
  generate();
</script>
