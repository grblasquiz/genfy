---
import Layout from '../../layouts/Layout.astro';
import { GENERATORS, urlFor, CATEGORIES_ES, type GeneratorMeta } from '../../lib/generators';
import { SITE_URL } from '../../lib/i18n';
import { HUB_COPY } from '../../lib/top-hub-data';

export async function getStaticPaths() {
  const cats: GeneratorMeta['category'][] = ['security','tech','data','business','marketing','design','random','pets','people','work','content','inspiration','fun','tools'];
  return cats.map(c => ({ params: { cat: c }, props: { cat: c } }));
}

const { cat } = Astro.props as { cat: GeneratorMeta['category'] };
const lang = 'es' as const;
const top = GENERATORS.filter(g => g.category === cat).slice(0, 10);
const catName = CATEGORIES_ES[cat];
const copy = HUB_COPY[cat]?.es;

const title = `Top 10 generadores de ${catName.toLowerCase()} | Genfy`;
const description = `Los 10 mejores generadores de ${catName.toLowerCase()} en Genfy: gratis, sin registro, todos en el navegador. Curados por uso real.`;

const path = Astro.url.pathname.replace(/\/$/, '');
const itemListSchema = {
  '@context': 'https://schema.org', '@type': 'ItemList',
  name: `Top 10 generadores de ${catName}`,
  numberOfItems: top.length,
  itemListElement: top.map((g, i) => ({ '@type': 'ListItem', position: i + 1, name: g.title.es, url: `${SITE_URL}${urlFor(g, lang)}` })),
};
---
<Layout title={title} description={description} lang={lang} schema={itemListSchema}>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href="/">Inicio</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <a href="/top">Top 10</a>
    <svg class="crumb-sep" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="crumb-current">{catName}</span>
  </nav>

  <header class="hub-hero">
    <span class="hub-eyebrow">Top 10 — {catName}</span>
    <h1>Los 10 mejores generadores de {catName.toLowerCase()}</h1>
    {copy && <p class="hub-intro">{copy.intro}</p>}
  </header>

  <ol class="hub-list">
    {top.map((g, i) => (
      <li class="hub-item">
        <span class="hub-rank">{String(i + 1).padStart(2, '0')}</span>
        <a class="hub-card" href={urlFor(g, lang)}>
          <span class="hub-emoji">{g.emoji}</span>
          <div class="hub-card-text">
            <span class="hub-card-title">{g.title.es}</span>
            <span class="hub-card-desc">{g.description.es}</span>
          </div>
          <span class="hub-card-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ol>

  {copy && (
    <div class="hub-content">
      <section>
        <h2>Por qué importa esta categoría</h2>
        <p>{copy.whyMatters}</p>
      </section>
      <section>
        <h2>Cómo elegir el generador correcto</h2>
        <ul>{copy.pickingTips.map(t => <li>{t}</li>)}</ul>
      </section>
      <section>
        <h2>Cuándo usarlos</h2>
        <ul>{copy.whenToUse.map(t => <li>{t}</li>)}</ul>
      </section>
    </div>
  )}

  <a class="hub-all-link" href={`/generadores#${cat}`}>Ver todos los de {catName.toLowerCase()} →</a>
</Layout>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; color: var(--text-muted); font-size: 0.8125rem; margin: 1.5rem 0 0; flex-wrap: wrap; }
  .crumbs a { color: var(--text-subtle); text-decoration: none; }
  .crumbs a:hover { color: var(--text); }
  .crumb-sep { color: var(--text-muted); flex-shrink: 0; }
  .crumb-current { color: var(--text); font-weight: 500; }
  .hub-hero { padding: 2rem 0 1.5rem; max-width: 720px; }
  .hub-eyebrow { display: inline-block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 0.75rem; }
  .hub-hero h1 { font-size: clamp(1.875rem, 4vw, 2.5rem); margin: 0 0 0.875rem; letter-spacing: -0.02em; }
  .hub-intro { font-size: 1.0625rem; color: var(--text-soft); line-height: 1.55; margin: 0; }
  .hub-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; margin: 0 0 3rem; }
  .hub-item { display: flex; align-items: stretch; gap: 0.875rem; }
  .hub-rank { display: flex; align-items: center; justify-content: center; min-width: 44px; padding: 0.5rem 0; background: var(--bg-inset); border-radius: var(--radius-sm); font-family: var(--font-mono); font-size: 0.875rem; font-weight: 700; color: var(--text-muted); }
  .hub-card { flex: 1; position: relative; display: flex; align-items: center; gap: 0.875rem; padding: 1rem 1.25rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius); text-decoration: none; color: var(--text); transition: border-color 180ms var(--ease), transform 180ms var(--ease); }
  .hub-card:hover { border-color: var(--accent); transform: translateX(2px); text-decoration: none; }
  .hub-emoji { font-size: 1.375rem; flex-shrink: 0; }
  .hub-card-text { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.125rem; }
  .hub-card-title { font-weight: 600; font-size: 0.9375rem; }
  .hub-card-desc { font-size: 0.8125rem; color: var(--text-soft); line-height: 1.5; }
  .hub-card-arrow { color: var(--text-muted); flex-shrink: 0; }
  .hub-card:hover .hub-card-arrow { color: var(--accent); }
  .hub-content { display: grid; gap: 2rem; max-width: 720px; margin-bottom: 3rem; }
  .hub-content h2 { font-size: 1.25rem; margin: 0 0 0.875rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border-soft); }
  .hub-content p { color: var(--text); line-height: 1.65; max-width: 64ch; }
  .hub-content ul { color: var(--text-soft); padding-left: 1.5rem; max-width: 62ch; }
  .hub-content li { margin-bottom: 0.5rem; line-height: 1.55; }
  .hub-all-link { display: inline-block; font-size: 0.9375rem; color: var(--accent); text-decoration: none; font-weight: 500; }
  .hub-all-link:hover { text-decoration: underline; }
</style>
